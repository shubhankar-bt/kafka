package com.fincore.process_status_service.consumer;

import java.sql.Timestamp;
import java.util.Set;
import java.util.stream.Collectors;

import com.fincore.process_status_service.util.TimeUtil;
import org.apache.kafka.common.errors.ResourceNotFoundException;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.stereotype.Component;

import com.fincore.process_status_service.dto.SingleReportCompletedDTO;
import com.fincore.process_status_service.dto.SingleReportStartedDTO;
import com.fincore.process_status_service.model.ProcessRunStage;
import com.fincore.process_status_service.service.ProcessStatusService;
import com.fincore.process_status_service.util.Constants;

import jakarta.validation.ConstraintViolation;
import jakarta.validation.Validator;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;

@Component
@RequiredArgsConstructor
@Slf4j
public class SingleReportEventConsumer {
    private final ProcessStatusService processStatusService;
    private final Validator validator;

    /**
     * JOB STARTED EVENT
     */
    @KafkaListener(topics = "report-builder.single-mode.started", groupId = "Airflow_ETL",  properties = "spring.json.value.default.type=com.fincore.process_status_service.dto.SingleReportStartedDTO")
    public void consumeStarted(SingleReportStartedDTO dto) {

        log.info("DtTO Recieved :{}",dto);
        Set<ConstraintViolation<SingleReportStartedDTO>> violations = validator.validate(dto);

        if (!violations.isEmpty()) {

            String error = violations.stream()
                    .map(ConstraintViolation::getMessage)
                    .collect(Collectors.joining(", "));

            log.error("Started Event Validation Failed: {}", error);
            return;
        }

        log.info("Received STARTED event {}", dto);

        ProcessRunStage stage = processStatusService.getProcessRunStage(
                dto.getStageId(),
                Long.valueOf(dto.getProcessRunId()));
        if(stage == null)
        {
            stage = new ProcessRunStage();
            stage.setStageId(dto.getStageId());
            stage.setStartTime(TimeUtil.getCurrentTimeStamp());

        }
        stage.setStatus(Constants.IN_PROGRESS);
        stage.setSource(Constants.SYSTEM);
        stage.setRemarks("Single Mode :: Report Generation Started for " + dto.getReportType() + " with template Id " + dto.getTemplateId());

        stage.setStartTime(convertEpoch(dto.getJobStartTime()).toLocalDateTime());

        processStatusService.upsertProcessRunStage(stage);
    }

    /**
     * JOB COMPLETED EVENT
     */
    @KafkaListener(topics = "report-builder.single-mode.completed", groupId = "Airflow_ETL" ,  properties = "spring.json.value.default.type=com.fincore.process_status_service.dto.SingleReportCompletedDTO")
    public void consumeCompleted(SingleReportCompletedDTO dto) {

        Set<ConstraintViolation<SingleReportCompletedDTO>> violations = validator.validate(dto);

        if (!violations.isEmpty()) {

            String error = violations.stream()
                    .map(ConstraintViolation::getMessage)
                    .collect(Collectors.joining(", "));

            log.error("Completed Event Validation Failed: {}", error);
            return;
        }

        log.info("Received COMPLETED event {}", dto);

        ProcessRunStage stage = processStatusService.getProcessRunStage(
                dto.getStageId(),
                Long.valueOf(dto.getProcessRunId()));
        if(stage == null)
        {
            throw new ResourceNotFoundException("Stage Not Found");
        }
        stage.setStatus(Constants.SUCCESS);

        stage.setEndTime(convertEpoch(dto.getJobCompletionTime()).toLocalDateTime());

        stage.setRemarks(
                "Total: " + dto.getTotalReports() +
                        ", Completed: " + dto.getCompletedReports() +
                        ", Failed: " + dto.getFailedReports());

        processStatusService.upsertProcessRunStage(stage);
    }

    private  Timestamp convertEpoch(Double epoch) {

        return TimeUtil.convertEpoch(epoch);
    }

}














package com.fincore.process_status_service.consumer;

import com.fincore.process_status_service.dto.SparkEvent;
import com.fincore.process_status_service.exception.AirflowIntegrationException;
import com.fincore.process_status_service.model.ProcessRunStage;
import com.fincore.process_status_service.service.ProcessStatusService;
import com.fincore.process_status_service.util.TimeUtil;
import lombok.AllArgsConstructor;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.jetbrains.annotations.NotNull;
import org.springframework.http.HttpStatus;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.stereotype.Component;

@Component
@RequiredArgsConstructor
@Slf4j

public class SparkEventConsumer {


    private final ProcessStatusService processStatusService;


    @KafkaListener(
            topics = "spark-events",
            groupId = "Airflow_ETL",
            properties = {"spring.json.value.default.type=com.fincore.process_status_service.dto.SparkEvent"}
    )
    public void consume(@NotNull SparkEvent sparkEvent)  {

        log.info("Received Spark Event:{}",sparkEvent);

        if(sparkEvent.isUpdatedRequired())
        {
            log.info("Updating DB due to Spark Event");
            log.info("Process Run Id:{}",sparkEvent.getProcessRunId());
            log.info("Stage Id:{}",sparkEvent.getStageId());

            ProcessRunStage processRunStage = processStatusService.getProcessRunStage(sparkEvent.getStageId(), sparkEvent.getProcessRunId()) ;
            if(processRunStage==null ){
                throw new AirflowIntegrationException("The Entry trying to be updated is not found", HttpStatus.NOT_FOUND);
            }
            processRunStage.setStatus(sparkEvent.getStatus());
            processRunStage.setRemarks(sparkEvent.getRemarks());
            processRunStage.setEndTime(TimeUtil.getCurrentTimeStamp());
            processStatusService.upsertProcessRunStage(processRunStage);
        }
        processStatusService.sendProcessStatusUpdates();
    }
}



















package com.fincore.process_status_service.consumer;


import com.fincore.process_status_service.dto.*;
import com.fincore.process_status_service.exception.AirflowIntegrationException;
import com.fincore.process_status_service.service.AirflowService;
import com.fincore.process_status_service.service.ProcessOrchestrationService;
import lombok.AllArgsConstructor;
import lombok.NoArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.apache.kafka.common.errors.ResourceNotFoundException;
import org.jetbrains.annotations.NotNull;
import org.springframework.dao.DataIntegrityViolationException;
import org.springframework.http.HttpStatus;
import org.springframework.kafka.annotation.DltHandler;
import org.springframework.kafka.annotation.KafkaHandler;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.kafka.annotation.RetryableTopic;
import org.springframework.kafka.core.KafkaTemplate;
import org.springframework.kafka.retrytopic.DltStrategy;
import org.springframework.kafka.support.Acknowledgment;
import org.springframework.kafka.support.KafkaHeaders;
import org.springframework.messaging.Message;
import org.springframework.messaging.handler.annotation.Header;
import org.springframework.retry.annotation.Backoff;
import org.springframework.stereotype.Component;

import java.util.HashMap;
import java.util.Map;

@Component
@Slf4j
@AllArgsConstructor
@RetryableTopic(
        attempts = "3", // 1 initial try + 2 retries
        backoff = @Backoff(delay = 2000, multiplier = 2.0), // Exponential backoff
        autoCreateTopics = "true",
        exclude = { DataIntegrityViolationException.class } // Immediately DLT these!
)
@KafkaListener(
        topics = "trigger-events",
        groupId = "Airflow_ETL",
        properties = {
                "spring.json.value.default.type=com.fincore.process_status_service.dto.DagRunRequestDTO"
        }
)

public class TriggerRequestEventConsumer {


    AirflowService airflowService;
    private final KafkaTemplate<String, TriggerRequestResponse> kafkaTemplate; // Added for publishing
    private static final String RESPONSE_TOPIC = "trigger-event-responses";
    private final ProcessOrchestrationService processOrchestrationService;



    @RetryableTopic(
            attempts = "3",
            backoff = @Backoff(delay = 2000, multiplier = 2.0),
            autoCreateTopics = "true",
            // Immediately move to DLT for these non-recoverable database errors
            exclude = {
                    DataIntegrityViolationException.class,
                    ResourceNotFoundException.class
            },
            // Stops the container if the DLT publish fails, preventing the infinite loop
            dltStrategy = DltStrategy.FAIL_ON_ERROR
    )

    @KafkaHandler
    public void consume(@NotNull DagRunRequestDTO dagRunRequestDTO, @Header(value="requestId",required = false) String requestIdStr) {
        log.info("Event Received From Common Master Service");
        TriggerRequestResponse triggerRequestResponse = new TriggerRequestResponse();

        try {

            try {
                if (requestIdStr != null) {
                    Long requestId = Long.parseLong(requestIdStr);
                    triggerRequestResponse.setRequestId(requestId);
                    if (dagRunRequestDTO == null || dagRunRequestDTO.getProcessId() == null) {
                        throw new AirflowIntegrationException("Dag Run Request Run is Invalid", HttpStatus.BAD_REQUEST);
                    }
                    // Updating Configuration
                    Map<String,Object> conf = new HashMap<String,Object>();
                    conf.put("requestId",requestIdStr);
                    dagRunRequestDTO.setConf(conf);




                    DagRunResponseDTO dagRunResponseDTO = processOrchestrationService.triggerDagIfNoActiveRun(dagRunRequestDTO);
                    triggerRequestResponse.setTriggerResponse(dagRunResponseDTO);
                    triggerRequestResponse.setProcessRunId(dagRunResponseDTO.getProcessRunId());
                    triggerRequestResponse.setMessage("Successfully triggered the pipeline");
                    triggerRequestResponse.setSuccess(true);



                } else {
                    throw new IllegalArgumentException("Invalid Request ID . Request Id is null");
                }


            } catch (AirflowIntegrationException e) {
                triggerRequestResponse.setMessage(e.getMessage());
                triggerRequestResponse.setSuccess(false);
            }

        } catch (IllegalArgumentException e) {
            triggerRequestResponse.setMessage(e.getMessage());
            triggerRequestResponse.setSuccess(false);
        }




            publishResponse(triggerRequestResponse);





    }

    /**
     * Publishes the response to a result topic, preserving the requestId in headers.
     */
    public void publishResponse(TriggerRequestResponse response) {

        log.info("Response being published :{}",response);
      Message<TriggerRequestResponse> message =
                org.springframework.messaging.support.MessageBuilder
                        .withPayload(response)
                        .setHeader(org.springframework.kafka.support.KafkaHeaders.TOPIC, RESPONSE_TOPIC)
//                        .setHeader("requestId", String.valueOf(requestId)) // Keep the ID linked
                        .build();

        kafkaTemplate.send(message).whenComplete((result, ex) -> {
            if (ex == null) {
                log.info("Successfully published response to {} at offset {}",
                        RESPONSE_TOPIC, result.getRecordMetadata().offset());

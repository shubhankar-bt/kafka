@Component
@Slf4j
@RequiredArgsConstructor
public class NwsaVarianceEventConsumer {

    private final ProcessStatusService processStatusService;

    @KafkaListener(topics = "nwsa-variance-report.started", groupId = "Report-Batch", properties = "spring.json.value.default.type=com.fincore.process_status_service.dto.NwsaVarianceStartedDTO")
    public void consumeStarted(NwsaVarianceStartedDTO dto) {

        ProcessRunStage stage = processStatusService.getProcessRunStage(
                dto.getStageId(),
                Long.valueOf(dto.getProcessRunId()) // processRunId is null
        );

        if (stage == null) {
            stage = new ProcessRunStage();
            stage.setStageId(dto.getStageId());
        }

        stage.setSource(Constants.SYSTEM);
        stage.setStatus(Constants.IN_PROGRESS);
        stage.setSummary(dto.getJobId());

        if (dto.getJobStartTime() != null) {
            long seconds = dto.getJobStartTime().longValue();
            stage.setStartTime(
                    TimeUtil.convertEpoch((double) seconds).toLocalDateTime());
        }

        stage.setRemarks("NWSA Report Started for date: " + dto.getReportDate());

        processStatusService.upsertProcessRunStage(stage);
    }


    @KafkaListener(topics = "nwsa-variance-report.completed", groupId = "Report-Batch", properties = "spring.json.value.default.type=com.fincore.process_status_service.dto.NwsaVarianceCompletedDTO")
    public void consumeCompleted(NwsaVarianceCompletedDTO dto) {

        ProcessRunStage stage = processStatusService.getProcessRunStage(
                dto.getStageId(),
                Long.valueOf(dto.getProcessRunId()));

        stage.setStatus(Constants.SUCCESS);
        stage.setEndTime(TimeUtil.getCurrentTimeStamp());

        stage.setRemarks(
                "Total: " + dto.getTotalReports() +
                        ", Completed: " + dto.getCompletedReports() +
                        ", Failed: " + dto.getFailedReports());

        processStatusService.upsertProcessRunStage(stage);
    }
}




















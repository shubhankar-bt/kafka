    private Map<String, Object> getProcessData(String etlDate, Integer processId) {

        LocalDate etlDateToUse;

        if (StringUtils.hasLength(etlDate)) {
            try {
                etlDateToUse = LocalDate.parse(etlDate); // yyyy-MM-dd
            } catch (DateTimeParseException e) {
                throw new IllegalArgumentException(
                        "Invalid etlDate format. Expected yyyy-MM-dd");
            }
        } else {
//            List<FincoreDate> list = fincoreDateRepository.findAll();
//            if (list.isEmpty()) {
//                throw new IllegalStateException("FINCORE_DATE table has no data");
//            }
//            etlDateToUse = list.get(0).getEtlDate().toLocalDate();
            etlDateToUse = fileService.getEtlDate();
        }


        Map<String, Object> wrapper = new LinkedHashMap<>();


        List<FincoreDate> fincoreList = fincoreDateRepository.findAll();
        if (!fincoreList.isEmpty()) {
            FincoreDate fincore = fincoreList.getFirst();
            Map<String, Object> fincoreJson = new LinkedHashMap<>();
            fincoreJson.put("usersDate",
                    formatDate(fincore.getUsersDate()));
            fincoreJson.put("etlDate",
                    formatDate(fincore.getEtlDate()));
            wrapper.put("fincoreDate", fincoreJson);
        } else {
            throw new ResourceNotFoundException("FinCore Date is Empty");
        }
        log.info("Process Id Recieved :{}", processId);

        List<Integer> excludedStatusesList = List.of(Constants.ARCHIVED);

        List<ProcessRunInfoProj> groupedList = processRunRepository.getProcessInfo(etlDateToUse, processId,excludedStatusesList);
        if (groupedList == null || groupedList.isEmpty()) {
            return wrapper;
        }
        Map<Long, ProcessRunInfo> map = new LinkedHashMap<>();
        groupedList.forEach(row -> {
            ProcessRunInfo process =
                    map.computeIfAbsent(row.getProcessRunId(), id -> {
                        ProcessRunInfo p = new ProcessRunInfo();
                        p.setProcessRunId(row.getProcessRunId());
                        p.setProcessId(row.getProcessId());
                        p.setRunId(row.getRunId());
                        p.setProcessType(row.getProcessType());
                        p.setProcessStartTime(row.getProcessStartTime());
                        p.setProcessEndTime(row.getProcessEndTime());
                        p.setTriggeredBy(row.getTriggeredBy());
                        p.setEtlDate(row.getEtlDate());
                        p.setStatus(row.getProcessStatus());
                        p.setExecutionRemarks(row.getProcessExecutionRemarks());
                        p.setAirflowRunId(row.getAirflowRunId());
                        p.setDagId(row.getDagId());
                        p.setStages(new ArrayList<ProcessRunStageInfo>());
                        return p;
                    });
            ProcessRunStageInfo stage = new ProcessRunStageInfo();
            stage.setStageId(row.getStageId());
            stage.setStageStatus(row.getStageStatus());
            stage.setStageRemarks(row.getStageRemarks());
            stage.setSummary(clobToString(row.getSummary()));
            stage.setStageTitle(row.getStageTitle());
            stage.setStageIcon(row.getStageIcon());
            stage.setStartTime(row.getStageStartTime());
            stage.setEndTime(row.getStageEndTime());
            stage.setStageSource(row.getStageSource());
            process.getStages().add(stage);
        });


        wrapper.put("initialData", List.copyOf(map.values()));
        return wrapper;
    }


    /*
     * Converts Oracle CLOB objects to a normal JAva String.
     * Handles both java.sql.Clob and oracle.sql.Clob objects.
     */
    private String clobToString(Object clobObj) {
        try {
            StringBuilder sb = new StringBuilder();
            if (clobObj == null)
                return null;
            if (clobObj instanceof java.sql.Clob clob) {
                Reader reader = clob.getCharacterStream();

                char[] buffer = new char[2048];
                int length;
                while ((length = reader.read(buffer)) != -1) {
                    sb.append(buffer, 0, length);
                }
                return sb.toString();
            }

            return clobObj.toString();
        } catch (SQLException | IOException e) {
            log.error("Unable to process the Payload");
            return null;
        }
    }

    /**
     * Normalize DB time values to each millis(Timestamp/Date/Long)
     */
    private Long toMills(Object time) {
        if (time == null)
            return 0L;
        if (time instanceof java.sql.Timestamp ts)
            return ts.getTime();
        if (time instanceof java.sql.Date d)
            return d.getTime();
        if (time instanceof Number n)
            return n.longValue();
        return 0L;
    }

    /**
     * Normalizes Db date/timestamp column values into ISO_8601 (yyyy-mm-dd) String.
     * Supports java.sql.Date, java.sql.Timestamp and falls back to string
     * conversion.
     *
     * @param date
     * @return null if value is null.
     */
    private String formatDate(Object date) {
        if (date == null)
            return null;
        if (date instanceof java.sql.Timestamp ts)
            return ts.toLocalDateTime().toLocalDate().toString();
        if (date instanceof java.sql.Date d)
            return d.toLocalDate().toString();
        return String.valueOf(date);
    }


package com.fincore.process_status_service.service;

import com.fincore.commonutilities.buisnessobject.ControlDateService;
import com.fincore.process_status_service.consumer.TriggerRequestEventConsumer;
import com.fincore.process_status_service.dto.DagRunRequestDTO;
import com.fincore.process_status_service.dto.DagRunResponseDTO;
import com.fincore.process_status_service.dto.TriggerRequestResponse;
import com.fincore.process_status_service.model.ProcessRun;
import com.fincore.process_status_service.producer.PipelineFailureProducer;
import com.fincore.process_status_service.util.Constants;
import com.fincore.process_status_service.util.Process;
import com.fincore.process_status_service.util.TimeUtil;
import jakarta.transaction.Transactional;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;

import java.time.*;
import java.time.format.DateTimeParseException;
import java.util.*;
import java.sql.Timestamp;

@Service
@RequiredArgsConstructor
@Slf4j
public class AirflowReconciliationServiceImpl implements AirflowReconciliationService {

    @Value("${reconciliation.queued-timeout-minutes:30}")
    private int queuedTimeoutMinutes;

    private final ProcessStatusService processStatusService;
    private final AirflowService airflowService;
    private final ControlDateService controlDateService;
    private final TriggerRequestEventConsumer triggerRequestEventConsumer;
    private final PipelineFailureProducer pipelineFailureProducer;
    public void reconcileRunningPipelines() {
        LocalDate etlDate = controlDateService.getEtlDate();
        List<ProcessRun> runningProcesses = processStatusService.getRunningProcessesForDate(etlDate);

        if (runningProcesses.isEmpty()) {
            log.info("No Running Processes Found for date :{}", etlDate);
            return;
        }

        log.info("Running Processes :{}", runningProcesses);

        // The method call returns dags which are in running state or queued state
        Map<String, Object> airflowRunningDagInfo = airflowService.getAllRunningDags();

        log.info("All Running / Queued Dags Info:{}", airflowRunningDagInfo);

        if (airflowRunningDagInfo == null) {
            log.warn("No Response from airflow - skipping reconciliation");
            return;
        }
        Integer totalEntries = (Integer) airflowRunningDagInfo.getOrDefault("total_entries", -1);
        log.info("Total Entries Received from airflow:{}", totalEntries);
        List<Map<String, Object>> dagRuns = (List<Map<String, Object>>) airflowRunningDagInfo.getOrDefault("dag_runs", Collections.emptyList());

        // Map AirflowRunId -> Map containing state and dag_id
       int queuedDagCount =0;

        Map<String, Map<String, Object>> airflowActiveRuns = new HashMap<>();

        for (Map<String, Object> dagRun : dagRuns) {
            Map<String, Object> details = new HashMap<>();
            String state = Objects.toString(dagRun.get("state"),null);

            if (Constants.AIRFLOW_QUEUED_STATE.equalsIgnoreCase(state)) {
                queuedDagCount++;
            }

            String dateToUse = Objects.toString(dagRun.get("start_date"),null);
            if (dateToUse == null) dateToUse = Objects.toString(dagRun.get("queued_at"),null);
            if (dateToUse == null) dateToUse = Objects.toString(dagRun.get("logical_date"),null);

            details.put("state", state);
            details.put("dag_id", dagRun.get("dag_id"));
            details.put("dag_start_date", dateToUse);

            // CAPTURE CONF MAP
            details.put("dag_conf", dagRun.getOrDefault("conf", new HashMap<String, Object>()));

            airflowActiveRuns.put((String) dagRun.get("dag_run_id"), details);
        }

        log.info("Queued Dags Count :{}",queuedDagCount);

        for (ProcessRun processRun : runningProcesses) {
            String dbAirflowRunId = processRun.getAirflowRunId();

            // The Dag Run Id associated with the Process Run is not found in airflow
            if (!airflowActiveRuns.containsKey(dbAirflowRunId)) {
                handleStuckProcess(processRun);
            }
            else{
                Map<String, Object> runDetails = airflowActiveRuns.get(dbAirflowRunId);
                Map<String, Object> dagConf = (Map<String, Object>) runDetails.get("dag_conf");
                String state = Objects.toString(runDetails.get("state"),null);
                String dagId = Objects.toString(runDetails.get("dag_id"),null);
                String dagStartedAtStr = Objects.toString(runDetails.get("dag_start_date"),null);



                if (Constants.AIRFLOW_QUEUED_STATE.equalsIgnoreCase(state)
                        && isTimeLimitExceeded(processRun.getStartTime() , dagStartedAtStr)
                ) {
                    // Now we have the dagId to stop it in Airflow
                    log.warn("Process  with Process Run ID {} is stuck in queued state. Stopping Airflow Dag {} with Dag Run ID {}",processRun.getProcessRunId(),dagId,processRun.getAirflowRunId());
                    handleProcessStuckInQueue(processRun, dagId,dagConf);
                }



            }








        }





    }

    private Boolean isTimeLimitExceeded(LocalDateTime processStartTime, String dagStartTimeStr) {
        if (dagStartTimeStr == null || processStartTime == null) return false;

        try {
            LocalDateTime now = TimeUtil.getCurrentIstLocalDateTime();

            LocalDateTime airflowStart = TimeUtil.parseAirflowUtcToIst(dagStartTimeStr);

            long diffDb = TimeUtil.getMinutesBetween(processStartTime, now);
            long diffAirflow = TimeUtil.getMinutesBetween(airflowStart, now);



            log.debug("Diff DB: {} mins, Diff Airflow: {} mins", diffDb, diffAirflow);

            return diffDb > queuedTimeoutMinutes && diffAirflow > queuedTimeoutMinutes;

        } catch (DateTimeParseException e) {
            log.error("Failed to parse Airflow timestamp: {}", dagStartTimeStr);
            return false;
        } catch (DateTimeException e) {
            log.error("Time conversion error for inputs: {} , {}", processStartTime, dagStartTimeStr);
            return false;
        }
    }

    /**
     * Will handle cases where the process is queued  in airflow for a long time , but the process is still in PROGRESS state in db
     *
     * @param processRun
     */
    private void handleProcessStuckInQueue(ProcessRun processRun,String dagId,Map<String,Object> conf) {
        processRun.setStatus(Constants.FAILED);
        processRun.setExecutionRemarks("Reconciled: Airflow DAG Was in queue for more than estimated time.");

        // Stop the queued dag
        DagRunRequestDTO requestDTO = new DagRunRequestDTO();
        Map<String,Object> requestConf = new HashMap<String , Object>();
        requestConf.put("reason","queued for a very long time");
        requestDTO.setConf(requestConf);
        airflowService.stopFincoreDag(requestDTO,dagId,processRun.getAirflowRunId());

        // Mark the process as failed in
        processStatusService.endProcess(processRun);
        publishResponseToDependentConsumers(processRun,conf);
    }

    /**
     * Will handle cases where the process is failed in airflow , but the process is still in PROGRESS state in db
     *
     * @param processRun
     */
    private void handleStuckProcess(ProcessRun processRun) {
        processRun.setStatus(Constants.FAILED);
        processRun.setExecutionRemarks("Reconciled: Airflow DAG not running");
        processStatusService.endProcess(processRun);
        publishResponseToDependentConsumers(processRun,Collections.emptyMap());
    }

    private void publishResponseToDependentConsumers(ProcessRun processRun,Map<String,Object> conf) {
//        TriggerRequestResponse triggerRequestResponse = new TriggerRequestResponse();
//        DagRunResponseDTO dagRunResponseDTO = new DagRunResponseDTO();
//        dagRunResponseDTO.setProcessRunId(processRun.getProcessRunId());
//        dagRunResponseDTO.setProcessId(processRun.getProcessId());
//        dagRunResponseDTO.setRunId(processRun.getRunId());
//        dagRunResponseDTO.setEtlDate(processRun.getEtlDate());
//        triggerRequestResponse.setTriggerResponse(dagRunResponseDTO);

        pipelineFailureProducer.sendFailureMessage(processRun,conf);

//        if (Objects.equals(processRun.getProcessId(), Process.YEAR_END_PROFIT_TRANSFER)) {
//            triggerRequestEventConsumer.publishResponse(triggerRequestResponse);
//        }

    }

}









@Slf4j
@Service
@RequiredArgsConstructor
public class ProcessOrchestrationServiceImpl implements ProcessOrchestrationService {

    private final ProcessStatusService processStatusService;
    private final AirflowService airflowService;
    private final FileService fileService;
    private final List<Integer> archiveProcessesList = List.of(Process.YEAR_END_PROFIT_TRANSFER);
    private final List<Integer> preDifferenceList = List.of(
            Process.CBS,Process.GLIF,Process.CONTROL_PIPELINE,Process.PRECHECK_PIPELINE,
            Process.EOD,Process.DIFFERENCE,Process.GLIF_ALL_DATA,Process.GLIF_ALL_DATA);
    private final List<Integer> differenceDependentList = List.of(Process.REPORT_GENERATION,Process.ETL_PLUS_ONE);

    @Transactional
    public DagRunResponseDTO triggerDagIfNoActiveRun(
            DagRunRequestDTO request
    ) {

        FincoreProcess process = processStatusService.verifyDag(request.getProcessId());
        request.setDagId(process.getDagId());
        LocalDate etlDate = fileService.getEtlDate();
        if (airflowService.hasActiveRun(process.getDagId())) {
            throw new AirflowIntegrationException(
                    "An Dag is already running or queued with that id",
                    HttpStatus.CONFLICT
            );
        }

        if(preDifferenceList.contains(process.getProcessId()))
        {
            List<ProcessRun> processesWaitingForApproval = processStatusService.getApprovalPendingProcesses(etlDate);

            if(!processesWaitingForApproval.isEmpty())
            {
                throw new AirflowIntegrationException(
                        "Please approve or reject Difference Pipeline before trying to trigger this Dag.",
                        HttpStatus.CONFLICT
                );
            }
        }




       try{
           Map<String,Object> airflowResponse = airflowService.triggerDag(request);


           if (airflowResponse != null && (
                   String.valueOf(airflowResponse.get("state")).equalsIgnoreCase("queued") ||

                           String.valueOf(airflowResponse.get("state")).equalsIgnoreCase("running"))) {






               ProcessRun processRun = new ProcessRun();
               processRun.setProcessId(request.getProcessId());
               processRun.setAirflowRunId(String.valueOf(airflowResponse.get("dag_run_id")));
               processRun.setTriggeredBy(request.getTriggeredBy());
               processRun.setEtlDate(etlDate);
               processRun.setStartTime(TimeUtil.getCurrentTimeStamp());
               processRun.setStatus(Constants.IN_PROGRESS);
               processRun.setRemarks(request.getRemarks());
               processRun.setRunId(processStatusService.getNextRunId(processRun.getProcessId(), etlDate));

               ProcessRun newProcessRun = processStatusService.insertProcess(processRun);
               ProcessRunStage processRunStage = new ProcessRunStage();
               processRunStage.setStatus(Constants.IN_PROGRESS);
               processRunStage.setProcessRunId(newProcessRun.getProcessRunId());
               processRunStage.setSource("system");
               processRunStage.setStartTime(TimeUtil.getCurrentTimeStamp());
               processRunStage.setStageId("dag_triggered");
               processStatusService.upsertProcessRunStage(processRunStage);

               // Creating Trigger Message


               String triggerMessage = "DAG triggered successfully by " + newProcessRun.getTriggeredBy() + (
                       String.valueOf(airflowResponse.get("state")).equalsIgnoreCase("queued") ? " and Dag is in queue." : " and Dag is in running state."
               );

                // Check if pipeline needs to be Archived
               if(archiveProcessesList.contains(newProcessRun.getProcessId()))
               {
                   processStatusService.archiveProcesses(newProcessRun.getProcessId(),newProcessRun.getProcessRunId());
               }


               // Constructing Response DTO
               DagRunResponseDTO dto = new DagRunResponseDTO();
               dto.setAirflowResponse(new HashMap<String, Object>(airflowResponse));
               dto.setTriggeredBy(newProcessRun.getTriggeredBy());
               dto.setTriggerMessage(triggerMessage);
               dto.setEtlDate(etlDate);
               dto.setProcessId(newProcessRun.getProcessId());
               dto.setRunId(newProcessRun.getRunId());
               dto.setProcessRunId(newProcessRun.getProcessRunId());

               return dto;
           } else {
               throw new AirflowIntegrationException("Failed to trigger DAG [" + request.getDagId() + "]: ", HttpStatus.EXPECTATION_FAILED);
           }
       }
       catch (AirflowIntegrationException ex) {

           throw new AirflowIntegrationException(
                   "Failed to trigger DAG [" + request.getDagId() + "]: " + ex.getMessage(),
                   ex.getStatus()
           );
       }
       catch (DataIntegrityViolationException ex)
       {
           throw  new DataIntegrityViolationException("Data Violation");
       }

    }

    public SseEmitter getProcessDataSSE()
    {
        try {
            return processStatusService.getProcessDataSSE();
        } catch (JsonProcessingException e) {
            throw new RuntimeException(e);
        }


    }


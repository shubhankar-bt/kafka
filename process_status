    @Override
    public DagRunResponseDTO stopPipeline(DagRunRequestDTO request) {

        FincoreProcess process =  processStatusService.verifyDag(request.getProcessId());

        log.info("request:{}", request);
        if (!airflowService.hasActiveRun(process.getDagId())) {
            throw new AirflowIntegrationException(
                    "No Dag is running with that id",
                    HttpStatus.CONFLICT
            );
        }
        LocalDate etlDate = fileService.getEtlDate();



        ProcessRun processRun = processStatusService.getDagRunInstance(request.getDagRunId(),  process.getProcessId());
        Map<String,Object> airflowResponse = airflowService.stopFincoreDag(request,process.getDagId(),processRun.getAirflowRunId());
        if (airflowResponse!=null && String.valueOf(airflowResponse.get("state")).equalsIgnoreCase("failed")) {
            processRun.setStatus(Constants.STOPPED_BY_USER);
            processRun.setRemarks(request.getRemarks());
            processRun.setExecutionRemarks("Process is stopped by user " + request.getTriggeredBy());
            processStatusService.endProcess(processRun);
            DagRunResponseDTO dto = new DagRunResponseDTO();
            dto.setAirflowResponse(new HashMap<String, Object>(airflowResponse));
            dto.setTriggerMessage("DAG stopped successfully");
            dto.setTriggeredBy(request.getTriggeredBy());
            dto.setEtlDate(etlDate);
            return dto;
        } else {
            throw new AirflowIntegrationException(
                    "Failed to stop the process",
                    HttpStatus.EXPECTATION_FAILED
            );
        }
    }


    @Transactional
    public ApproveRejectResponseDTO approveOrRejectProcess(ApproveRejectDto approveRejectDto)
    {
        log.info("Approve Reject DTo:{}",approveRejectDto);
        String actionFlag = approveRejectDto.getActionFlag();
        if(!(actionFlag.equalsIgnoreCase(Constants.ACCEPT)) && !(actionFlag.equalsIgnoreCase(Constants.REJECT)))
        {
            throw new IllegalArgumentException("Not an Accepted Value");
        }
        ProcessRun processRun = processStatusService.getProcessRunByProcessRunId(approveRejectDto.getProcessRunId());
        if(processRun==null)
        {
            throw new ResourceNotFoundException("No process found with process run id " + approveRejectDto.getProcessRunId());
        }
        if(!Objects.equals(processRun.getStatus(), Constants.WAITING_FOR_APPROVAL))
        {
            throw new ResourceNotFoundException("The Request is not in waiting for approval state");
        }


        ProcessRunStage processRunStage = processStatusService.getByStageIdAndProcessRunId(Constants.WAITING_FOR_APPROVAL_STAGE, approveRejectDto.getProcessRunId());
        if(processRunStage==null)
        {
            throw new ResourceNotFoundException("No Entry found with Stage Waiting For Approval for process run id " + approveRejectDto.getProcessRunId());
        }
        processRunStage.setRemarks(approveRejectDto.getRemarks());
        processRunStage.setEndTime(TimeUtil.getCurrentTimeStamp());
        processRunStage.setStatus(Constants.SUCCESS);

        // Triggering Report Generation Pipeline:
        DagRunRequestDTO dagRunRequestDTO = new DagRunRequestDTO();
        dagRunRequestDTO.setProcessId(Process.REPORT_GENERATION);
        dagRunRequestDTO.setRemarks(approveRejectDto.getRemarks());
        dagRunRequestDTO.setAction(Constants.START);
        dagRunRequestDTO.setTriggeredBy(approveRejectDto.getUserId());


        ApproveRejectResponseDTO approveRejectResponseDTO = new ApproveRejectResponseDTO();
        List<DagRunResponseDTO> dagRunResponses = new ArrayList<DagRunResponseDTO>();
        if(actionFlag.equalsIgnoreCase(Constants.ACCEPT))
        {
//            DagRunResponseDTO dagRunResponseDTO = triggerDagIfNoActiveRun(dagRunRequestDTO);
            //approveRejectResponseDTO.setDagRun(dagRunResponseDTO);
            dagRunResponses = triggerDifferenceDependentPipelines(approveRejectDto.getUserId());
            approveRejectResponseDTO.setDagRuns(dagRunResponses);


        }


        processStatusService.upsertProcessRunStage(processRunStage);

        processRun.setStatus(actionFlag.equalsIgnoreCase(Constants.ACCEPT) ? Constants.APPROVED_BY_USER
                : (actionFlag.equalsIgnoreCase(Constants.REJECT) ? Constants.REJECTED_BY_USER : null ));
        processRun.setEndTime(TimeUtil.getCurrentTimeStamp());
        processStatusService.insertProcess(processRun);


        approveRejectResponseDTO.setProcessRunId(processRun.getProcessRunId());
        approveRejectResponseDTO.setMessage("Process" + actionFlag.toUpperCase() + "ED" );

        return approveRejectResponseDTO;
    }


    public List<DagRunResponseDTO> triggerDifferenceDependentPipelines(String userId)
    {
        List<DagRunResponseDTO> dagRunResponses = new ArrayList<DagRunResponseDTO>();
        differenceDependentList.forEach(pipelineId ->{

            DagRunRequestDTO dagRunRequestDTO = new DagRunRequestDTO();
            dagRunRequestDTO.setTriggeredBy(userId);
            dagRunRequestDTO.setProcessId(pipelineId);

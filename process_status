package com.fincore.process_status_service.client;

import com.fincore.process_status_service.exception.AirflowIntegrationException;
import com.fincore.process_status_service.service.NiFiAuthService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.core.ParameterizedTypeReference;
import org.springframework.http.*;
import org.springframework.retry.annotation.Retryable;
import org.springframework.stereotype.Component;
import org.springframework.web.reactive.function.client.WebClient;
import org.springframework.web.reactive.function.client.WebClientResponseException;
import org.springframework.web.util.UriBuilder;
import reactor.core.publisher.Mono;

import java.net.URI;
import java.util.Map;
import java.util.function.Function;

@Slf4j
@Component
@RequiredArgsConstructor
public class NiFiRestClient {

    private final WebClient nifiApiClient;
    private final NiFiAuthService authService;

    public Function<UriBuilder, URI> uri(String path) {
        return uriBuilder -> uriBuilder.path(path).build();
    }

    public Function<UriBuilder, URI> uri(String path, Map<String, ?> queryParams) {
        return uriBuilder -> {
            UriBuilder builder = uriBuilder.path(path);
            if (queryParams != null) {
                queryParams.forEach(builder::queryParam);
            }
            return builder.build();
        };
    }

    @Retryable(
            retryFor = WebClientResponseException.Unauthorized.class,
            maxAttempts = 3
    )
    public <T> T execute(HttpMethod method, String path, Object body, Class<T> responseClass) {
        try {
            return doRequest(method, uri(path), body, spec -> spec.bodyToMono(responseClass));
        } catch (WebClientResponseException.Unauthorized ex) {
            authService.clearToken();
            throw ex;
        }
    }

    private <T> T doRequest(
            HttpMethod method,
            Function<UriBuilder, URI> uriFn,
            Object body,
            Function<WebClient.ResponseSpec, Mono<T>> decoder
    ) {
        String token = authService.getToken();

        WebClient.ResponseSpec responseSpec = nifiApiClient
                .method(method)
                .uri(uriFn)
                .header(HttpHeaders.AUTHORIZATION, "Bearer " + token)
                .contentType(MediaType.APPLICATION_JSON)
                .bodyValue(body != null ? body : Map.of())
                .retrieve()
                .onStatus(HttpStatus.UNAUTHORIZED::equals, response -> {
                    log.warn("NiFi 401 detected. Clearing token cache.");
                    authService.clearToken();
                    return response.createException();
                })
                .onStatus(status -> status.is4xxClientError() || status.is5xxServerError(), response ->
                        response.bodyToMono(String.class)
                                .flatMap(errorBody -> {
                                    log.error("NiFi API Error: {}", errorBody);
                                    return Mono.error(new AirflowIntegrationException(
                                            errorBody,
                                            (HttpStatus) response.statusCode()
                                    ));
                                })
                );

        return decoder.apply(responseSpec).block();
    }

    @Retryable(
            retryFor = WebClientResponseException.Unauthorized.class,
            maxAttempts = 3
    )
    public <T> T execute(
            HttpMethod method,
            Function<UriBuilder, URI> uriFn,
            Object body,
            ParameterizedTypeReference<T> responseType
    ) {
        try {
            return doRequest(method, uriFn, body, spec -> spec.bodyToMono(responseType));
        } catch (WebClientResponseException.Unauthorized ex) {
            authService.clearToken();
            throw ex;
        }
    }
}
















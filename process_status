import java.util.Map;

@Slf4j
@Service
@AllArgsConstructor
public class NiFiServiceImpl  implements  NiFiService{


    private final NiFiRestClient nifiRestClient;

    public void testConnection() {
        try {
            // NiFi endpoint to get the authenticated user's details
            JsonNode userDetails = nifiRestClient.execute(
                    HttpMethod.GET,
                    "/flow/current-user",
                    null,
                    JsonNode.class
            );

            System.out.println("Success! Connected as: " + userDetails.get("identity").asText());
        } catch (Exception e) {
            System.err.println("Connection failed: " + e.getMessage());
        }
    }

    /**
     * Start/Stop a Process Group using its Name (e.g., "transfer_test")
     */
    public JsonNode setProcessGroupStateByName(String groupName, String state) {
        log.info("Attempting to {} Process Group by name: {}", state, groupName);

        // Step 1: Find the ID using Search
        String groupId = findGroupIdByName(groupName);

        // Step 2: Use the ID to change state
        return updateFlowState(groupId, state);
    }

    private String findGroupIdByName(String groupName) {
        // NiFi Search API: /flow/search-results?q={query}
        JsonNode searchResponse = nifiRestClient.execute(
                HttpMethod.GET,
                "/flow/search-results?q=" + groupName,
                null,
                JsonNode.class
        );

        // Dig into: searchResults -> processGroupResults (Array)
        JsonNode groupResults = searchResponse.at("/searchResults/processGroupResults");

        for (JsonNode result : groupResults) {
            if (groupName.equalsIgnoreCase(result.get("name").asText())) {
                return result.get("id").asText();
            }
        }

        throw new NiFiException(
                "Could not find a Process Group with name: " + groupName,
                HttpStatus.NOT_FOUND
        );
    }

    private JsonNode updateFlowState(String groupId, String state) {
        // NiFi Flow API: PUT /flow/process-groups/{id}
        Map<String, Object> body = Map.of(
                "id", groupId,
                "state", state.toUpperCase() // "RUNNING" or "STOPPED"
        );

        return nifiRestClient.execute(
                HttpMethod.PUT,
                "/flow/process-groups/" + groupId,
                body,
                JsonNode.class
        );
    }



}












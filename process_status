import org.springframework.kafka.core.KafkaTemplate;
import org.springframework.stereotype.Service;

import java.util.Set;
import java.util.stream.Collectors;

@Service
@RequiredArgsConstructor
@Slf4j
public class NwsaVarianceTriggerProducer {

    private final KafkaTemplate<String, Object> kafkaTemplate;
    private final Validator validator;

    private static final String TOPIC = "nwsa-variance-report.trigger";

    public void trigger(NwsaVarianceTriggerDTO dto) {

        Set<ConstraintViolation<NwsaVarianceTriggerDTO>> violations = validator.validate(dto);

        if (!violations.isEmpty()) {

            String error = violations.stream()
                    .map(ConstraintViolation::getMessage)
                    .collect(Collectors.joining(", "));

            log.error("NWSA Trigger Validation Failed: {}", error);
            return;
        }

        log.info("Producing NWSA trigger event: {}", dto);

        kafkaTemplate.send(TOPIC, dto);
    }
}













package com.fincore.process_status_service.producer;

import com.fincore.process_status_service.model.ProcessRun;
import com.fincore.process_status_service.util.Process;
import com.fincore.process_status_service.util.TimeUtil;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.kafka.core.KafkaTemplate;
import org.springframework.stereotype.Component;

import java.util.HashMap;
import java.util.Map;
import java.util.Objects;

@Component
@RequiredArgsConstructor
@Slf4j
public class PipelineFailureProducer {

    // Using Object as the value type to match your JsonSerializer config
    private final KafkaTemplate<String, Object> kafkaTemplate;

    public void sendFailureMessage(ProcessRun processRun, Map<String, Object> airflowConf) {
        Integer processId = processRun.getProcessId();
        String topic = getTopicForProcess(processId);

        // 1. Create a new map containing all existing key-value pairs from Airflow
        Map<String, Object> finalPayload = new HashMap<>(airflowConf);

        // 2. Add NEW specific key-value pairs
        enrichPayload(finalPayload, processRun);



        log.info("Producing failure object to topic: {} for ProcessId: {}", topic, processId);
        kafkaTemplate.send(topic, String.valueOf(processRun.getProcessRunId()), finalPayload);
    }

    private void enrichPayload(Map<String, Object> payload, ProcessRun processRun) {
        // Adding metadata to the existing map
        payload.put("reconciled_at", TimeUtil.getCurrentTimeStamp().toString());
        payload.put("db_process_run_id", processRun.getProcessRunId());
        payload.put("execution_remarks", processRun.getExecutionRemarks());
        payload.put("process_id", processRun.getProcessId());

        // Process-specific tags
        if (Process.GLIF.equals(processRun.getProcessId())) {
            payload.put("alert_group", "FINANCE");
            payload.put("remediation", "MANUAL_CHECK");
        }


//        else if (Process.CBS.equals(processRun.getProcessId())) {
//            payload.put("alert_group", "IT_OPS");
//            payload.put("remediation", "RETRIGGER_GLIF");
//        }
    }

    private String getTopicForProcess(Integer processId) {



        // Using if-else to handle Integer object comparison safely
        if (Objects.equals(processId, Process.YEAR_END_PROFIT_TRANSFER)) {
            return "year-end-transfer-process-response-event";
        }
//        if (Objects.equals(processId, Process.GLIF)) {
//            return "fincore.failure.glif";
//        }
//        if (Objects.equals(processId, Process.CBS)) {
//            return "fincore.failure.cbs";
//        }

        return "fincore.failure.general";

    }


}


















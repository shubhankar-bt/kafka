import java.time.LocalDateTime;
import java.time.ZoneId;
import java.time.ZonedDateTime;
import java.time.format.DateTimeParseException;
import java.time.temporal.ChronoUnit;

@Slf4j
public class TimeUtil {

    private static final ZoneId IST_ZONE = ZoneId.of("Asia/Kolkata");

    public static String getCurrentUTCTime() {
        String utcTimestamp = Instant.now()
                .truncatedTo(ChronoUnit.SECONDS)
                .toString();
        log.info("TIME:{}", utcTimestamp);
        return utcTimestamp;
    }

    public static LocalDateTime getCurrentTimeStamp() {
        ZonedDateTime zdt = ZonedDateTime.now(ZoneId.of("Asia/Kolkata"));

        //return Timestamp.valueOf(zdt.toLocalDateTime());
        return LocalDateTime.now(ZoneId.of("Asia/Kolkata"));
    }

    public static Instant convertToISTInstant(Timestamp time) {
        if (time == null) return null;
        return time.toLocalDateTime()
                .atZone(IST_ZONE)
                .toInstant();
    }

    /**
     * Converts an Airflow UTC String to an IST LocalDateTime
     */
    public static LocalDateTime parseAirflowUtcToIst(String dagStartTimeStr) throws DateTimeParseException {
        return ZonedDateTime.parse(dagStartTimeStr)
                .withZoneSameInstant(IST_ZONE)
                .toLocalDateTime();
    }

    /**
     * Calculates minutes between two IST LocalDateTime points
     */
    public static long getMinutesBetween(LocalDateTime start, LocalDateTime end) {
        if (start == null || end == null) return 0;
        return java.time.Duration.between(start, end).toMinutes();
    }

    /**
     * Gets current IST time as LocalDateTime for comparison
     */
    public static LocalDateTime getCurrentIstLocalDateTime() {
        return LocalDateTime.now(IST_ZONE);
    }


    public static   Timestamp convertEpoch(Double epoch) {

        long seconds = epoch.longValue();

        return new Timestamp(seconds * 1000);
    }


}












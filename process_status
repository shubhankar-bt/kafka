public class AirflowRestClient {


    private final WebClient airflowApiClient;

    private final AirflowAuthService authService;


    public Function<UriBuilder, URI> uri(String path) {
        return uri(path, null, null);
    }

    public Function<UriBuilder, URI> uri(String path, Map<String, ?> queryParams) {
        return uri(path, null, queryParams);
    }

    public Function<UriBuilder, URI> uri(
            String path,
            Map<String, ?> pathVars,
            Map<String, ?> queryParams
    ) {
        return uriBuilder -> {
            UriBuilder builder = uriBuilder.path(path);
            if (queryParams != null) {
                queryParams.forEach(builder::queryParam);
            }
            if (pathVars != null && !pathVars.isEmpty()) {
                return builder.build(pathVars);
            }
            return builder.build();
        };
    }


    //@NoRetry
    @Retryable(
            retryFor = WebClientResponseException.Unauthorized.class,
            maxAttempts = 3
    )
    public <T> T execute(
            HttpMethod method,
            String path,
            Object body,
            Class<T> responseClass
    ) {
        try {
            return doRequest(
                    method,
                    uri(path),
                    body,
                    responseSpec -> responseSpec.bodyToMono(responseClass)
            );
        } catch (WebClientResponseException.Unauthorized ex) {
            authService.clearToken();
            throw ex;
        }
    }

    private <T> T doRequest(
            HttpMethod method,
            Function<UriBuilder, URI> uriFn,
            Object body,
            Function<WebClient.ResponseSpec, Mono<T>> decoder
    ) {
        String token = authService.getToken();
        WebClient.ResponseSpec responseSpec =
                airflowApiClient
                        .method(method)
                        .uri(uriFn)
                        .header(HttpHeaders.AUTHORIZATION, "Bearer " + token)
                        .contentType(MediaType.APPLICATION_JSON)
                        .bodyValue(body != null ? body : Map.of())
                        .retrieve()
                        .onStatus(
                                HttpStatus.NOT_FOUND::equals,
                                response -> response.bodyToMono(Map.class)
                                        .flatMap(airflowBody -> {
                                            String detail = (String) airflowBody.get("detail");
                                            return Mono.error(new AirflowIntegrationException(
                                                    String.valueOf(detail) !=null ? detail : airflowBody.toString() ,
                                                    HttpStatus.NOT_FOUND
                                            ));
                                        })
                        )
                        .onStatus(HttpStatus.UNAUTHORIZED::equals, response -> {
                            log.warn("401 detected in onStatus. Clearing token.");
                            authService.clearToken();
                            return response.createException(); // This throws the Unauthorized exception
                        })
                        .onStatus(
                                status -> status.value() >= 400 && status.value() != 401,
                                resp -> resp.bodyToMono(String.class)
                                        .map(RuntimeException::new)
                        )
                        .onStatus(
                                status -> status.value() == 500,
                                resp -> resp.bodyToMono(String.class)
                                        .map(RuntimeException::new)
                        )

                ;
        return decoder.apply(responseSpec).block();
    }

    @Retryable(
            retryFor = WebClientResponseException.Unauthorized.class,
            maxAttempts = 3
    )
    public <T> T execute(
            HttpMethod method,
            Function<UriBuilder, URI> uriFn,
            Object body,
            ParameterizedTypeReference<T> responseType
    ) {
        try {
            return doRequest(
                    method,
                    uriFn,
                    body,
                    responseSpec -> responseSpec.bodyToMono(responseType)
            );
        } catch (WebClientResponseException.Unauthorized ex) {
            authService.clearToken();
            throw ex;
        }
    }



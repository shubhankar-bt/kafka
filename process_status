package com.fincore.process_status_service.service;



import com.fincore.process_status_service.config.NifiProperties;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.http.MediaType;
import org.springframework.stereotype.Service;
import org.springframework.web.reactive.function.BodyInserters;
import org.springframework.web.reactive.function.client.WebClient;

@Slf4j
@Service
@RequiredArgsConstructor
public class NiFiAuthService {

    private final WebClient nifiAuthClient;
    private final NifiProperties props;
    private String token;

    public synchronized String getToken() {
        if (token != null) return token;

        log.info("Fetching new NiFi JWT for user: {}", props.getUsername());

        // NiFi returns the JWT as a raw String in the body
        String jwt = nifiAuthClient.post()
                .uri("/access/token")
                .contentType(MediaType.APPLICATION_FORM_URLENCODED)
                .body(BodyInserters.fromFormData("username", props.getUsername())
                        .with("password", props.getPassword()))
                .retrieve()
                .bodyToMono(String.class)
                .block();

        this.token = jwt;
        return jwt;
    }

    public synchronized void clearToken() {
        this.token = null;
    }
}















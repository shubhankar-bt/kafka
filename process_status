package com.fincore.process_status_service.advice;

import com.fincore.process_status_service.dto.ApiResponse;
import org.jetbrains.annotations.NotNull;
import org.springframework.core.MethodParameter;
import org.springframework.core.annotation.AnnotatedElementUtils;
import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.http.converter.HttpMessageConverter;
import org.springframework.http.server.ServerHttpRequest;
import org.springframework.http.server.ServerHttpResponse; 
import org.springframework.web.bind.annotation.ControllerAdvice;
import org.springframework.web.bind.annotation.RestController;
import org.springframework.web.servlet.mvc.method.annotation.RequestMappingHandlerAdapter;
import org.springframework.web.servlet.mvc.method.annotation.ResponseBodyAdvice;

/**
 * Global API response wrapper using {@link ControllerAdvice} and
 * {@link ResponseBodyAdvice}.
 * <p>
 * This class intercepts the return values of controller methods annotated with
 * {@link RestController}
 * and automatically wraps the raw response body in a standardized
 * {@link ApiResponse} structure.
 * This ensures consistency across all successful API responses (e.g., adding a
 * status, message, etc.)
 * without requiring manual wrapping in every controller method.
 * </p>
 */
@ControllerAdvice
public class ApiResponseWrapper implements ResponseBodyAdvice<Object> {

    /**
     * Determines whether this {@link ResponseBodyAdvice} is applicable to the given
     * method return type
     * and message converter.
     *
     * @param returnType    The return type of the controller method.
     * @param converterType The class of the message converter selected for
     *                      rendering the response.
     * @return {@code true} if this advice should be applied, {@code false}
     *         otherwise.
     */
    @Override
    public boolean supports(MethodParameter returnType,
            @NotNull Class<? extends HttpMessageConverter<?>> converterType) {
        // Apply this advice only to methods within classes annotated with
        // @RestController.
        // It specifically excludes methods that already return a ResponseEntity, as
        // those
        // responses are manually controlled by the developer and should not be
        // auto-wrapped.
        return AnnotatedElementUtils.hasAnnotation(returnType.getContainingClass(), RestController.class) &&
                !returnType.getParameterType().equals(ResponseEntity.class);
    }

    /**
     * Invoked after an {@code HttpMessageConverter} selected by the
     * {@link RequestMappingHandlerAdapter}
     * has converted the return value of a controller method to a response body but
     * before the body
     * is written to the output stream.
     *
     * This method performs the actual wrapping of the response body.
     *
     * @param body                  The original response body as returned by the
     *                              controller method.
     * @param returnType            The return type of the controller method.
     * @param selectedContentType   The content type selected by the content
     *                              negotiation process.
     * @param selectedConverterType The converter type selected to write the body to
     *                              the response.
     * @param request               The current server request.
     * @param response              The current server response.
     * @return The potentially modified or wrapped response body (an
     *         {@link ApiResponse} instance).
     */
    @Override
    public Object beforeBodyWrite(Object body, @NotNull MethodParameter returnType,
            @NotNull MediaType selectedContentType,
            @NotNull Class<? extends HttpMessageConverter<?>> selectedConverterType,
            @NotNull ServerHttpRequest request, @NotNull ServerHttpResponse response) {

        // If the body is already an instance of ApiResponse (meaning the controller
        // manually returned a wrapped response), return it as is to prevent double
        // wrapping.
        if (body instanceof ApiResponse<?>) {
            return body;
        }

        // Wrap the original response body in the standard success ApiResponse
        // structure.
        return ApiResponse.success(body);
    }
}















package com.fincore.gateway.Config;

import java.nio.charset.StandardCharsets;
import java.security.KeyFactory;
import java.security.NoSuchAlgorithmException;
import java.security.PrivateKey;
import java.security.spec.InvalidKeySpecException;
import java.security.spec.PKCS8EncodedKeySpec;
import java.util.Base64;
import javax.crypto.Cipher;
import lombok.extern.slf4j.Slf4j;

@Slf4j
public class KeyUtils {

    /**
     * Parses a PKCS#8 PEM formatted private key.
     */
    public static PrivateKey parseRsaPrivateKey(String pem) {
        try {
            String clean = pem.replace("-----BEGIN PRIVATE KEY-----", "")
                              .replace("-----END PRIVATE KEY-----", "")
                              .replaceAll("\\s", "");
            byte[] decoded = Base64.getDecoder().decode(clean);
            PKCS8EncodedKeySpec spec = new PKCS8EncodedKeySpec(decoded);
            KeyFactory kf = KeyFactory.getInstance("RSA");
            return kf.generatePrivate(spec);
        } catch (NoSuchAlgorithmException | InvalidKeySpecException e) {
            log.error("Failed to parse RSA Private Key. Check configuration format.");
            throw new IllegalArgumentException("Invalid RSA private key", e);
        }
    }

    /**
     * Decrypts the Base64 encoded RSA ciphertext.
     */
    public static String decryptRsaPassword(String encryptedBase64, String privateKeyPem) {
        if (encryptedBase64 == null || encryptedBase64.isBlank()) {
            return "";
        }
        try {
            PrivateKey privateKey = parseRsaPrivateKey(privateKeyPem);
            // PKCS1Padding aligns with standard frontend JSEncrypt libraries
            Cipher cipher = Cipher.getInstance("RSA/ECB/PKCS1Padding");
            cipher.init(Cipher.DECRYPT_MODE, privateKey);
            
            byte[] decodedBytes = Base64.getDecoder().decode(encryptedBase64);
            byte[] decryptedBytes = cipher.doFinal(decodedBytes);
            
            return new String(decryptedBytes, StandardCharsets.UTF_8);
        } catch (Exception e) {
            // PROD SECURITY: Never log the exact cryptographic failure reason to prevent Padding Oracle attacks.
            log.warn("Payload decryption failed. Invalid ciphertext provided.");
            throw new SecurityException("Invalid encrypted payload");
        }
    }
}



















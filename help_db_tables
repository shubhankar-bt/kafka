queries used to fetch data from permission tables to help_question_masdter;

CREATE OR REPLACE PROCEDURE SYNC_AI_HELP_PROC AS
BEGIN
    -- STEP 1: Update URLs and Active status for existing screens. 
    -- (This safely ignores question/answer text to protect Admin edits)
    UPDATE help_question_master hqm
    SET (action_link, is_active, screen_name) = (
        SELECT MENU_URL, 'Y', MENU_TITLE
        FROM permissions p
        WHERE p.MENU_ID = hqm.permission_id
    )
    WHERE EXISTS (
        SELECT 1 FROM permissions p WHERE p.MENU_ID = hqm.permission_id
    );

    -- STEP 2: Generate the 4-Angle Multiplier for completely NEW screens
    INSERT INTO help_question_master (
        question_id, screen_name, question_text, answer_content, 
        permission_id, action_link, action_label, pro_tip, is_active
    )
    WITH new_screens AS (
        SELECT MENU_ID, MENU_TITLE, MENU_SUBMENU, MENU_ACTION, MENU_DESCRIPTION, MENU_URL
        FROM permissions
        WHERE MENU_URL IS NOT NULL
          -- Only select screens that are NOT in the help table yet
          AND MENU_ID NOT IN (SELECT NVL(permission_id, 0) FROM help_question_master)
    ),
    question_types AS (
        SELECT 1 AS q_type FROM dual UNION ALL
        SELECT 2 AS q_type FROM dual UNION ALL
        SELECT 3 AS q_type FROM dual UNION ALL
        SELECT 4 AS q_type FROM dual

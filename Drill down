package com.app.analytics.dto;

import jakarta.validation.constraints.NotEmpty;
import jakarta.validation.constraints.NotNull;
import jakarta.validation.constraints.Pattern;
import java.util.List;
import java.util.Map;

public class DrillDownDtos {

    // --- REQUEST DTOs ---
    
    public record DrillDownRequest(
        @NotEmpty(message = "At least one dimension is required")
        List<@Pattern(regexp = "^[a-zA-Z0-9_]+$", message = "Invalid dimension name format") String> dimensions,
        
        @NotEmpty(message = "At least one metric is required")
        List<@Pattern(regexp = "^[a-zA-Z0-9_]+$", message = "Invalid metric name format") String> metrics,
        
        @NotEmpty(message = "Hierarchy array is required to determine leaf nodes dynamically")
        List<@Pattern(regexp = "^[a-zA-Z0-9_]+$", message = "Invalid hierarchy name format") String> hierarchy,
        
        @NotNull(message = "Filters array cannot be null")
        List<FilterDto> filters
    ) {}

    public record FilterDto(
        @NotEmpty(message = "Filter field is required")
        @Pattern(regexp = "^[a-zA-Z0-9_]+$", message = "Invalid filter field format") 
        String field,
        
        @NotEmpty(message = "Filter operator is required") 
        String operator, 
        
        @NotNull(message = "Filter value cannot be null") 
        Object value
    ) {}

    // --- RESPONSE DTOs ---

    public record DrillDownResponse(
        Meta meta,
        List<Map<String, Object>> data
    ) {}

    public record Meta(
        String status,
        String level,
        int rowCount,
        long executionTimeMs
    ) {}
}



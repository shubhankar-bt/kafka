package com.app.analytics.service;

import com.app.analytics.client.DruidRestClient;
import com.app.analytics.component.DruidQueryBuilder;
import com.app.analytics.dto.DrillDownDtos.*;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.cache.annotation.Cacheable;
import org.springframework.stereotype.Service;
import org.springframework.util.CollectionUtils;

import java.util.*;

@Service
public class DruidAnalyticsServiceImpl {

    private static final Logger log = LoggerFactory.getLogger(DruidAnalyticsServiceImpl.class);

    private final DruidRestClient druidRestClient;
    private final DruidQueryBuilder queryBuilder;

    public DruidAnalyticsServiceImpl(DruidRestClient druidRestClient, DruidQueryBuilder queryBuilder) {
        this.druidRestClient = druidRestClient;
        this.queryBuilder = queryBuilder;
    }

    // Cache key built safely to distinguish distinct JSON queries in Redis
    @Cacheable(value = "drillDownData", key = "T(java.lang.String).valueOf(#request.hashCode())")
    public DrillDownResponse getDrillDownData(DrillDownRequest request) {
        long startTime = System.currentTimeMillis();
        String targetDimension = request.dimensions().get(0);
        
        log.info("Initiating drill-down for dimension: [{}] with {} metrics and {} filters", 
                 targetDimension, request.metrics().size(), request.filters().size());

        // 1. Build & Execute
        Map<String, Object> druidPayload = queryBuilder.buildSqlPayload(request, targetDimension);
        List<Map<String, Object>> rawDruidData = druidRestClient.executeQuery(druidPayload);

        // Edge Case: No data returned
        if (CollectionUtils.isEmpty(rawDruidData)) {
            log.info("Druid returned empty result set for dimension: [{}]", targetDimension);
            return new DrillDownResponse(new Meta("SUCCESS", targetDimension, 0, System.currentTimeMillis() - startTime), Collections.emptyList());
        }

        // 2. Resolve hierarchy position
        boolean hasChildren = determineIfHasChildren(targetDimension, request.hierarchy());

        // 3. Format Response to Contract
        List<Map<String, Object>> formattedData = formatResponseData(rawDruidData, targetDimension, hasChildren);

        long executionTime = System.currentTimeMillis() - startTime;
        log.info("Drill-down for [{}] completed successfully in {} ms with {} rows", targetDimension, executionTime, formattedData.size());

        return new DrillDownResponse(new Meta("SUCCESS", targetDimension, formattedData.size(), executionTime), formattedData);
    }

    private boolean determineIfHasChildren(String targetDimension, List<String> hierarchy) {
        int currentIndex = hierarchy.indexOf(targetDimension);
        if (currentIndex == -1) {
            log.warn("Dimension [{}] not found in provided hierarchy array. Defaulting hasChildren to false.", targetDimension);
            return false;
        }
        return currentIndex < hierarchy.size() - 1;
    }

    private List<Map<String, Object>> formatResponseData(List<Map<String, Object>> rawData, String dimension, boolean hasChildren) {
        String dimensionPrefix = dimension.toLowerCase().split("_")[0];
        List<Map<String, Object>> formattedList = new ArrayList<>(rawData.size());

        for (Map<String, Object> row : rawData) {
            Map<String, Object> formattedRow = new LinkedHashMap<>();
            
            // Handle null/empty group-by strings from Druid gracefully
            Object rawName = row.get("name");
            String nameValue = (rawName != null && !rawName.toString().isBlank()) ? rawName.toString() : "Unassigned";
            
            // Create deterministic ID for React Rendering (e.g. branch_mumbai_south)
            String generatedId = dimensionPrefix + "_" + nameValue.toLowerCase().replaceAll("[^a-z0-9]", "_");

            formattedRow.put("id", generatedId);
            formattedRow.put("name", nameValue);
            
            // Map metrics safely
            for (Map.Entry<String, Object> entry : row.entrySet()) {
                if (!entry.getKey().equals("name")) {
                    formattedRow.put(entry.getKey(), entry.getValue() == null ? 0.0 : entry.getValue());
                }
            }
            
            formattedRow.put("hasChildren", hasChildren);
            formattedList.add(formattedRow);
        }

        return formattedList;
    }
}



package com.app.analytics.dto;

import jakarta.validation.constraints.NotBlank;
import jakarta.validation.constraints.NotEmpty;
import jakarta.validation.constraints.NotNull;
import jakarta.validation.constraints.Pattern;
import java.util.List;
import java.util.Map;

public class DrillDownDtos {

    // --- FRONTEND REQUEST ---
    public record DrillDownRequest(
        @NotBlank(message = "viewCode is required to route the request securely")
        @Pattern(regexp = "^[a-zA-Z0-9_]+$", message = "Invalid viewCode format")
        String viewCode,

        @NotEmpty(message = "At least one logical dimension is required")
        List<@Pattern(regexp = "^[a-zA-Z0-9_]+$") String> dimensions,
        
        @NotEmpty(message = "At least one logical metric is required")
        List<@Pattern(regexp = "^[a-zA-Z0-9_]+$") String> metrics,
        
        @NotNull(message = "Filters array cannot be null")
        List<FilterDto> filters
    ) {}

    public record FilterDto(
        @NotBlank String logicalField, // e.g., "Branch"
        @NotBlank String operator, 
        @NotNull Object value
    ) {}

    // --- RESPONSE ---
    public record DrillDownResponse(
        Meta meta,
        List<Map<String, Object>> data
    ) {}

    public record Meta(
        String status,
        String level,
        int rowCount,
        long executionTimeMs
    ) {}

    // --- INTERNAL METADATA CONTEXT (Cached from Oracle) ---
    public record ViewMetadataContext(
        String viewCode,
        String physicalDruidTable,
        String requiredRole,
        List<String> logicalHierarchyOrdered, // e.g., ["Branch", "GeneralLedger", "Account"]
        Map<String, String> dimensionMap,     // e.g., "Branch" -> "BRANCH_CODE"
        Map<String, String> metricMap         // e.g., "TotalAmount" -> "SUM_LCY"
    ) {}
}



package com.fincore.analyticsservice.strategy;

import org.springframework.stereotype.Component;

/**
 * Strategy implementation for calculating Total Balance.
 * * WHY WE USE THIS:
 * The LOAN table has a typo in its column ("BALALANCE").
 * The DEPOSIT table calls it ("BALANCE").
 * By using this Strategy, the frontend just asks for "TotalBalance", 
 * and this code handles the weird database schemas securely without if/else blocks.
 */
@Component
public class SumBalanceStrategy implements MetricStrategy {

    /**
     * The internal code mapped in the Oracle DR_VIEW_METRIC table.
     */
    @Override
    public String getStrategyCode() {
        return "SUM_BALANCE";
    }

    /**
     * Safely constructs the SQL expression.
     * Notice we use the physical DB column we want to sum (e.g., BALALANCE).
     * The UI will receive it as the clean logical name (e.g., "TotalBalance").
     */
    @Override
    public String buildSqlExpression(String logicalAlias) {
        // Change "BALALANCE" to whatever the physical column is for the specific view.
        // If dealing with multiple DBs, you'd create SumLoanBalanceStrategy vs SumDepositBalanceStrategy.
        return "SUM(\"BALALANCE\") AS \"" + logicalAlias + "\"";
    }
}


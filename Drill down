import org.springframework.web.bind.annotation.*;

@RestController
@RequestMapping("/api/reports")
@CrossOrigin(origins = "*") // Configure based on UI host security requirements
public class AnalyticsController {

    private final DruidAnalyticsServiceImpl analyticsService;

    public AnalyticsController(DruidAnalyticsServiceImpl analyticsService) {
        this.analyticsService = analyticsService;
    }

    /**
     * POST /api/reports/drill-down
     * RBAC Note: Protect this endpoint using @PreAuthorize if Spring Security is enabled.
     */
    @PostMapping("/drill-down")
    public ResponseEntity<DrillDownResponse> getDrillDownReport(
            @Valid @RequestBody DrillDownRequest request) {
        
        DrillDownResponse response = analyticsService.getDrillDownData(request);
        return ResponseEntity.ok(response);
    }
}



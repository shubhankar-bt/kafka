package com.app.analytics.component;

import com.app.analytics.dto.DrillDownDtos.FilterDto;
import com.app.analytics.strategy.MetricStrategy;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.stereotype.Component;

import java.util.ArrayList;
import java.util.List;
import java.util.Map;

@Component
public class DruidQueryBuilder {

    private static final Logger log = LoggerFactory.getLogger(DruidQueryBuilder.class);

    /**
     * Safely constructs Druid SQL using validated physical identifiers.
     */
    public Map<String, Object> buildSqlPayload(
            String physicalTable,
            String logicalTargetDim,
            String physicalTargetDim,
            List<String> logicalMetrics,
            Map<String, MetricStrategy> resolvedStrategies,
            List<FilterDto> filters,
            Map<String, String> dimensionTranslationMap) {

        StringBuilder sql = new StringBuilder("SELECT ");
        
        // 1. Grouping Column (Aliased directly to the logical name for the UI!)
        sql.append("\"").append(physicalTargetDim).append("\" AS \"").append(logicalTargetDim).append("\"");
        
        // 2. Metrics (Generated safely via Strategies)
        for (String logicalMetric : logicalMetrics) {
            MetricStrategy strategy = resolvedStrategies.get(logicalMetric);
            sql.append(", ").append(strategy.buildSqlExpression(logicalMetric));
        }
        
        // 3. From physical datasource
        sql.append(" FROM \"").append(physicalTable).append("\" WHERE 1=1 ");

        // 4. Filters (Translated and Parameterized)
        List<Map<String, String>> parameters = new ArrayList<>();
        if (filters != null && !filters.isEmpty()) {
            for (FilterDto filter : filters) {
                String physicalFilterCol = dimensionTranslationMap.get(filter.logicalField());
                if (physicalFilterCol == null) {
                    throw new IllegalArgumentException("Filter dimension not mapped for this view: " + filter.logicalField());
                }
                appendFilterCondition(sql, parameters, physicalFilterCol, filter);
            }
        }
        
        // 5. Group By
        sql.append(" GROUP BY \"").append(physicalTargetDim).append("\"");

        return Map.of(
            "query", sql.toString(),
            "parameters", parameters
        );
    }

    private void appendFilterCondition(StringBuilder sql, List<Map<String, String>> parameters, String physicalCol, FilterDto filter) {
        if ("EQUALS".equalsIgnoreCase(filter.operator())) {
            sql.append(" AND \"").append(physicalCol).append("\" = ? ");
            parameters.add(Map.of("type", "VARCHAR", "value", String.valueOf(filter.value())));
        } else {
            throw new IllegalArgumentException("Unsupported filter operator: " + filter.operator());
        }
    }
}



package com.app.analytics.strategy;

/**
 * Enterprise Strategy Pattern for Druid SQL Metric Generation.
 * Ensures no raw SQL is stored in the database or passed from the UI.
 */
public interface MetricStrategy {
    
    /**
     * @return The internal code mapped in the Oracle DR_VIEW_METRIC table.
     */
    String getStrategyCode();

    /**
     * Safely constructs the SQL expression for this metric.
     * @param logicalAlias The alias expected by the frontend (e.g., "TotalAmount")
     * @return Formatted Druid SQL string (e.g., SUM("LCY_AMT") AS "TotalAmount")
     */
    String buildSqlExpression(String logicalAlias);
}


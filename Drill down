package com.app.analytics.service;

import com.app.analytics.client.DruidRestClient;
import com.app.analytics.component.DruidQueryBuilder;
import com.app.analytics.dto.DrillDownDtos.*;
import com.app.analytics.strategy.MetricStrategy;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.cache.annotation.Cacheable;
import org.springframework.security.access.AccessDeniedException;
import org.springframework.stereotype.Service;
import org.springframework.util.CollectionUtils;

import java.util.*;
import java.util.function.Function;
import java.util.stream.Collectors;

@Service
public class SemanticDrillDownService {

    private static final Logger log = LoggerFactory.getLogger(SemanticDrillDownService.class);

    private final DruidRestClient druidRestClient;
    private final DruidQueryBuilder queryBuilder;
    private final ReportMetadataProvider metadataProvider; // Interface fetching from Oracle
    private final Map<String, MetricStrategy> strategyRegistry;

    public SemanticDrillDownService(
            DruidRestClient druidRestClient, 
            DruidQueryBuilder queryBuilder, 
            ReportMetadataProvider metadataProvider,
            List<MetricStrategy> strategies) {
        this.druidRestClient = druidRestClient;
        this.queryBuilder = queryBuilder;
        this.metadataProvider = metadataProvider;
        // Automatically registers all Spring Beans that implement MetricStrategy
        this.strategyRegistry = strategies.stream()
            .collect(Collectors.toMap(MetricStrategy::getStrategyCode, Function.identity()));
    }

    @Cacheable(value = "drillDownData", key = "T(java.lang.String).valueOf(#request.hashCode())")
    public DrillDownResponse executeDrillDown(DrillDownRequest request, List<String> userRoles) {
        long startTime = System.currentTimeMillis();
        String logicalTargetDim = request.dimensions().get(0);
        
        log.info("Executing DrillDown for view: [{}], logicalDim: [{}]", request.viewCode(), logicalTargetDim);

        // 1. Fetch Metadata context for this view (Cached)
        ViewMetadataContext context = metadataProvider.getViewContext(request.viewCode());

        // 2. Perform RBAC validation
        validateAccess(context.requiredRole(), userRoles);

        // 3. Translate Logical to Physical
        String physicalTargetDim = translateDimension(logicalTargetDim, context.dimensionMap());
        Map<String, MetricStrategy> resolvedMetrics = resolveMetrics(request.metrics(), context.metricMap());

        // 4. Build and Execute Query securely
        Map<String, Object> druidPayload = queryBuilder.buildSqlPayload(
            context.physicalDruidTable(),
            logicalTargetDim,
            physicalTargetDim,
            request.metrics(),
            resolvedMetrics,
            request.filters(),
            context.dimensionMap()
        );

        List<Map<String, Object>> rawDruidData = druidRestClient.executeQuery(druidPayload);

        if (CollectionUtils.isEmpty(rawDruidData)) {
            return new DrillDownResponse(new Meta("SUCCESS", logicalTargetDim, 0, System.currentTimeMillis() - startTime), Collections.emptyList());
        }

        // 5. Determine UI Hierarchy State
        boolean hasChildren = determineIfHasChildren(logicalTargetDim, context.logicalHierarchyOrdered());

        // 6. Format Final UI Response (Deterministic IDs)
        List<Map<String, Object>> formattedData = formatResponseData(rawDruidData, logicalTargetDim, hasChildren);

        long executionTime = System.currentTimeMillis() - startTime;
        return new DrillDownResponse(new Meta("SUCCESS", logicalTargetDim, formattedData.size(), executionTime), formattedData);
    }

    private void validateAccess(String requiredRole, List<String> userRoles) {
        if (requiredRole != null && !userRoles.contains(requiredRole) && !userRoles.contains("ROLE_SUPER_ADMIN")) {
            throw new AccessDeniedException("Insufficient permissions to execute drill-down for this view.");
        }
    }

    private String translateDimension(String logicalName, Map<String, String> dimMap) {
        String physical = dimMap.get(logicalName);
        if (physical == null) {
            throw new IllegalArgumentException("Logical dimension '" + logicalName + "' is not supported in this view.");
        }
        return physical;
    }

    private Map<String, MetricStrategy> resolveMetrics(List<String> logicalMetrics, Map<String, String> metricMap) {
        Map<String, MetricStrategy> resolved = new HashMap<>();
        for (String logicalName : logicalMetrics) {
            String strategyCode = metricMap.get(logicalName);
            if (strategyCode == null || !strategyRegistry.containsKey(strategyCode)) {
                throw new IllegalArgumentException("Logical metric '" + logicalName + "' is not supported in this view.");
            }
            resolved.put(logicalName, strategyRegistry.get(strategyCode));
        }
        return resolved;
    }

    private boolean determineIfHasChildren(String currentDim, List<String> hierarchy) {
        int index = hierarchy.indexOf(currentDim);
        return index != -1 && index < hierarchy.size() - 1;
    }

    private List<Map<String, Object>> formatResponseData(List<Map<String, Object>> rawData, String logicalDim, boolean hasChildren) {
        String idPrefix = logicalDim.toLowerCase() + "_";
        List<Map<String, Object>> result = new ArrayList<>(rawData.size());

        for (Map<String, Object> row : rawData) {
            Map<String, Object> formattedRow = new LinkedHashMap<>();
            
            // The query aliased the physical col to the logicalDim, so we extract it directly
            Object nameObj = row.get(logicalDim);
            String nameValue = (nameObj != null && !nameObj.toString().isBlank()) ? nameObj.toString() : "Unassigned";
            
            formattedRow.put("id", idPrefix + nameValue.toLowerCase().replaceAll("[^a-z0-9]", "_"));
            formattedRow.put("name", nameValue); // UI relies on "name"
            
            for (Map.Entry<String, Object> entry : row.entrySet()) {
                if (!entry.getKey().equals(logicalDim)) {
                    formattedRow.put(entry.getKey(), entry.getValue() == null ? 0.0 : entry.getValue());
                }
            }
            formattedRow.put("hasChildren", hasChildren);
            result.add(formattedRow);
        }
        return result;
    }
}


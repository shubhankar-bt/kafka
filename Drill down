package com.fincore.analyticsservice.controller;

import com.fincore.analyticsservice.dto.DrillDownRequest;
import com.fincore.analyticsservice.dto.DrillDownResponse;
import com.fincore.analyticsservice.dto.ReportConfigResponse;
import com.fincore.analyticsservice.service.ReportConfigService;
import com.fincore.analyticsservice.service.SemanticDrillDownService;
import com.fincore.commonutilities.jwt.JwtUtil;
import jakarta.validation.Valid;
import lombok.extern.slf4j.Slf4j;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.List;

/**
 * Enterprise REST Controller for the Analytics Drill-Down Engine.
 * Follows clean architecture: the controller solely handles HTTP routing, 
 * token extraction, and delegates core business logic to the service layer.
 */
@Slf4j
@RestController
@RequestMapping("/api/v1/analytics")
@CrossOrigin(origins = "*")
public class AnalyticsController {

    private final SemanticDrillDownService semanticDrillDownService;
    private final JwtUtil jwtUtil;
    private final ReportConfigService configService;

    public AnalyticsController(SemanticDrillDownService semanticDrillDownService, JwtUtil jwtUtil, ReportConfigService configService) {
        this.semanticDrillDownService = semanticDrillDownService;
        this.jwtUtil = jwtUtil;
        this.configService = configService;
    }

    /**
     * POST /api/v1/analytics/drill-down
     * Executes the dynamic drill-down query against Apache Druid.
     * * @param request The logical JSON payload from the React frontend.
     * @param token The JWT authorization token.
     * @return DrillDownResponse containing aggregated data and metadata.
     */
    @PostMapping("/drill-down")
    public ResponseEntity<DrillDownResponse> executeDrillDown(
            @Valid @RequestBody DrillDownRequest request,
            @RequestHeader("Authorization") String token) {

        // Extract the integer Role ID (e.g., 10 for Admin, 54 for Branch)
        Integer roleId = jwtUtil.getUserRoleFromToken(token);
        
        // Pass the request and the User's Role ID to the Semantic Engine
        DrillDownResponse response = semanticDrillDownService.executeDrillDown(request, roleId);
        
        return ResponseEntity.ok(response);
    }

    /**
     * GET /api/v1/analytics/config
     * UI calls this immediately on application load to figure out which reports 
     * and dropdowns this specific user is allowed to see.
     */
    @GetMapping("/config")
    public ResponseEntity<List<ReportConfigResponse>> getUIConfiguration(
            @RequestHeader("Authorization") String token) {
        
        Integer roleId = jwtUtil.getUserRoleFromToken(token);
        
        // Fetch only configurations permitted for this Role ID
        List<ReportConfigResponse> config = configService.getPermittedConfigurations(roleId);

        return ResponseEntity.ok(config);
    }
}


package com.app.analytics.component;

import com.app.analytics.dto.DrillDownDtos.DrillDownRequest;
import com.app.analytics.dto.DrillDownDtos.FilterDto;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Component;

import java.util.ArrayList;
import java.util.List;
import java.util.Map;

@Component
public class DruidQueryBuilder {

    private static final Logger log = LoggerFactory.getLogger(DruidQueryBuilder.class);

    @Value("${druid.datasource.name:financial_data}")
    private String datasourceName;

    /**
     * Dynamically builds a secure Druid SQL query mapping frontend dimensions/metrics.
     */
    public Map<String, Object> buildSqlPayload(DrillDownRequest request, String targetDimension) {
        StringBuilder sql = new StringBuilder("SELECT ");
        
        // 1. Target Dimension
        sql.append("\"").append(targetDimension).append("\" AS \"name\"");
        
        // 2. Aggregate Metrics securely
        for (String metric : request.metrics()) {
            sql.append(", SUM(\"").append(metric).append("\") AS \"").append(metric).append("\"");
        }
        
        sql.append(" FROM \"").append(datasourceName).append("\" ");

        // 3. Apply Filters using parameterized SQL values (protects against SQLi)
        List<Map<String, String>> parameters = new ArrayList<>();
        if (request.filters() != null && !request.filters().isEmpty()) {
            sql.append("WHERE 1=1 ");
            for (FilterDto filter : request.filters()) {
                appendFilterCondition(sql, parameters, filter);
            }
        }
        
        // 4. Group By the target dimension explicitly
        sql.append(" GROUP BY \"").append(targetDimension).append("\"");

        return Map.of(
            "query", sql.toString(),
            "parameters", parameters
        );
    }

    private void appendFilterCondition(StringBuilder sql, List<Map<String, String>> parameters, FilterDto filter) {
        switch (filter.operator().toUpperCase()) {
            case "EQUALS" -> {
                sql.append(" AND \"").append(filter.field()).append("\" = ? ");
                parameters.add(Map.of("type", "VARCHAR", "value", String.valueOf(filter.value())));
            }
            case "NOT_EQUALS" -> {
                sql.append(" AND \"").append(filter.field()).append("\" <> ? ");
                parameters.add(Map.of("type", "VARCHAR", "value", String.valueOf(filter.value())));
            }
            // Future extensibility for other operators like IN, LIKE, etc.
            default -> {
                log.warn("Unsupported filter operator requested: {}", filter.operator());
                throw new IllegalArgumentException("Unsupported filter operator: " + filter.operator());
            }
        }
    }
}



package com.fincore.login.entity;

import jakarta.persistence.*;
import lombok.Data;
import java.time.Instant;

@Entity
@Table(name = "LAUNCH_CONFIG")
@Data
public class LaunchConfig {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY) // Or SEQUENCE for Oracle
    @Column(name = "ID")
    private Long id;

    @Column(name = "APP_NAME")
    private String appName;

    @Column(name = "APP_VERSION")
    private String appVersion;

    // Instant automatically represents a specific moment on the UTC timeline
    @Column(name = "LAUNCH_TIMESTAMP", columnDefinition = "TIMESTAMP WITH TIME ZONE")
    private Instant launchTimestamp; 
}









package com.fincore.login.repository;

import com.fincore.login.entity.LaunchConfig;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;

import java.util.Optional;

@Repository
public interface LaunchConfigRepository extends JpaRepository<LaunchConfig, Long> {
    // Fetches the most recently added configuration
    Optional<LaunchConfig> findTopByOrderByIdDesc();
}












package com.fincore.login.service;

import com.fincore.login.dto.LaunchResponse;

public interface LaunchService {
    LaunchResponse getLaunchDetails();
}












package com.fincore.login.service.impl;

import com.fincore.login.dto.LaunchResponse;
import com.fincore.login.entity.LaunchConfig;
import com.fincore.login.repository.LaunchConfigRepository;
import com.fincore.login.service.LaunchService;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;

import java.time.ZoneId;
import java.time.ZonedDateTime;
import java.time.format.DateTimeFormatter;

@Service
@RequiredArgsConstructor
public class LaunchServiceImpl implements LaunchService {

    private final LaunchConfigRepository launchConfigRepository;

    @Override
    public LaunchResponse getLaunchDetails() {
        LaunchConfig config = launchConfigRepository.findTopByOrderByIdDesc()
                .orElseThrow(() -> new RuntimeException("Launch configuration not found in DB"));

        // Force the timestamp into UTC to match the frontend 'Z' requirement
        ZonedDateTime utcLaunchTime = config.getLaunchTimestamp().atZone(ZoneId.of("UTC"));

        DateTimeFormatter dateFormatter = DateTimeFormatter.ofPattern("yyyy-MM-dd");
        DateTimeFormatter timeFormatter = DateTimeFormatter.ofPattern("HH:mm:ss");

        return new LaunchResponse(
                utcLaunchTime.format(dateFormatter),
                utcLaunchTime.format(timeFormatter),
                "UTC",
                config.getAppVersion(),
                config.getAppName()
        );
    }
}











package com.fincore.login.controller;

import com.fincore.login.dto.LaunchResponse;
import com.fincore.login.service.LaunchService;
import lombok.RequiredArgsConstructor;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

@RestController
@RequestMapping("/api/v1/public")
@RequiredArgsConstructor
public class LaunchController {

    private final LaunchService launchService;

    @GetMapping("/start-prod")
    public ResponseEntity<LaunchResponse> getLaunchData() {
        return ResponseEntity.ok(launchService.getLaunchDetails());
    }
}









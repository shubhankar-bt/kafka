import React, { useState, useEffect } from "react";
import { useNavigate } from "react-router-dom";
import CountdownPage from "./CountdownPage"; // adjust import path
import CelebrationOverlay from "./CelebrationOverlay"; // adjust import path
import Login from "../features/auth/pages/Login"; // adjust import path
import { fetchLaunchData } from "../api/launch"; // adjust import path

const LaunchScreen = () => {
  const [launchData, setLaunchData] = useState(null);
  const [isLoading, setIsLoading] = useState(true);
  const [showCelebration, setShowCelebration] = useState(false);
  const [isLaunched, setIsLaunched] = useState(false);

  useEffect(() => {
    const checkLaunchStatus = async () => {
      try {
        const data = await fetchLaunchData();
        // Combine prodDate and launchTime to create a valid Date object
        const target = new Date(`${data.prodDate}T${data.launchTime}Z`); 
        
        if (target.getTime() <= Date.now()) {
          setIsLaunched(true);
        } else {
          setLaunchData({ ...data, targetDate: target });
        }
      } catch (error) {
        console.error("Failed to fetch launch data", error);
        setIsLaunched(true); // Fallback to login if API fails
      } finally {
        setIsLoading(false);
      }
    };

    checkLaunchStatus();
  }, []);

  const handleCountdownComplete = () => {
    setShowCelebration(true);
  };

  const handleCelebrationComplete = () => {
    setShowCelebration(false);
    setIsLaunched(true);
  };

  if (isLoading) return <div>Loading...</div>; // Or use your PageLoader

  if (isLaunched) return <Login />;

  return (
    <>
      {showCelebration ? (
        <CelebrationOverlay 
          version={launchData?.version} 
          onComplete={handleCelebrationComplete} 
        />
      ) : (
        <CountdownPage
          targetDate={launchData?.targetDate}
          appName={launchData?.appName}
          version={launchData?.version}
          onCountdownComplete={handleCountdownComplete}
        />
      )}
    </>
  );
};

export default LaunchScreen;




















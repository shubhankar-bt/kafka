import { fetchEventSource } from "@microsoft/fetch-event-source";
import api from "../../../config/axiosConfig";
import { resolveConfig } from "../../../config/EnvironmentConfig";

const getApiBase = () => {
  try {
    return resolveConfig("/HS") || "/HS";
  } catch {
    return "/HS";
  }
};

export const submitFeedback = async (logId, type) => {
  if (!logId) return;
  try {
    await api.post(`${getApiBase()}/help/feedback`, {
      logId,
      isHelpful: type === "up",
    });
  } catch (err) {
    console.error("[Feedback] Failed:", err);
  }
};

export const trackFaqClick = async (questionText) => {
  if (!questionText) return;
  try {
    await api.post(`${getApiBase()}/help/faqs/track`, { questionText });
  } catch (err) {
    console.error("[FAQ Track] Failed:", err);
  }
};

export const sendMessageSSE = async (
  { userMessage, currentScreen, token },
  handlers,
  abortController,
) => {
  const API_URL = `${getApiBase()}/help/chat`;
  await fetchEventSource(API_URL, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      Authorization: `Bearer ${token}`,
    },
    body: JSON.stringify({ userMessage, currentScreen }),
    signal: abortController?.signal,
    openWhenHidden: true, 
    onopen(response) {
      if (!response.ok) throw new Error(`Server error: ${response.status}`);
    },
    onmessage(event) {
      const parse = () => JSON.parse(event.data);
      switch (event.event) {
        case "start":
          handlers.onStart?.();
          break;
        case "token":
          handlers.onToken?.(parse().token);
          break;
        case "end":
          handlers.onEnd?.(parse());
          break;
        case "suggestion":
          handlers.onSuggestion?.(parse());
          break;
        case "escalation":
          handlers.onEscalation?.(parse());
          break;
        case "error":
          handlers.onError?.(parse().botReply || "An error occurred");
          break;
        case "text_reply":
          handlers.onTextReply?.(parse());
          break;
        default:
          break;
      }
    },
    onerror(err) {
      handlers.onError?.(err.message || "Connection lost");
      throw err;
    },
  });
};














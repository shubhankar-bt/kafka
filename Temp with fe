```java
package com.fincore.NotificationService.controller;

import com.fincore.NotificationService.service.KubernetesAdminService;
import lombok.RequiredArgsConstructor;
import org.apache.kafka.clients.admin.AdminClient;
import org.apache.kafka.clients.admin.DescribeClusterResult;
import org.springframework.http.ResponseEntity;
import org.springframework.kafka.core.KafkaAdmin;
import org.springframework.web.bind.annotation.*;

import java.util.Map;
import java.util.concurrent.TimeUnit;

@RestController
@RequestMapping("/api/admin")
@RequiredArgsConstructor
public class AdminDashboardController {

    private final KubernetesAdminService k8sService;
    private final KafkaAdmin kafkaAdmin; // Provided by Spring Kafka auto-configuration

    private static final String DEBEZIUM_APP_NAME = "debezium-server";

    // --- DEBEZIUM SERVER MANAGEMENT ---

    @GetMapping("/debezium/status")
    public ResponseEntity<Map<String, Object>> getDebeziumStatus() {
        return ResponseEntity.ok(k8sService.getDeploymentStatus(DEBEZIUM_APP_NAME));
    }

    @PostMapping("/debezium/start")
    public ResponseEntity<Map<String, String>> startDebezium() {
        // Scale to 1 to start the connector
        k8sService.scaleDeployment(DEBEZIUM_APP_NAME, 1);
        return ResponseEntity.ok(Map.of("message", "Debezium Server starting..."));
    }

    @PostMapping("/debezium/stop")
    public ResponseEntity<Map<String, String>> stopDebezium() {
        // Scale to 0 to stop the connector completely
        k8sService.scaleDeployment(DEBEZIUM_APP_NAME, 0);
        return ResponseEntity.ok(Map.of("message", "Debezium Server stopped."));
    }

    @PostMapping("/debezium/restart")
    public ResponseEntity<Map<String, String>> restartDebezium() {
        k8sService.restartDeployment(DEBEZIUM_APP_NAME);
        return ResponseEntity.ok(Map.of("message", "Debezium Server restarting..."));
    }

    @GetMapping("/debezium/logs")
    public ResponseEntity<String> getDebeziumLogs(@RequestParam(defaultValue = "200") int lines) {
        return ResponseEntity.ok(k8sService.getDeploymentLogs(DEBEZIUM_APP_NAME, lines));
    }

    // --- KAFKA CLUSTER STATUS ---

    @GetMapping("/kafka/status")
    public ResponseEntity<Object> getKafkaClusterStatus() {
        try (AdminClient adminClient = AdminClient.create(kafkaAdmin.getConfigurationProperties())) {
            DescribeClusterResult cluster = adminClient.describeCluster();
            String clusterId = cluster.clusterId().get(3, TimeUnit.SECONDS);
            int nodeCount = cluster.nodes().get(3, TimeUnit.SECONDS).size();
            
            return ResponseEntity.ok(Map.of(
                    "status", "HEALTHY",
                    "clusterId", clusterId,
                    "brokerCount", nodeCount
            ));
        } catch (Exception e) {
            return ResponseEntity.ok(Map.of("status", "DOWN", "error", e.getMessage()));
        }
    }
}



    private Mono<ResponseEntity<ResponseVO<?>>> initiateOtpPhase(User user) {
        String txId = UUID.randomUUID().toString();
        String plainOtp = generateSecureOtp();
        
        return otpSessionService.saveOtpState(txId, user.getUserId(), plainOtp, false)
            .then(otpKafkaProducer.publishOtpEvent(txId, user.getMobile(), user.getEmail(), plainOtp, user.getFirstName()))
            .map(v -> {
                OtpInitiatedResponseDTO dto = OtpInitiatedResponseDTO.builder()
                    .transactionId(txId)
                    .maskedEmail(maskEmail(user.getEmail()))
                    .maskedMobile(maskMobile(user.getMobile()))
                    .expiresInSeconds(300)
                    .build();
                    
                return ResponseEntity.status(HttpStatus.ACCEPTED).body(
                    ResponseVO.<OtpInitiatedResponseDTO>builder()
                        .statusCode(HttpStatus.ACCEPTED)
                        .message("Credentials verified. OTP sent to registered contacts.")
                        .result(dto)
                        .build()
                );
            });
    }

    // --- PHASE 2: VERIFY OTP (OTP Check -> Issue JWT) ---
    public Mono<ResponseEntity<ResponseVO<?>>> verifyOtp(VerifyOtpRequestDTO requestDto, ServerHttpResponse response) {
        return otpSessionService.verifyOtp(requestDto.getTransactionId(), requestDto.getOtp())
            // .flatMap(userId -> userRepository.findByUserId(userId))
            .flatMap(user -> finalizeLogin(user, response)); 
    }

    // --- PHASE 3: RESEND OTP ---
    public Mono<ResponseEntity<ResponseVO<?>>> resendOtp(ResendOtpRequestDTO requestDto, ServerHttpRequest request) {
        String clientIp = getClientIp(request);
        String txId = requestDto.getTransactionId();
        
        return otpSessionService.checkIpRateLimit(clientIp)
            .then(otpSessionService.processResend(txId, generateSecureOtp()))
            .flatMap(tuple -> {
                String plainOtp = tuple.getT1();
                String userId = tuple.getT2();
                
                // Fetch User to resend to Kafka
                // return userRepository.findByUserId(userId)
                //    .flatMap(user -> otpKafkaProducer.publishOtpEvent(txId, user.getMobile(), user.getEmail(), plainOtp, user.getFirstName()))
                return Mono.empty(); // (Mocked for compilation, replace with DB fetch above)
            })
            .thenReturn(ResponseEntity.accepted().body(
                ResponseVO.builder()
                    .statusCode(HttpStatus.ACCEPTED)
                    .message("A new OTP has been dispatched.")
                    .build()
            ));
    }

    /**
     * Original logic extracted to finalization step.
     */
    private Mono<ResponseEntity<ResponseVO<?>>> finalizeLogin(User user, ServerHttpResponse response) {
        // ... Fetch role data
        // ... Generate JWT & Refresh Tokens
        // ... Call TokenSessionValidator to set Redis Session
        // ... Generate Session AES Key
        // Return 200 OK with LoginResponseDTO
        return Mono.empty(); 
    }

    // --- UTILITIES ---
    private String generateSecureOtp() {
        SecureRandom random = new SecureRandom();
        int otp = 100000 + random.nextInt(900000); 
        return String.valueOf(otp);
    }

    private String getClientIp(ServerHttpRequest request) {
        String ip = request.getHeaders().getFirst("X-Forwarded-For");
        if (ip == null || ip.isEmpty()) {
            ip = request.getRemoteAddress() != null ? request.getRemoteAddress().getAddress().getHostAddress() : "UNKNOWN";
        }
        return ip;
    }

    private String maskEmail(String email) {
        if (email == null || !email.contains("@")) return email;
        String[] parts = email.split("@");
        return (parts[0].length() <= 2 ? "**" : parts[0].charAt(0) + "***" + parts[0].charAt(parts[0].length() - 1)) + "@" + parts[1];
    }

    private String maskMobile(String mobile) {
        if (mobile == null || mobile.length() < 4) return mobile;
        return "******" + mobile.substring(mobile.length() - 4);
    }

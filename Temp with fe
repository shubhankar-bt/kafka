    /**
     * Encrypts a plaintext JSON string using AES-256-GCM.
     * Returns format: "Base64(IV):Base64(Ciphertext)"
     */
    public String encrypt(String plainTextJson, String base64SecretKey) throws GeneralSecurityException {
        
        byte[] decodedKey = Base64.getDecoder().decode(base64SecretKey);
        var secretKey = new SecretKeySpec(decodedKey, 0, decodedKey.length, "AES");

        // Generate a random 12-byte IV for this specific response
        byte[] iv = new byte[12];
        new SecureRandom().nextBytes(iv);
        var gcmParameterSpec = new GCMParameterSpec(TAG_LENGTH_BIT, iv);

        var cipher = Cipher.getInstance(ALGORITHM);
        cipher.init(Cipher.ENCRYPT_MODE, secretKey, gcmParameterSpec);

        byte[] cipherText = cipher.doFinal(plainTextJson.getBytes(StandardCharsets.UTF_8));

        return Base64.getEncoder().encodeToString(iv) + ":" + Base64.getEncoder().encodeToString(cipherText);
    }



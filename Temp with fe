-- 1. Clear out the old, manual data
TRUNCATE TABLE help_question_master;

-- 2. Insert fresh, dynamically generated data from the permissions table
INSERT INTO help_question_master (
    question_id, 
    permission_id, 
    screen_name, 
    question_text, 
    answer_content, 
    action_link, 
    action_label, 
    pro_tip, 
    is_active, 
    created_by, 
    created_date
)
SELECT 
    -- Replace with your actual sequence if you don't use identity columns
    FINCORE.ISEQ$$_78061.nextval, 
    p.MENU_ID,
    p.MENU_SUBMENU,
    
    -- DYNAMIC QUESTION GENERATOR (Based on MENU_ACTION and TITLE)
    CASE 
        WHEN UPPER(p.MENU_ACTION) LIKE '%APPROVE%' OR UPPER(p.MENU_SUBMENU) LIKE '%REQUEST%' THEN 
            'How do I review, approve, or reject pending requests for ' || p.MENU_TITLE || '?'
        WHEN UPPER(p.MENU_SUBMENU) LIKE '%REPORT%' THEN 
            'How do I view, generate, or download the ' || p.MENU_SUBMENU || '?'
        WHEN UPPER(p.MENU_ACTION) LIKE '%CREATE%' OR UPPER(p.MENU_ACTION) LIKE '%MODIFY%' THEN 
            'How do I manage, create, or update records in ' || p.MENU_SUBMENU || '?'
        ELSE 
            'How do I access and navigate the ' || p.MENU_SUBMENU || ' screen?'
    END,
    
    -- DYNAMIC ANSWER GENERATOR (Injects the actual MENU_DESCRIPTION from DB)
    CASE 
        WHEN UPPER(p.MENU_ACTION) LIKE '%APPROVE%' THEN 
            'Navigate to ' || p.MENU_TITLE || ' -> ' || p.MENU_SUBMENU || '. ' || NVL(p.MENU_DESCRIPTION, '') || '. **Important:** FinCore enforces strict Maker-Checker separation. You cannot approve requests that you initiated yourself. Rejections require a mandatory remark.'
        WHEN UPPER(p.MENU_SUBMENU) LIKE '%REPORT%' THEN 
            'Navigate to ' || p.MENU_TITLE || ' -> ' || p.MENU_SUBMENU || '. ' || NVL(p.MENU_DESCRIPTION, '') || '. You can apply relevant filters before downloading the data.'
        ELSE 
            'Navigate to ' || p.MENU_TITLE || ' -> ' || p.MENU_SUBMENU || '. ' || NVL(p.MENU_DESCRIPTION, '') || '. Ensure your active role has the necessary permissions.'
    END,
    
    p.MENU_URL, 
    
    -- DYNAMIC ACTION LABEL
    'Open ' || p.MENU_SUBMENU,
    
    -- DYNAMIC PRO-TIP
    CASE 
        WHEN UPPER(p.MENU_ACTION) LIKE '%APPROVE%' THEN 'Tip: Always verify the Maker''s attached documents and details before taking an approve or reject action.'
        WHEN UPPER(p.MENU_ACTION) LIKE '%CREATE%' THEN 'Tip: You can check the approval status of your submitted actions in the corresponding Requests screen.'
        WHEN UPPER(p.MENU_SUBMENU) LIKE '%REPORT%' THEN 'Tip: Reports involving large date ranges may take a few moments to generate. Please be patient after clicking download.'
        ELSE 'Tip: Use the global search bar to jump to this screen instantly.'
    END,
    
    -- Assuming the 13th column in your data is IS_ACTIVE. Adjust if named differently.
    'Y', 
    'SYSTEM_INIT',
    SYSDATE
FROM permissions p
WHERE p.MENU_URL IS NOT NULL; -- Ignore parent menu headers that don't have URLs



    // ✅ Java 16+ Record to efficiently hold organizational data in memory
    private record OrgDetails(String branchName, String circleName, String circleCode, String circleBranch, boolean isCircle) {}

    @Override
    public Mono<LoginResponse> login(LoginRequest loginRequest) {
        log.info("Processing LDAP Login for user: {}", loginRequest.getUserId());

        return Mono.fromCallable(() -> {
            // 1. Fetch User
            User user = userRepository.findByUserId(loginRequest.getUserId())
                    .orElseThrow(() -> new RuntimeException("User not found: " + loginRequest.getUserId()));

            if (user.getIsDeleted() == 'Y') {
                throw new RuntimeException("User account is disabled");
            }

            // 2. Perform LDAP Auth
            try {
                boolean isLdapAuthSuccess = adAuthenticationService.authenticateUser(loginRequest.getUserId(), loginRequest.getPassword());
                if (!isLdapAuthSuccess) {
                    recordFailedAttempt(user, "LDAP Authentication Failed", "LDAP");
                    throw new RuntimeException("Invalid credentials from AD");
                }
            } catch (Exception e) {
                recordFailedAttempt(user, "LDAP Error: " + e.getMessage(), "LDAP");
                log.error("LDAP Auth failed for {}: {}", loginRequest.getUserId(), e.getMessage());
                throw new RuntimeException("Invalid credentials from AD");
            }

            // 3. Reset failed attempts
            if (user.getUserWrongPasswordCount() > 0) {
                user.setUserWrongPasswordCount(0);
                userRepository.save(user);
            }

            // 4. Fetch Permissions
            List<RolePermissions> rolePermissionsList = rolePermissionsRepository.findByRoleId(user.getRoleId());
            if (rolePermissionsList.isEmpty()) {
                throw new RuntimeException("No permissions configured for user role");
            }
            RolePermissions rolePerms = rolePermissionsList.get(0);
            Set<String> permissions = rolePermissionsList.stream()
                    .map(RolePermissions::getPermissionId)
                    .collect(Collectors.toSet());

            // ✅ 5. Fetch Organization Details (Branch & Circle)
            OrgDetails orgDetails = fetchOrgDetails(user.getBranch());

            // Prepare extra claims for JWT
            Map<String, Object> extraClaims = new HashMap<>();
            extraClaims.put("branchName", orgDetails.branchName());
            extraClaims.put("circleName", orgDetails.circleName());
            extraClaims.put("circleCode", orgDetails.circleCode());
            extraClaims.put("circleBranch", orgDetails.circleBranch());
            extraClaims.put("isCircle", orgDetails.isCircle());

            // ✅ 6. Generate JWT (Passing the extra claims)
            String jwtToken = hmacJwtUtil.generateToken(
                    user.getUserId(), 
                    user.getRoleId(), 
                    rolePerms.getRoleType(), 
                    Set.copyOf(permissions), 
                    extraClaims
            );

            // 7. Save Login Attempt
            saveLoginAttempt(loginRequest.getUserId(), true, "LDAP", "Success", "APP");

            // ✅ 8. Construct enriched LoginResponse
            LoginResponse response = LoginResponse.builder()
                    .accessToken(jwtToken)
                    .tokenType("Bearer")
                    .expiresIn(jwtExpiration)
                    .roleType(rolePerms.getRoleType())
                    .requirePasswordChange(false)
                    .branchName(orgDetails.branchName())
                    .circleName(orgDetails.circleName())
                    .circleCode(orgDetails.circleCode())
                    .circleBranch(orgDetails.circleBranch())
                    .isCircle(orgDetails.isCircle())
                    .build();

            return response;
            
        }).subscribeOn(Schedulers.boundedElastic())
        .flatMap(response -> {
            return saveSessionToRedis(loginRequest.getUserId(), response.getAccessToken())
                    .thenReturn(response);
        });
    }

    /**
     * ✅ O(1) Time Complexity Native Query to fetch Branch and Circle Details.
     */
    private OrgDetails fetchOrgDetails(Integer branchCodeNumber) {
        if (branchCodeNumber == null) {
            return new OrgDetails(null, null, null, null, false);
        }

        // Pad the branch number to exactly 5 digits to match VARCHAR2 CODE in DB
        String paddedBranchCode = String.format("%05d", branchCodeNumber);

        String sql = """
                SELECT 
                    b.NAME as branchName, 
                    c.CIRCLE_NAME as circleName, 
                    b.CIRCLE_CODE as circleCode, 
                    c.BRANCH_CODE as circleBranch
                FROM branch_master b
                JOIN circle_master c ON b.CIRCLE_CODE = c.CIRCLE_CODE
                WHERE b.CODE = ?
                """;

        try {
            return jdbcTemplate.queryForObject(sql, (rs, rowNum) -> {
                String cBranch = rs.getString("circleBranch");
                
                // Logic: isCircle is true if the user's branch exact matches the Circle's main branch
                boolean isCircle = paddedBranchCode.equals(cBranch);
                
                return new OrgDetails(
                        rs.getString("branchName"),
                        rs.getString("circleName"),
                        rs.getString("circleCode"),
                        cBranch,
                        isCircle
                );
            }, paddedBranchCode);
            
        } catch (EmptyResultDataAccessException e) {
            log.warn("Organization details not found for branch code: {}", paddedBranchCode);
            return new OrgDetails(null, null, null, null, false);
        } catch (Exception e) {
            log.error("Error fetching organization details for branch: {}", paddedBranchCode, e);
            return new OrgDetails(null, null, null, null, false);
        }
    }

    private void recordFailedAttempt(User user, String reason, String loginMethod) {
        user.setUserWrongPasswordCount(user.getUserWrongPasswordCount() + 1);
        userRepository.save(user);

        LoginParam limitParam = loginParamRepository.findByParamName("MAX_WRONG_PASSWORD_ATTEMPTS")
                .orElseThrow(() -> new RuntimeException("System configuration error: login params missing"));

        int maxAttempts = Integer.parseInt(limitParam.getParamValue());
        if (user.getUserWrongPasswordCount() >= maxAttempts) {
            user.setPasswordLogin("INACTIVE");
            userRepository.save(user);
            reason += " | Account Locked due to max failed attempts";
        }

        saveLoginAttempt(user.getUserId(), false, loginMethod, reason, "APP");
    }

    private void saveLoginAttempt(String userId, boolean isSuccess, String loginMethod, String failureReason, String appCode) {
        LoginAttempt attempt = new LoginAttempt();
        attempt.setUserId(userId);
        attempt.setLoginMethod(loginMethod); // E.g., "LDAP"
        attempt.setAppCode(appCode);
        attempt.setSuccess(isSuccess);
        attempt.setFailureReason(failureReason);
        attempt.setAttemptTime(LocalDateTime.now());
        attempt.setIpAddress("0.0.0.0"); // Consider passing real IP later
        loginAttemptRepository.save(attempt);
    }

    private Mono<Void> saveSessionToRedis(String userId, String token) {
        String sessionKey = Constants.SESSION_PREFIX + userId;
        Map<String, String> sessionData = new HashMap<>();
        sessionData.put("token", token);
        sessionData.put("loginTime", LocalDateTime.now().toString());

        try {
            String sessionJson = objectMapper.writeValueAsString(sessionData);
            return redisTemplate.opsForValue()
                    .set(sessionKey, sessionJson, Duration.ofSeconds(jwtExpiration))
                    .then();
        } catch (JsonProcessingException e) {
            return Mono.error(new RuntimeException("Error creating session data", e));
        }
    }
}



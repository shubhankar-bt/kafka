# SPRING BOOT BACKEND DEPLOYMENT (UAT: fincore-cbops1)
# =========================================================================
apiVersion: apps/v1
kind: Deployment
metadata:
  name: fincore-helpservice
  namespace: fincore-cbops1
spec:
  replicas: 2
  selector:
    matchLabels:
      app: fincore-helpservice
  template:
    metadata:
      labels:
        app: fincore-helpservice
    spec:
      containers:
      - name: helpservice
        image: your-internal-registry.sbi.com/fincore-backend/helpservice:v1.0
        ports:
        - containerPort: 9099
        env:
        # Override application.properties environment variables here
        - name: SPRING_PROFILES_ACTIVE
          value: "uat"
        resources:
          requests:
            memory: "1Gi"
            cpu: "500m"
          limits:
            memory: "2Gi"
            cpu: "1000m"
        # Increase the readiness probe delays so it doesn't fail while running initial ingestion
        readinessProbe:
          httpGet:
            path: /actuator/health
            port: 9099
          initialDelaySeconds: 45
          periodSeconds: 10
---
# =========================================================================
# SPRING BOOT SERVICE
# =========================================================================
apiVersion: v1
kind: Service
metadata:
  name: fincore-helpservice-svc
  namespace: fincore-cbops1
spec:
  selector:
    app: fincore-helpservice
  ports:
    - protocol: TCP
      port: 9099
      targetPort: 9099

---
# =========================================================================
# INGRESS CONFIGURATION (CRITICAL FOR SSE CHATBOT)
# =========================================================================
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: fincore-helpservice-ingress
  namespace: fincore-cbops1
  annotations:
    # IF YOU USE NGINX INGRESS:
    # You MUST increase these timeouts. By default, NGINX closes idle connections
    # after 60 seconds. Since LLMs stream data, if the LLM takes 61 seconds to finish,
    # NGINX will abruptly cut the stream and the UI will throw a network error.
    nginx.ingress.kubernetes.io/proxy-read-timeout: "300"
    nginx.ingress.kubernetes.io/proxy-send-timeout: "300"
    
    # Required for Server-Sent Events (SSE) so NGINX doesn't buffer the stream
    nginx.ingress.kubernetes.io/proxy-buffering: "off"
spec:
  ingressClassName: nginx
  rules:
  - host: fincore-uat.sbi.com
    http:
      paths:
      - path: /HS/api/help
        pathType: Prefix
        backend:
          service:
            name: fincore-helpservice-svc
            port:
              number: 9099


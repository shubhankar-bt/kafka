    @PostMapping("/login")
    public Mono<ResponseEntity<ResponseVO<?>>> login(@Valid @RequestBody LoginDto loginDto, 
                                                     ServerHttpRequest request, 
                                                     ServerHttpResponse response) {
        log.info("Login Request Initiated for User: {}", loginDto.getUserId());
        return loginService.login(loginDto, request, response);
    }

    @PostMapping("/verify-otp")
    public Mono<ResponseEntity<ResponseVO<?>>> verifyOtp(@Valid @RequestBody VerifyOtpRequestDTO requestDto, 
                                                         ServerHttpResponse response) {
        log.info("OTP Verification Initiated for TxId: {}", requestDto.getTransactionId());
        return loginService.verifyOtp(requestDto, response);
    }

    @PostMapping("/resend-otp")
    public Mono<ResponseEntity<ResponseVO<?>>> resendOtp(@Valid @RequestBody ResendOtpRequestDTO requestDto, 
                                                         ServerHttpRequest request) {
        log.info("OTP Resend Initiated for TxId: {}", requestDto.getTransactionId());
        return loginService.resendOtp(requestDto, request);
    }
    
    // (Existing refresh, logout endpoints remain unchanged)
}


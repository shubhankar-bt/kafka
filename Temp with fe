import React, { useState, useEffect, useRef, useCallback } from 'react';
import {
  Box,
  Card,
  CardContent,
  CardHeader,
  CardActions,
  Grid,
  Typography,
  Button,
  Chip,
  IconButton,
  Tooltip,
  CircularProgress,
  Divider,
  Snackbar,
  Alert,
  Paper,
  Switch,
  FormControlLabel
} from '@mui/material';
import {
  Play,
  Square,
  RotateCcw,
  RefreshCw,
  Copy,
  Terminal,
  Activity,
  Server,
  Pause,
  Trash2
} from 'lucide-react';

// ============================================================================
// INSTRUCTIONS: 
// Import your actual useApi hook here. 
// I am assuming it returns a function (e.g., callApi) that accepts { url, method, payload }.
// import useApi from '../../hooks/useApi'; 
// ============================================================================

// Mocking useApi for demonstration so the file doesn't break. 
// DELETE this mock block and use your actual import above.
const useApi = () => {
  const [loading, setLoading] = useState(false);
  const callApi = async ({ url, method, payload }) => {
    setLoading(true);
    // Simulate API delay
    await new Promise((res) => setTimeout(res, 800));
    setLoading(false);
    console.log(`Called ${method} ${url}`, payload);
    return { data: { status: 'RUNNING', message: 'Success' } }; 
  };
  return { callApi, loading };
};
// --- END MOCK ---

const AdminDashboard = () => {
  const { callApi, loading: apiLoading } = useApi();

  // State Management
  const [kafkaStatus, setKafkaStatus] = useState(null);
  const [debeziumStatus, setDebeziumStatus] = useState(null);
  const [logs, setLogs] = useState("Initializing log stream...\n");
  const [isAutoRefresh, setIsAutoRefresh] = useState(true);
  
  // Loading states for specific actions
  const [isRefreshingStatus, setIsRefreshingStatus] = useState(false);
  const [isActionLoading, setIsActionLoading] = useState(false);
  const [isLogRefreshing, setIsLogRefreshing] = useState(false);

  // Toast Notification State
  const [toast, setToast] = useState({ open: false, message: '', severity: 'info' });

  const logsEndRef = useRef(null);
  const logContainerRef = useRef(null);

  const showToast = (message, severity = 'success') => {
    setToast({ open: true, message, severity });
  };

  const handleCloseToast = () => setToast((prev) => ({ ...prev, open: false }));

  // --- API CALLS ---

  const fetchClusterStatus = useCallback(async () => {
    setIsRefreshingStatus(true);
    try {
      // Fetch Kafka Status
      const kRes = await callApi({ url: '/api/admin/kafka/status', method: 'GET' });
      if (kRes?.data) setKafkaStatus(kRes.data);

      // Fetch Debezium Status
      const dRes = await callApi({ url: '/api/admin/debezium/status', method: 'GET' });
      if (dRes?.data) setDebeziumStatus(dRes.data);
    } catch (error) {
      showToast('Failed to fetch status data.', 'error');
    } finally {
      setIsRefreshingStatus(false);
    }
  }, [callApi]);

  const fetchLogs = useCallback(async (isBackground = false) => {
    if (!isBackground) setIsLogRefreshing(true);
    try {
      const res = await callApi({ url: '/api/admin/debezium/logs?lines=200', method: 'GET' });
      if (res?.data) {
        // If your API returns a raw string, use it directly. If it's JSON, parse it appropriately.
        const logText = typeof res.data === 'string' ? res.data : JSON.stringify(res.data, null, 2);
        setLogs(logText);
      }
    } catch (error) {
      if (!isBackground) showToast('Failed to fetch logs.', 'error');
    } finally {
      if (!isBackground) setIsLogRefreshing(false);
    }
  }, [callApi]);

  const handleDebeziumAction = async (action) => {
    setIsActionLoading(true);
    try {
      const res = await callApi({ url: `/api/admin/debezium/${action}`, method: 'POST' });
      showToast(res?.data?.message || `Successfully executed ${action}.`);
      // Refresh status after 2 seconds to allow K8s to process the scale/restart
      setTimeout(() => fetchClusterStatus(), 2000);
    } catch (error) {
      showToast(`Failed to ${action} Debezium.`, 'error');
    } finally {
      setIsActionLoading(false);
    }
  };

  // --- LIFECYCLE & EFFECTS ---

  // Initial Load
  useEffect(() => {
    fetchClusterStatus();
    fetchLogs();
  }, [fetchClusterStatus, fetchLogs]);

  // Auto-refresh Logs Effect
  useEffect(() => {
    let intervalId;
    if (isAutoRefresh) {
      intervalId = setInterval(() => {
        fetchLogs(true); // silent background fetch
      }, 5000); // Fetch every 5 seconds
    }
    return () => {
      if (intervalId) clearInterval(intervalId);
    };
  }, [isAutoRefresh, fetchLogs]);

  // Auto-scroll logs to bottom when new logs arrive
  useEffect(() => {
    if (isAutoRefresh && logsEndRef.current) {
      logsEndRef.current.scrollIntoView({ behavior: 'smooth' });
    }
  }, [logs]);

  // --- HANDLERS ---

  const handleCopyLogs = () => {
    navigator.clipboard.writeText(logs).then(() => {
      showToast('Logs copied to clipboard!');
    }).catch(() => {
      // Fallback for older browsers or non-secure contexts
      const textArea = document.createElement("textarea");
      textArea.value = logs;
      document.body.appendChild(textArea);
      textArea.select();
      try {
        document.execCommand('copy');
        showToast('Logs copied to clipboard!');
      } catch (err) {
        showToast('Failed to copy logs.', 'error');
      }
      document.body.removeChild(textArea);
    });
  };

  const handleClearLogs = () => {
    setLogs("Logs cleared locally.\n");
  };

  // --- RENDER HELPERS ---

  const getStatusColor = (status) => {
    if (!status) return 'default';
    const s = status.toUpperCase();
    if (s === 'HEALTHY' || s === 'RUNNING') return 'success';
    if (s === 'STOPPED') return 'warning';
    if (s === 'DOWN' || s === 'ERROR') return 'error';
    return 'default';
  };

  return (
    <Box sx={{ p: 3, maxWidth: '1400px', margin: '0 auto' }}>
      
      {/* HEADER */}
      <Box sx={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', mb: 4 }}>
        <Box sx={{ display: 'flex', alignItems: 'center', gap: 2 }}>
          <Activity size={32} color="#1976d2" />
          <Typography variant="h4" fontWeight="600" color="text.primary">
            Streaming Engine Admin
          </Typography>
        </Box>
        <Button 
          variant="outlined" 
          color="primary" 
          startIcon={isRefreshingStatus ? <CircularProgress size={16} /> : <RefreshCw size={18} />}
          onClick={fetchClusterStatus}
          disabled={isRefreshingStatus}
        >
          Refresh Status
        </Button>
      </Box>

      <Grid container spacing={3}>
        
        {/* KAFKA CLUSTER STATUS CARD */}
        <Grid item xs={12} md={6}>
          <Card elevation={2} sx={{ height: '100%', borderRadius: 2 }}>
            <CardHeader 
              title="Kafka Cluster" 
              titleTypographyProps={{ variant: 'h6', fontWeight: 600 }}
              avatar={<Server size={24} color="#555" />}
              action={
                <Chip 
                  label={kafkaStatus?.status || 'UNKNOWN'} 
                  color={getStatusColor(kafkaStatus?.status)} 
                  variant="filled" 
                  size="small"
                  sx={{ fontWeight: 'bold' }}
                />
              }
              sx={{ pb: 0 }}
            />
            <CardContent>
              <Grid container spacing={2} sx={{ mt: 1 }}>
                <Grid item xs={6}>
                  <Typography variant="body2" color="text.secondary">Cluster ID</Typography>
                  <Typography variant="body1" fontWeight="500">
                    {kafkaStatus?.clusterId || '---'}
                  </Typography>
                </Grid>
                <Grid item xs={6}>
                  <Typography variant="body2" color="text.secondary">Active Brokers</Typography>
                  <Typography variant="body1" fontWeight="500">
                    {kafkaStatus?.brokerCount !== undefined ? kafkaStatus.brokerCount : '---'}
                  </Typography>
                </Grid>
              </Grid>
            </CardContent>
          </Card>
        </Grid>

        {/* DEBEZIUM CONNECTOR STATUS CARD */}
        <Grid item xs={12} md={6}>
          <Card elevation={2} sx={{ height: '100%', borderRadius: 2, display: 'flex', flexDirection: 'column' }}>
            <CardHeader 
              title="Debezium Server" 
              titleTypographyProps={{ variant: 'h6', fontWeight: 600 }}
              avatar={<Activity size={24} color="#555" />}
              action={
                <Chip 
                  label={debeziumStatus?.status || 'UNKNOWN'} 
                  color={getStatusColor(debeziumStatus?.status)} 
                  variant="filled" 
                  size="small"
                  sx={{ fontWeight: 'bold' }}
                />
              }
              sx={{ pb: 0 }}
            />
            <CardContent sx={{ flexGrow: 1 }}>
              <Grid container spacing={2} sx={{ mt: 1 }}>
                <Grid item xs={6}>
                  <Typography variant="body2" color="text.secondary">Desired Replicas</Typography>
                  <Typography variant="body1" fontWeight="500">
                    {debeziumStatus?.desiredReplicas !== undefined ? debeziumStatus.desiredReplicas : '---'}
                  </Typography>
                </Grid>
                <Grid item xs={6}>
                  <Typography variant="body2" color="text.secondary">Ready Replicas</Typography>
                  <Typography variant="body1" fontWeight="500">
                    {debeziumStatus?.readyReplicas !== undefined ? debeziumStatus.readyReplicas : '---'}
                  </Typography>
                </Grid>
              </Grid>
            </CardContent>
            <Divider />
            <CardActions sx={{ justifyContent: 'flex-end', p: 2, gap: 1 }}>
              <Button 
                variant="contained" 
                color="success" 
                startIcon={<Play size={16} />}
                onClick={() => handleDebeziumAction('start')}
                disabled={isActionLoading || debeziumStatus?.status === 'RUNNING'}
                disableElevation
              >
                Start
              </Button>
              <Button 
                variant="contained" 
                color="warning" 
                startIcon={<Square size={16} />}
                onClick={() => handleDebeziumAction('stop')}
                disabled={isActionLoading || debeziumStatus?.status === 'STOPPED'}
                disableElevation
              >
                Stop
              </Button>
              <Button 
                variant="contained" 
                color="primary" 
                startIcon={<RotateCcw size={16} />}
                onClick={() => handleDebeziumAction('restart')}
                disabled={isActionLoading}
                disableElevation
              >
                Restart
              </Button>
            </CardActions>
          </Card>
        </Grid>

        {/* LOG VIEWER SECTION */}
        <Grid item xs={12}>
          <Paper 
            elevation={3} 
            sx={{ 
              borderRadius: 2, 
              overflow: 'hidden', 
              display: 'flex', 
              flexDirection: 'column',
              bgcolor: '#1e1e1e', // Dark terminal background
              border: '1px solid #333'
            }}
          >
            {/* Terminal Toolbar */}
            <Box 
              sx={{ 
                bgcolor: '#2d2d2d', 
                px: 2, 
                py: 1, 
                display: 'flex', 
                alignItems: 'center',
                justifyContent: 'space-between',
                borderBottom: '1px solid #000'
              }}
            >
              <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                <Terminal size={18} color="#aaa" />
                <Typography variant="subtitle2" sx={{ color: '#eee', fontFamily: 'monospace' }}>
                  Debezium Pod Logs
                </Typography>
              </Box>
              
              <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                <FormControlLabel
                  control={
                    <Switch 
                      size="small" 
                      checked={isAutoRefresh} 
                      onChange={(e) => setIsAutoRefresh(e.target.checked)} 
                      color="primary"
                    />
                  }
                  label={
                    <Typography variant="caption" sx={{ color: '#aaa', userSelect: 'none' }}>
                      Auto-Tail
                    </Typography>
                  }
                  sx={{ mr: 1, m: 0 }}
                />
                
                <Tooltip title="Refresh Logs Now">
                  <IconButton 
                    size="small" 
                    onClick={() => fetchLogs()} 
                    disabled={isLogRefreshing}
                    sx={{ color: '#aaa', '&:hover': { color: '#fff' } }}
                  >
                    <RefreshCw size={16} className={isLogRefreshing ? "animate-spin" : ""} />
                  </IconButton>
                </Tooltip>
                
                <Tooltip title="Copy Logs">
                  <IconButton 
                    size="small" 
                    onClick={handleCopyLogs}
                    sx={{ color: '#aaa', '&:hover': { color: '#fff' } }}
                  >
                    <Copy size={16} />
                  </IconButton>
                </Tooltip>
                
                <Tooltip title="Clear Window (Local)">
                  <IconButton 
                    size="small" 
                    onClick={handleClearLogs}
                    sx={{ color: '#aaa', '&:hover': { color: '#fff' } }}
                  >
                    <Trash2 size={16} />
                  </IconButton>
                </Tooltip>
              </Box>
            </Box>

            {/* Terminal Output */}
            <Box 
              ref={logContainerRef}
              sx={{ 
                height: '450px', 
                overflowY: 'auto', 
                p: 2,
                '&::-webkit-scrollbar': { width: '8px' },
                '&::-webkit-scrollbar-track': { background: '#1e1e1e' },
                '&::-webkit-scrollbar-thumb': { background: '#555', borderRadius: '4px' },
                '&::-webkit-scrollbar-thumb:hover': { background: '#777' }
              }}
            >
              <Typography 
                component="pre" 
                sx={{ 
                  margin: 0, 
                  fontFamily: '"Fira Code", "Consolas", monospace', 
                  fontSize: '0.85rem',
                  color: '#4af626', // Hacker green
                  whiteSpace: 'pre-wrap',
                  wordBreak: 'break-all',
                  lineHeight: 1.5
                }}
              >
                {logs}
                {/* Invisible element to anchor the auto-scroll */}
                <span ref={logsEndRef} />
              </Typography>
            </Box>
          </Paper>
        </Grid>
      </Grid>

      {/* Global Snackbar for Notifications */}
      <Snackbar
        open={toast.open}
        autoHideDuration={4000}
        onClose={handleCloseToast}
        anchorOrigin={{ vertical: 'bottom', horizontal: 'right' }}
      >
        <Alert onClose={handleCloseToast} severity={toast.severity} sx={{ width: '100%' }} variant="filled">
          {toast.message}
        </Alert>
      </Snackbar>
    </Box>
  );
};

export default AdminDashboard;


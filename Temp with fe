package com.fincore.analyticsservice.component;

import com.fincore.analyticsservice.dto.DimensionConfig;
import com.fincore.analyticsservice.dto.FilterDto;
import com.fincore.analyticsservice.strategy.MetricStrategy;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.stereotype.Component;

import java.util.ArrayList;
import java.util.List;
import java.util.Map;

@Component
public class DruidQueryBuilder {

    private static final Logger log = LoggerFactory.getLogger(DruidQueryBuilder.class);

    public Map<String, Object> buildSqlPayload(
            String physicalTable,
            String logicalTargetDim,
            DimensionConfig targetDimConfig, // Now receives the full config
            List<String> logicalMetrics,
            Map<String, MetricStrategy> resolvedStrategies,
            List<FilterDto> filters,
            Map<String, DimensionConfig> dimensionTranslationMap) {

        StringBuilder sql = new StringBuilder("SELECT ");
        
        // 1. Grouping Column (Dynamically formatted)
        sql.append(formatDimension(targetDimConfig)).append(" AS \"").append(logicalTargetDim).append("\"");
        
        // 2. Metrics
        for (String logicalMetric : logicalMetrics) {
            MetricStrategy strategy = resolvedStrategies.get(logicalMetric);
            sql.append(", ").append(strategy.buildSqlExpression(logicalMetric));
        }
        
        // 3. From physical datasource
        sql.append(" FROM \"").append(physicalTable).append("\" WHERE 1=1 ");

        // 4. Filters (Securely parameterized, even if they use expressions)
        List<Map<String, String>> parameters = new ArrayList<>();
        if (filters != null && !filters.isEmpty()) {
            for (FilterDto filter : filters) {
                DimensionConfig filterDimConfig = dimensionTranslationMap.get(filter.logicalField());
                if (filterDimConfig == null) {
                    throw new IllegalArgumentException("Filter dimension not mapped: " + filter.logicalField());
                }
                appendFilterCondition(sql, parameters, filterDimConfig, filter);
            }
        }
        
        // 5. Group By (Must perfectly match the SELECT expression)
        sql.append(" GROUP BY ").append(formatDimension(targetDimConfig));

        return Map.of(
            "query", sql.toString(),
            "parameters", parameters
        );
    }

    /**
     * The heart of the new architecture:
     * If it's an expression (like CASE WHEN), wrap it in parentheses safely.
     * If it's a standard column (like BRANCH_CODE), wrap it in double quotes.
     */
    private String formatDimension(DimensionConfig config) {
        if (config.isExpression()) {
            return "(" + config.physicalSql() + ")";
        } else {
            return "\"" + config.physicalSql() + "\"";
        }
    }

    private void appendFilterCondition(StringBuilder sql, List<Map<String, String>> parameters, DimensionConfig config, FilterDto filter) {
        if ("EQUALS".equalsIgnoreCase(filter.operator())) {
            sql.append(" AND ").append(formatDimension(config)).append(" = ? ");
            parameters.add(Map.of("type", "VARCHAR", "value", String.valueOf(filter.value())));
        } else {
            throw new IllegalArgumentException("Unsupported filter operator: " + filter.operator());
        }
    }
}


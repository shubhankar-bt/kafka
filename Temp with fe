    return contextSource;
}

@Bean
public PoolingContextSource poolingContextSource() {
    PoolingContextSource poolingSource = new PoolingContextSource();
    poolingSource.setDirContextValidator(new DefaultDirContextValidator());
    poolingSource.setContextSource(targetContextSource());
    poolingSource.setTestOnBorrow(true); // Ensures the connection is alive before using it
    poolingSource.setTestWhileIdle(true); 
    poolingSource.setMaxTotal(50);       // Max active connections
    poolingSource.setMaxIdle(10);        // Keep 10 idle connections ready for traffic spikes
    return poolingSource;
}

@Bean
public LdapTemplate ldapTemplate() {
    LdapTemplate template = new LdapTemplate(poolingContextSource()); // Use the pooled source
    template.setIgnorePartialResultException(true);
    template.setIgnoreNameNotFoundException(true);
    return template;
}











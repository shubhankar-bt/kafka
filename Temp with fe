package com.fincore.NotificationService.service;

import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;

import java.util.Map;

@Service
@Slf4j
public class KafkaConnectAdminService {

    private final RestTemplate restTemplate = new RestTemplate();

    // In application.properties, set this to your K8s service URL
    // e.g., kafka.connect.url=http://kafka-connect:8083
    @Value("${kafka.connect.url:http://localhost:8083}")
    private String connectUrl;

    /**
     * Get status of a specific connector
     */
    public Object getConnectorStatus(String connectorName) {
        String url = connectUrl + "/connectors/" + connectorName + "/status";
        try {
            ResponseEntity<Object> response = restTemplate.getForEntity(url, Object.class);
            return response.getBody();
        } catch (Exception e) {
            log.error("Failed to fetch connector status", e);
            return Map.of("error", e.getMessage(), "status", "UNREACHABLE");
        }
    }

    /**
     * Create or Update a Connector (Your JSON config)
     */
    public Object deployConnector(String connectorName, Map<String, Object> configMap) {
        // We use PUT /connectors/{name}/config to create OR update
        String url = connectUrl + "/connectors/" + connectorName + "/config";
        try {
            restTemplate.put(url, configMap);
            return getConnectorStatus(connectorName);
        } catch (Exception e) {
            log.error("Failed to deploy connector", e);
            throw new RuntimeException("Deployment failed: " + e.getMessage());
        }
    }

    /**
     * Restart a failed connector or its tasks
     */
    public void restartConnector(String connectorName) {
        String url = connectUrl + "/connectors/" + connectorName + "/restart?includeTasks=true";
        try {
            restTemplate.postForLocation(url, null);
        } catch (Exception e) {
            log.error("Failed to restart connector", e);
            throw new RuntimeException("Restart failed");
        }
    }

    /**
     * Delete the connector entirely
     */
    public void deleteConnector(String connectorName) {
        String url = connectUrl + "/connectors/" + connectorName;
        try {
            restTemplate.delete(url);
        } catch (Exception e) {
            log.error("Failed to delete connector", e);
        }
    }
}


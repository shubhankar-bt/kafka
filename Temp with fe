package com.fincore.gateway.repository;

import com.fincore.gateway.dto.BranchCircleProjection;
import com.fincore.gateway.model.User; // using an arbitrary entity to satisfy JpaRepository, though we only use native queries here
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;

@Repository
public interface BranchRepository extends JpaRepository<User, String> {

    /**
     * Native query to fetch Branch and Circle details by performing a LEFT JOIN.
     * LEFT JOIN ensures that even if a branch doesn't have a mapped circle, 
     * the query won't fail and will still return the branch name.
     */
    @Query(value = """
            SELECT 
                b.NAME AS branchName, 
                c.CIRCLE_CODE AS circleCode, 
                c.CIRCLE_NAME AS circleName, 
                c.BRANCH_CODE AS circleBranch 
            FROM BRANCH_MASTER b
            LEFT JOIN CIRCLE_MASTER c ON b.CIRCLE_CODE = c.CIRCLE_CODE
            WHERE b.CODE = :branchCode
            FETCH FIRST 1 ROWS ONLY
            """, nativeQuery = true)
    BranchCircleProjection findBranchAndCircleDetails(@Param("branchCode") String branchCode);
}


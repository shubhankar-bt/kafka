export default WelcomeScreen;

















import React, { useState, useRef, useEffect, useCallback, useMemo } from "react";
import { useSelector } from "react-redux";
import { Box, Fab, Tooltip, Fade, Typography, Drawer, Paper } from "@mui/material";
import KeyboardArrowDownIcon from "@mui/icons-material/KeyboardArrowDown";

// Separated Components
import ChatAnimations from "./ChatAnimations";
import ChatHeader from "./ChatHeader";
import ChatInput from "./ChatInput";
import TypingIndicator from "./TypingIndicator";
import ChatBubble from "./ChatBubble";
import WelcomeScreen from "./WelcomeScreen";

// Services & Utilities
import { generateId } from "./chatUtils";
import { sendMessageSSE, trackFaqClick } from "./chatApiService";

const ChatWidget = ({ isOpen, setIsOpen, hasLaunched, setHasLaunched }) => {
  const [messages, setMessages] = useState([]);
  const [isLoading, setIsLoading] = useState(false);
  const [isClosing, setIsClosing] = useState(false);
  const [streamingMessageId, setStreamingMessageId] = useState(null);
  const [isScrolledUp, setIsScrolledUp] = useState(false);

  const scrollRef = useRef(null);
  const abortRef = useRef(null);
  const token = useSelector((state) => state.auth.token);
  const selectedMenuItem = useSelector((state) => state.menus.selectedMenuItem);

  const currentScreenName = useMemo(
    () => selectedMenuItem?.title || "Dashboard",
    [selectedMenuItem],
  );

  const handleScroll = () => {
    if (!scrollRef.current) return;
    setIsScrolledUp(
      scrollRef.current.scrollHeight -
        scrollRef.current.scrollTop -
        scrollRef.current.clientHeight >
        60,
    );
  };

  const scrollToBottom = useCallback(
    (force = false) => {
      if (scrollRef.current && (force || !isScrolledUp)) {
        scrollRef.current.scrollTo({
          top: scrollRef.current.scrollHeight,
          behavior: "smooth",
        });
      }
    },
    [isScrolledUp],
  );

  useEffect(
    () => scrollToBottom(false),
    [messages, isLoading, streamingMessageId, scrollToBottom],
  );

  const handleStreamMessage = useCallback(
    async (apiMessage, displayMessage) => {
      setMessages((prev) => [
        ...prev,
        {
          id: generateId(),
          role: "user",
          content: displayMessage || apiMessage,
          timestamp: new Date(),
          feedback: null,
        },
      ]);
      setIsLoading(true);
      scrollToBottom(true);

      if (abortRef.current) abortRef.current.abort();
      abortRef.current = new AbortController();
      const botId = generateId();

      const pushOrUpdateBotMessage = (token, isStream, responseData = null) => {
        setMessages((prev) => {
          const exists = prev.some((msg) => msg.id === botId);
          if (exists)
            return prev.map((msg) => {
              if (msg.id === botId && msg.interrupted) return msg;

              return msg.id === botId
                ? {
                    ...msg,
                    content: msg.content + (token || ""),
                    isStreaming: isStream,
                    response: responseData || msg.response,
                  }
                : msg;
            });
          return [
            ...prev,
            {
              id: botId,
              role: "bot",
              content: token || "",
              timestamp: new Date(),
              feedback: null,
              isStreaming: isStream,
              response: responseData,
            },
          ];
        });
      };

      const handlers = {
        onStart: () => {},
        onToken: (token) => {
          setIsLoading(false);
          setStreamingMessageId(botId);
          pushOrUpdateBotMessage(token, true);
        },
        onEnd: (data) => {
          setStreamingMessageId(null);
          setIsLoading(false);
          pushOrUpdateBotMessage("", false, {
            responseType: "TEXT_REPLY",
            logId: data.logId,
            navigationLink: data.navigationLink,
            navigationLabel: data.navigationLabel,
          });
        },
        onSuggestion: (data) => {
          setIsLoading(false);
          setStreamingMessageId(null);
          pushOrUpdateBotMessage(data.botReply, false, {
            responseType: "SUGGESTION",
            items: data.items,
            logId: data.logId,
          });
        },
        onTextReply: (data) => {
          setIsLoading(false);
          setStreamingMessageId(null);
          pushOrUpdateBotMessage(data.botReply, false, {
            responseType: "TEXT_REPLY",
            logId: data.logId,
          });
        },
        onEscalation: (data) => {
          setIsLoading(false);
          setStreamingMessageId(null);
          pushOrUpdateBotMessage(data.botReply, false, {
            responseType: "ESCALATION_OFFER",
            logId: data.logId,
          });
        },
        onError: (err) => {
          setIsLoading(false);
          setStreamingMessageId(null);
          pushOrUpdateBotMessage(err || "Error connecting.", false);
        },
      };

      try {
        await sendMessageSSE(
          { userMessage: apiMessage, currentScreen: currentScreenName, token },
          handlers,
          abortRef.current,
        );
      } catch {}
    },
    [token, scrollToBottom, currentScreenName],
  );

  const handleQuickAction = (label, slashCommand) => {
    let apiMessage = label;
    if (slashCommand) {
      if (slashCommand === "/action module")
        apiMessage = `${slashCommand} ${currentScreenName}`;
      else apiMessage = slashCommand;
    }
    if (!slashCommand || slashCommand === "/action faq") trackFaqClick(label);
    handleStreamMessage(apiMessage, label);
  };

  const handleStopStreaming = () => {
    if (abortRef.current) abortRef.current.abort();

    setMessages((prev) =>
      prev.map((msg) =>
        msg.id === streamingMessageId || (msg.role === "bot" && msg.isStreaming)
          ? { ...msg, isStreaming: false, interrupted: true }
          : msg,
      ),
    );

    setStreamingMessageId(null);
    setIsLoading(false);
  };

  return (
    <>
      <ChatAnimations />
      <Drawer
        className={isClosing ? "animate-chat-close" : "animate-chat-open"}
        anchor="right"
        open={isOpen}
        onClose={() => isOpen(false)}
        sx={{
          "& .MuiDrawer-paper": {
            width: 400,
            p: 0,
            position: "fixed",
            display: "flex",
            flexDirection: "column",
            boxShadow: 44,
            border: "1px solid",
            borderColor: "divider",
            bgcolor: "background.paper",
            backdropFilter: "blur(20px)",
          },
        }}
      >
        <ChatHeader
          onMinimize={() => {
            setIsClosing(true);
            setTimeout(() => {
              setIsOpen(false);
              setIsClosing(false);
            }, 250);
          }}
          onClearChat={() => {
            abortRef.current?.abort();
            setMessages([]);
          }}
        />
        <Box
          ref={scrollRef}
          onScroll={handleScroll}
          className="chat-scrollbar"
          sx={{
            flex: 1,
            overflowY: "auto",
            display: "flex",
            flexDirection: "column",
            justifyContent: "flex-start",
            position: "relative",
          }}
        >
          {messages.length === 0 ? (
            <Box sx={{ width: "100%" }}>
              <WelcomeScreen
                onQuickAction={handleQuickAction}
                showTypewriter={hasLaunched}
              />
            </Box>
          ) : (
            <Box sx={{ px: 2, py: 2, pb: 8 }}>
              {messages.map((msg) => (
                <ChatBubble
                  key={msg.id}
                  message={msg}
                  onSuggestionClick={handleStreamMessage}
                  onFeedback={(id, f) =>
                    setMessages((prev) =>
                      prev.map((m) =>
                        m.id === id
                          ? { ...m, feedback: m.feedback === f ? null : f }
                          : m,
                      ),
                    )
                  }
                />
              ))}
              {isLoading && <TypingIndicator />}
            </Box>
          )}
          <Box
            sx={{
              position: "sticky",
              bottom: 10,
              left: 0,
              right: 0,
              display: "flex",
              justifyContent: "center",
              gap: 1,
              pointerEvents: "none",
            }}
          >
            <Fade in={isScrolledUp}>
              <Tooltip title="Scroll to bottom">
                <Fab
                  size="small"
                  color="primary"
                  onClick={() => scrollToBottom(true)}
                  sx={{
                    pointerEvents: "auto",
                    width: 36,
                    height: 36,
                    minHeight: 36,
                  }}
                >
                  <KeyboardArrowDownIcon />
                </Fab>
              </Tooltip>
            </Fade>
          </Box>
        </Box>

        <Box
          component={Paper}
          sx={{
            background:
              "linear-gradient(90deg, rgba(162,141,240,0.3), rgba(93,63,211,0.8))",
            p: 1.5,
          }}
        >
          <ChatInput
            onSend={handleStreamMessage}
            onStop={handleStopStreaming}
            isLoading={isLoading || !!streamingMessageId}
          />

          <Typography
            variant="caption"
            align="center"
            display="block"
            sx={{
              mt: 1,
              color: "text.primary",
              fontSize: "0.75rem",
            }}
          >
            AI can make mistakes. Verify important info.
          </Typography>
        </Box>
      </Drawer>
    </>
  );
};

export default ChatWidget;
















        String clientIp = getClientIp(request);
        
        // 1. Pre-Auth Rate Limiting (Prevents LDAP DOS & SMS Fraud)
        return otpSessionService.checkIpRateLimit(clientIp)
            // 2. Standard flow: Fetch User -> Check Locks -> AD/DB Auth

export default function ChatWidget() {
  const [isOpen, setIsOpen] = useState(false);
  const [messages, setMessages] = useState([]);
  const [isLoading, setIsLoading] = useState(false);
  const [isClosing, setIsClosing] = useState(false);
  const [hasLaunched, setHasLaunched] = useState(false);
  const [streamingMessageId, setStreamingMessageId] = useState(null);
  const [isScrolledUp, setIsScrolledUp] = useState(false);
  
  const scrollRef = useRef(null);
  const abortRef = useRef(null);
  const token = useSelector((state) => state.auth.token);
  const selectedMenuItem = useSelector((state) => state.menus.selectedMenuItem);

  const currentScreenName = useMemo(() => selectedMenuItem?.title || "Dashboard", [selectedMenuItem]);

  const handleScroll = () => {
    if (!scrollRef.current) return;
    setIsScrolledUp(scrollRef.current.scrollHeight - scrollRef.current.scrollTop - scrollRef.current.clientHeight > 60);
  };

  const scrollToBottom = useCallback((force = false) => {
    if (scrollRef.current && (force || !isScrolledUp)) {
      scrollRef.current.scrollTo({ top: scrollRef.current.scrollHeight, behavior: "smooth" });
    }
  }, [isScrolledUp]);

  useEffect(() => scrollToBottom(false), [messages, isLoading, streamingMessageId, scrollToBottom]);

  const handleStreamMessage = useCallback(async (apiMessage, displayMessage) => {
    setMessages((prev) => [...prev, { id: generateId(), role: "user", content: displayMessage || apiMessage, timestamp: new Date(), feedback: null }]);
    setIsLoading(true);
    scrollToBottom(true);

    if (abortRef.current) abortRef.current.abort();
    abortRef.current = new AbortController();
    const botId = generateId();

    const pushOrUpdateBotMessage = (token, isStream, responseData = null) => {
      setMessages((prev) => {
        const exists = prev.some((msg) => msg.id === botId);
        if (exists) return prev.map((msg) => msg.id === botId ? { ...msg, content: msg.content + (token || ""), isStreaming: isStream, response: responseData || msg.response } : msg);
        return [...prev, { id: botId, role: "bot", content: token || "", timestamp: new Date(), feedback: null, isStreaming: isStream, response: responseData }];
      });
    };

    const handlers = {
      onStart: () => {}, 
      onToken: (token) => { setIsLoading(false); setStreamingMessageId(botId); pushOrUpdateBotMessage(token, true); },
      onEnd: (data) => { setStreamingMessageId(null); setIsLoading(false); pushOrUpdateBotMessage("", false, { responseType: "TEXT_REPLY", logId: data.logId, navigationLink: data.navigationLink, navigationLabel: data.navigationLabel }); },
      onSuggestion: (data) => { setIsLoading(false); setStreamingMessageId(null); pushOrUpdateBotMessage(data.botReply, false, { responseType: "SUGGESTION", items: data.items, logId: data.logId }); },
      onTextReply: (data) => { setIsLoading(false); setStreamingMessageId(null); pushOrUpdateBotMessage(data.botReply, false, { responseType: "TEXT_REPLY", logId: data.logId }); },
      onEscalation: (data) => { setIsLoading(false); setStreamingMessageId(null); pushOrUpdateBotMessage(data.botReply, false, { responseType: "ESCALATION_OFFER", logId: data.logId }); },
      onError: (err) => { setIsLoading(false); setStreamingMessageId(null); pushOrUpdateBotMessage(err || "Error connecting.", false); },
    };

    try {
      await sendMessageSSE({ userMessage: apiMessage, currentScreen: currentScreenName, token }, handlers, abortRef.current);
    } catch {}
  }, [token, scrollToBottom, currentScreenName]);

  const handleQuickAction = (label, slashCommand) => {
    let apiMessage = label;
    if (slashCommand) {
      if (slashCommand === "/action module") apiMessage = `${slashCommand} ${currentScreenName}`;
      else apiMessage = slashCommand;
    }
    if (!slashCommand || slashCommand === "/action faq") trackFaqClick(label);
    handleStreamMessage(apiMessage, label);
  };

  if (!isOpen) {
    return (
      <>
        <ChatAnimations />
        <Fab onClick={() => { setIsOpen(true); setHasLaunched(true); }} className="fab-pulse" color="primary" sx={{ position: "fixed", bottom: 24, right: 24, zIndex: 50, width: 60, height: 60 }}>
          <FinCoreIcon size={58} glow animated />
        </Fab>
      </>
    );
  }

  return (
    <>
      <ChatAnimations />
      <Box className={isClosing ? "animate-chat-close" : "animate-chat-open"} sx={{ position: "fixed", bottom: 24, right: 24, zIndex: 50, width: 390, height: 650, display: "flex", flexDirection: "column", borderRadius: 3, overflow: "hidden", boxShadow: (theme) => theme.palette.baseShadow || 24, border: "1px solid", borderColor: "divider", bgcolor: "background.paper", backdropFilter: "blur(20px)" }}>
        <ChatHeader onMinimize={() => { setIsClosing(true); setTimeout(() => { setIsOpen(false); setIsClosing(false); }, 250); }} onClearChat={() => { abortRef.current?.abort(); setMessages([]); }} />
        <Box ref={scrollRef} onScroll={handleScroll} className="chat-scrollbar" sx={{ flex: 1, overflowY: "auto", display: "flex", flexDirection: "column", position: "relative" }}>
          {messages.length === 0 ? <WelcomeScreen onQuickAction={handleQuickAction} showTypewriter={hasLaunched} /> : (
            <Box sx={{ px: 2, py: 2, pb: 8 }}>
              {messages.map((msg) => <ChatBubble key={msg.id} message={msg} onSuggestionClick={handleStreamMessage} onFeedback={(id, f) => setMessages(prev => prev.map(m => m.id === id ? { ...m, feedback: m.feedback === f ? null : f } : m))} />)}
              {isLoading && <TypingIndicator />}
            </Box>
          )}
          <Box sx={{ position: "sticky", bottom: 10, left: 0, right: 0, display: "flex", justifyContent: "center", gap: 1, pointerEvents: "none" }}>
            <Fade in={!!streamingMessageId || isLoading}><Button variant="contained" size="small" color="error" startIcon={<StopCircleIcon />} onClick={() => { abortRef.current?.abort(); setStreamingMessageId(null); setIsLoading(false); }} sx={{ pointerEvents: "auto", borderRadius: 5, boxShadow: 3 }}>Stop</Button></Fade>
            <Fade in={isScrolledUp}><Tooltip title="Scroll to bottom"><Fab size="small" color="primary" onClick={() => scrollToBottom(true)} sx={{ pointerEvents: "auto", width: 36, height: 36, minHeight: 36 }}><KeyboardArrowDownIcon /></Fab></Tooltip></Fade>
          </Box>
        </Box>
        <ChatInput onSend={handleStreamMessage} isLoading={isLoading || !!streamingMessageId} />
      </Box>
    </>
  );
}


package com.fincore.helpservice.controller;

import com.fincore.commonutilities.jwt.JwtUtil;
import com.fincore.helpservice.dto.HelpRequestDTO;
import com.fincore.helpservice.model.HelpQuestionEntity;
import com.fincore.helpservice.repository.HelpQuestionRepository;
import com.fincore.helpservice.service.DocumentIngestionService;
import com.fincore.helpservice.service.FinCoreChatAgent;
import com.fincore.helpservice.service.HelpAnalyticsService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.data.redis.core.StringRedisTemplate;
import org.springframework.http.HttpStatus;
import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.servlet.mvc.method.annotation.SseEmitter;

import java.util.List;
import java.util.Map;

@RestController
@RequestMapping("/api/help")
@RequiredArgsConstructor
@Slf4j
public class HelpController {

    private final JwtUtil jwtUtil;
    private final FinCoreChatAgent chatAgent;
    private final HelpQuestionRepository questionRepository;
    private final HelpAnalyticsService analyticsService;
    private final DocumentIngestionService ingestionService;
    private final StringRedisTemplate redisTemplate;

    private static final String STRICT_MODE_KEY = "fincore:ai:strict_mode";

    // ========================================================================
    // CHAT & FAQ ENDPOINTS (Existing)
    // ========================================================================
    @GetMapping("/faqs")
    public ResponseEntity<List<HelpQuestionEntity>> getGlobalFaqs(@RequestHeader("Authorization") String token) {
        return ResponseEntity.ok(questionRepository.findGlobalFaqs());
    }

    @PostMapping("/feedback")
    public ResponseEntity<Void> submitChatFeedback(@RequestHeader("Authorization") String token, @RequestBody Map<String, Object> payload) {
        analyticsService.updateFeedback(Long.valueOf(payload.get("logId").toString()), (Boolean) payload.get("isHelpful"));
        return ResponseEntity.ok().build();
    }

    @PostMapping("/faqs/track")
    public ResponseEntity<Void> trackFaqClick(@RequestBody Map<String, String> payload) {
        chatAgent.incrementFaqPopularity(payload.get("questionText"));
        return ResponseEntity.ok().build();
    }

    @PostMapping(value = "/chat", produces = MediaType.TEXT_EVENT_STREAM_VALUE)
    public SseEmitter handleChatQuery(@RequestHeader("Authorization") String token, @RequestBody HelpRequestDTO request) {
        String userId = jwtUtil.getUserIdFromToken(token);
        String roleId = String.valueOf(jwtUtil.getUserRoleFromToken(token));
        return chatAgent.handleStreamChat(userId, roleId, request.getUserMessage(), request.getCurrentScreen());
    }

    // ========================================================================
    // ADMIN ENDPOINTS (New Features)
    // ========================================================================

    // 1. Manually Trigger Vector DB Ingestion
    @PostMapping("/admin/ingest")
    public ResponseEntity<String> triggerManualIngestion(@RequestHeader("Authorization") String token) {
        String roleId = String.valueOf(jwtUtil.getUserRoleFromToken(token));
        if (!"10".equals(roleId)) {
            return ResponseEntity.status(HttpStatus.FORBIDDEN).body("Only Admin (Role 10) can trigger data ingestion.");
        }
        
        // Triggers the Java 21 Virtual Thread in the background
        boolean started = ingestionService.triggerManualIngestion();
        
        if (started) {
            return ResponseEntity.accepted().body("Data ingestion started in the background. It may take a few minutes to reflect in chats.");
        } else {
            return ResponseEntity.status(HttpStatus.CONFLICT).body("Ingestion is already currently running.");
        }
    }

    // 2. Toggle Strict Mode
    @PostMapping("/admin/strict-mode")
    public ResponseEntity<String> toggleStrictMode(@RequestHeader("Authorization") String token, @RequestBody Map<String, Boolean> payload) {
        String roleId = String.valueOf(jwtUtil.getUserRoleFromToken(token));
        if (!"10".equals(roleId)) {
            return ResponseEntity.status(HttpStatus.FORBIDDEN).body("Only Admin (Role 10) can change AI settings.");
        }

        Boolean isStrict = payload.getOrDefault("enabled", true);
        redisTemplate.opsForValue().set(STRICT_MODE_KEY, String.valueOf(isStrict));
        
        log.info("[ADMIN] FinCore AI Strict Mode changed to: {}", isStrict);
        return ResponseEntity.ok("Strict Mode successfully set to " + isStrict);
    }
    
    // Helper to get current Strict Mode status for UI toggle rendering
    @GetMapping("/admin/strict-mode")
    public ResponseEntity<Boolean> getStrictModeStatus(@RequestHeader("Authorization") String token) {
        String roleId = String.valueOf(jwtUtil.getUserRoleFromToken(token));
        if (!"10".equals(roleId)) return ResponseEntity.status(HttpStatus.FORBIDDEN).build();

        String status = redisTemplate.opsForValue().get(STRICT_MODE_KEY);
        // Default to true if not set
        return ResponseEntity.ok(status == null || Boolean.parseBoolean(status));
    }
}



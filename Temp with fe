import org.springframework.ldap.pool2.factory.PoolingContextSource;
import org.springframework.ldap.pool2.validation.DefaultDirContextValidator;

// Replace your contextSource() bean with this:
@Bean
public LdapContextSource targetContextSource() {
    LdapContextSource contextSource = new LdapContextSource();
    contextSource.setUrl(ldapUrl);
    contextSource.setBase(ldapBaseDn);
    contextSource.setUserDn(ldapUsername);
    contextSource.setPassword(ldapPassword);
    
    Map<String, Object> baseEnv = new HashMap<>();
    if (ldapUrl.toLowerCase().startsWith("ldaps")) {
        baseEnv.put("java.naming.security.protocol", "ssl");
    }
    baseEnv.put("com.sun.jndi.ldap.connect.timeout", "1500");
    baseEnv.put("com.sun.jndi.ldap.read.timeout", "3000");
    baseEnv.put("java.naming.referral", "ignore");
    
    contextSource.setBaseEnvironmentProperties(baseEnv);
    return contextSource;
}

@Bean
public PoolingContextSource poolingContextSource() {
    PoolingContextSource poolingSource = new PoolingContextSource();
    poolingSource.setDirContextValidator(new DefaultDirContextValidator());
    poolingSource.setContextSource(targetContextSource());
    poolingSource.setTestOnBorrow(true); // Ensures the connection is alive before using it
    poolingSource.setTestWhileIdle(true); 
    poolingSource.setMaxTotal(50);       // Max active connections
    poolingSource.setMaxIdle(10);        // Keep 10 idle connections ready for traffic spikes
    return poolingSource;
}

@Bean
public LdapTemplate ldapTemplate() {
    LdapTemplate template = new LdapTemplate(poolingContextSource()); // Use the pooled source
    template.setIgnorePartialResultException(true);
    template.setIgnoreNameNotFoundException(true);
    return template;
}










import reactor.core.scheduler.Scheduler;
import reactor.core.scheduler.Schedulers;

@Configuration
public class LdapSchedulerConfig {
    
    // Creates a dedicated thread pool for LDAP. 
    // 50 threads max, with a queue size of 1000.
    @Bean
    public Scheduler ldapScheduler() {
        return Schedulers.newBoundedElastic(50, 1000, "ldap-pool");
    }
}

















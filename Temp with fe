@Repository
public interface HelpQuestionRepository extends JpaRepository<HelpQuestionEntity, Long> {

    List<HelpQuestionEntity> findByIsActive(String isActive);

    @Query("SELECT q FROM HelpQuestionEntity q WHERE q.permissionId IS NULL AND q.isActive = 'Y'")
    List<HelpQuestionEntity> findGlobalFaqs();

    // THE FIX: RBAC for Quick Action Pills!
    @Query("SELECT q FROM HelpQuestionEntity q WHERE q.screenName = :screenName AND q.isActive = :isActive AND (q.permissionId IN :userPerms OR q.permissionId IS NULL)")
    List<HelpQuestionEntity> findAllowedQuestions(
            @Param("screenName") String screenName, 
            @Param("isActive") String isActive, 
            @Param("userPerms") List<Long> userPerms);
}

























package com.fincore.analyticsservice.service;

import com.fincore.analyticsservice.dto.DimensionConfig;
import com.fincore.analyticsservice.dto.ViewMetadataContext;
import com.fincore.analyticsservice.model.DrReportView;
import com.fincore.analyticsservice.model.DrViewDimension;
import com.fincore.analyticsservice.model.DrViewMetric;
import com.fincore.analyticsservice.repository.DrReportViewRepository;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.cache.annotation.Cacheable;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

@Service
public class OracleMetadataProviderImpl implements ReportMetadataProvider {

    private static final Logger log = LoggerFactory.getLogger(OracleMetadataProviderImpl.class);
    private final DrReportViewRepository viewRepository;

    public OracleMetadataProviderImpl(DrReportViewRepository viewRepository) {
        this.viewRepository = viewRepository;
    }

    @Override
    @Transactional(readOnly = true)
    @Cacheable(value = "viewMetadataContextCache", key = "#viewCode")
    public ViewMetadataContext getViewContext(String viewCode) {
        log.debug("Fetching physical mapping for viewCode: [{}] from Oracle DB", viewCode);

        DrReportView viewEntity = viewRepository.findByViewCodeActive(viewCode)
                .orElseThrow(() -> new IllegalArgumentException("Invalid or inactive viewCode requested: " + viewCode));

        List<String> orderedHierarchy = viewEntity.getDimensions().stream()
                .map(DrViewDimension::getLogicalName)
                .toList();

        // UPDATED: Now maps the Logical Name to the new DimensionConfig object
        Map<String, DimensionConfig> dimMap = viewEntity.getDimensions().stream()
                .collect(Collectors.toMap(
                        DrViewDimension::getLogicalName, 
                        dim -> new DimensionConfig(dim.getPhysicalColumn(), dim.isExpression())
                ));

        Map<String, String> metricMap = viewEntity.getMetrics().stream()
                .collect(Collectors.toMap(DrViewMetric::getLogicalName, DrViewMetric::getStrategyCode));

        return new ViewMetadataContext(
                viewEntity.getViewCode(),
                viewEntity.getDatasource().getDruidTableName(),
                viewEntity.getRequiredRoleIds(),
                orderedHierarchy,
                dimMap,
                metricMap
        );
    }
}


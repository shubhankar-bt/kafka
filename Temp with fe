package com.fincore.gateway.Service;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.fincore.commonutilities.util.AesEncryptionUtil;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.kafka.core.KafkaTemplate;
import org.springframework.stereotype.Service;
import reactor.core.publisher.Mono;

import java.util.Map;
import java.util.UUID;

/**
 * Publishes encrypted PII payloads to Kafka, ensuring zero-trust
 * data security across the event brokers.
 */
@Slf4j
@Service
@RequiredArgsConstructor
public class OtpKafkaProducer {

    private final KafkaTemplate<String, String> kafkaTemplate;
    private final ObjectMapper mapper;
    private final AesEncryptionUtil aesUtil;

    @Value("${security.internal.kafka-aes-key}")
    private String internalAesKey;

    @Value("${spring.profiles.active:dev}")
    private String currentEnvironment;

    public Mono<Void> publishOtpEvent(String txId, String mobile, String email, String plainOtp, String userName) {
        
        return Mono.fromCallable(() -> {
            // 1. Build Flexible Payload for Communication Service
            Map<String, Object> payload = Map.of(
                "eventId", UUID.randomUUID().toString(),
                "eventType", "LOGIN_OTP",
                "txId", txId,
                "environment", currentEnvironment.toUpperCase(),
                "channels", new String[]{"SMS", "EMAIL"},
                "templateId", "AUTH_LOGIN_OTP_V1",
                "recipients", Map.of(
                        "mobile", mobile != null ? mobile : "", 
                        "email", email != null ? email : ""
                ),
                "templateData", Map.of(
                        "otpPlaintext", plainOtp, 
                        "expiryMins", "5", 
                        "userName", userName != null ? userName : "User"
                ),
                "timestamp", java.time.Instant.now().toString()
            );

            String jsonString = mapper.writeValueAsString(payload);

            // 2. Encrypt Payload before it hits the broker
            return aesUtil.encrypt(jsonString, internalAesKey);
            
        }).flatMap(encryptedString -> {
            // 3. Convert CompletableFuture to Mono for non-blocking IO
            return Mono.fromFuture(
                kafkaTemplate.send("fincore.auth.otp.priority", txId, encryptedString)
            );
        }).doOnSuccess(result -> log.info("Encrypted OTP event published to Kafka for txId={}", txId))
          .doOnError(e -> log.error("CRITICAL: Kafka publish failed for txId={}", txId, e))
          .then();
    }
}


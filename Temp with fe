    private Mono<ResponseEntity<ApiResponse<?>>> generateSessionAndTokens(UserDto user, ServerHttpResponse response) {
        Map<String, Object> claimsMap = mapper.convertValue(user.getUser(), new TypeReference<>() {});
        String accessToken = HmacJwtUtil.generate(hmacSecret, user.getUserId(), accessTokenTtl, claimsMap);
        Map<String, Object> refreshClaims = Map.of("type", "refresh");

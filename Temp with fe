apiVersion: apps/v1
kind: Deployment
metadata:
  name: dashboard-deployment
  namespace: uat-cbops1
spec:
  replicas: 1
  selector:
    matchLabels:
      app: dashboard-backend
  template:
    metadata:
      labels:
        app: dashboard-backend
    spec:
      containers:
      - name: dashboard-container
        image: h06vksharbor.corp.ad.sbi/cbops/dashboard-service:UAT06
        envFrom:
            - configMapRef:
                name: uat-common-app-config
            - secretRef:
                name: uat-common-app-secret            
        env:
            # 1. Force Spring Boot into the UAT profile
            - name: SPRING_PROFILES_ACTIVE
              value: "uat"
            # 2. Dynamically inject the namespace! This overrides application.properties
            - name: KUBERNETES_NAMESPACE
              valueFrom:
                fieldRef:
                  fieldPath: metadata.namespace
        ports:
        - containerPort: 9015
        imagePullPolicy: Always
---
apiVersion: v1
kind: Service
metadata:
  name: dashboard-service
  namespace: uat-cbops1
spec:
  selector:
    app: dashboard-backend
  ports:
    - name: http
      protocol: TCP
      port: 80
      targetPort: 9015
  type: ClusterIP

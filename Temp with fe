package com.fincore.NotificationService.service;

import io.fabric8.kubernetes.api.model.Pod;
import io.fabric8.kubernetes.api.model.apps.Deployment;
import io.fabric8.kubernetes.client.KubernetesClient;
import io.fabric8.kubernetes.client.KubernetesClientBuilder;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;

import java.util.HashMap;
import java.util.List;
import java.util.Map;

@Service
@Slf4j
public class KubernetesAdminService {

    // Automatically connects to the cluster using the pod's service account
    private final KubernetesClient client = new KubernetesClientBuilder().build();

    // Pulls the namespace dynamically from application.properties (e.g., be-test, be-uat)
    @Value("${kubernetes.namespace:be-test}")
    private String namespace;

    /**
     * Get the status of a Deployment (e.g., "debezium-server" or "kafka")
     */
    public Map<String, Object> getDeploymentStatus(String deploymentName) {
        Map<String, Object> status = new HashMap<>();
        try {
            Deployment deployment = client.apps().deployments()
                    .inNamespace(namespace)
                    .withName(deploymentName)
                    .get();

            if (deployment == null) {
                status.put("status", "NOT_FOUND");
                return status;
            }

            Integer readyReplicas = deployment.getStatus().getReadyReplicas();
            Integer desiredReplicas = deployment.getSpec().getReplicas();

            status.put("desiredReplicas", desiredReplicas != null ? desiredReplicas : 0);
            status.put("readyReplicas", readyReplicas != null ? readyReplicas : 0);
            status.put("status", (readyReplicas != null && readyReplicas > 0) ? "RUNNING" : "STOPPED");

        } catch (Exception e) {
            log.error("Error fetching status for {}", deploymentName, e);
            status.put("status", "ERROR");
            status.put("message", e.getMessage());
        }
        return status;
    }

    /**
     * Start or Stop Debezium by scaling the replicas
     */
    public void scaleDeployment(String deploymentName, int replicas) {
        try {
            client.apps().deployments()
                    .inNamespace(namespace)
                    .withName(deploymentName)
                    .scale(replicas);
            log.info("Scaled {} to {} replicas", deploymentName, replicas);
        } catch (Exception e) {
            log.error("Failed to scale deployment {}", deploymentName, e);
            throw new RuntimeException("Failed to scale: " + e.getMessage());
        }
    }

    /**
     * Restart a deployment (Equivalent to kubectl rollout restart)
     */
    public void restartDeployment(String deploymentName) {
        try {
            client.apps().deployments()
                    .inNamespace(namespace)
                    .withName(deploymentName)
                    .rolling().restart();
            log.info("Restarted deployment: {}", deploymentName);
        } catch (Exception e) {
            log.error("Failed to restart {}", deploymentName, e);
            throw new RuntimeException("Failed to restart: " + e.getMessage());
        }
    }

    /**
     * Fetch the last N lines of logs for a deployment
     */
    public String getDeploymentLogs(String deploymentName, int tailLines) {
        try {
            // Find the active pod for this deployment
            List<Pod> pods = client.pods().inNamespace(namespace).withLabel("app", deploymentName).list().getItems();
            
            if (pods.isEmpty()) {
                return "No active pods found for " + deploymentName + ". Is it stopped?";
            }

            // Get logs from the first pod found
            return client.pods()
                    .inNamespace(namespace)
                    .withName(pods.get(0).getMetadata().getName())
                    .tailingLines(tailLines)
                    .getLog();
        } catch (Exception e) {
            log.error("Failed to fetch logs for {}", deploymentName, e);
            return "Error fetching logs: " + e.getMessage();
        }
    }
}



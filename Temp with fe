        log.info("Check-User info user id: {} , ip : {}", userId, rawClientIp);

        if (isIpBlocked(rawClientIp)) {
            VerifyUserDTO blockedResponse = VerifyUserDTO.builder().userId(userId).message("Access denied: Your IP address is blocked.").userStatus(Constants.RESTRICTED).build();
            return Mono.just(ApiResponse.success(blockedResponse, "Access Restricted"));
        }

        if (rsaPublicPem == null || rsaPublicPem.isBlank()) {
            return Mono.just(ApiResponse.error("Public key not configured on server", "CONFIG_ERROR"));

    job_name        => 'SYNC_PERMISSIONS_TO_AI_HELP',
    job_type        => 'PLSQL_BLOCK',
    job_action      => '
      BEGIN
        MERGE INTO help_question_master hqm
        USING (
            SELECT 
                MENU_ID, 
                MENU_TITLE, 
                MENU_SUBMENU, 
                MENU_ACTION,
                MENU_DESCRIPTION,
                MENU_URL,
                ''Y'' as IS_ACTIVE 
            FROM permissions
            WHERE MENU_URL IS NOT NULL
        ) p
        ON (hqm.permission_id = p.MENU_ID)
        
        -- CASE 1: SCREEN EXISTS (Updates URL & Title, PRESERVES AI Answers)
        WHEN MATCHED THEN 
          UPDATE SET 
            hqm.screen_name = p.MENU_TITLE,
            hqm.action_link = p.MENU_URL,
            hqm.is_active = p.IS_ACTIVE
            
        -- CASE 2: BRAND NEW SCREEN (Generates Dynamic AI Context)
        WHEN NOT MATCHED THEN 
          INSERT (
            question_id, screen_name, question_text, answer_content, 
            permission_id, action_link, action_label, pro_tip, is_active

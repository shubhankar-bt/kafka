package com.fincore.helpservice.service;

import com.fincore.helpservice.model.HelpFaqEntity;
import com.fincore.helpservice.model.HelpQuestionEntity;
import com.fincore.helpservice.model.KnowledgeBaseEntity;
import com.fincore.helpservice.repository.HelpFaqRepository;
import com.fincore.helpservice.repository.HelpQuestionRepository;
import com.fincore.helpservice.repository.KnowledgeBaseRepository;
import dev.langchain4j.data.document.Document;
import dev.langchain4j.data.document.Metadata;
import dev.langchain4j.data.document.splitter.DocumentSplitters;
import dev.langchain4j.data.embedding.Embedding;
import dev.langchain4j.data.segment.TextSegment;
import dev.langchain4j.model.embedding.EmbeddingModel;
import dev.langchain4j.store.embedding.EmbeddingStore;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.boot.context.event.ApplicationReadyEvent;
import org.springframework.context.event.EventListener;
import org.springframework.data.redis.core.StringRedisTemplate;
import org.springframework.stereotype.Service;

import java.time.Duration;
import java.util.ArrayList;
import java.util.List;

@Service
@RequiredArgsConstructor
@Slf4j
public class DocumentIngestionService {

    private final HelpQuestionRepository questionRepository;
    private final KnowledgeBaseRepository knowledgeBaseRepository;
    private final HelpFaqRepository faqRepository;

    private final EmbeddingModel embeddingModel;
    private final EmbeddingStore<TextSegment> embeddingStore;
    private final StringRedisTemplate redisTemplate;

    // Safe batch size to prevent Ollama Timeouts / OOM
    private static final int BATCH_SIZE = 50;
    
    // Distributed Lock Key to prevent multi-pod collision
    private static final String INGESTION_LOCK_KEY = "fincore:ai:ingestion_lock";

    @EventListener(ApplicationReadyEvent.class)
    public void triggerIngestionOnStartup() {
        // EDGE CASE FIX 2: Distributed Lock for Kubernetes Multi-Pod setups
        // Attempts to set a lock for 10 minutes. 
        Boolean acquiredLock = redisTemplate.opsForValue().setIfAbsent(INGESTION_LOCK_KEY, "LOCKED", Duration.ofMinutes(10));

        if (Boolean.TRUE.equals(acquiredLock)) {
            log.info("[AI-INGEST] Lock acquired. Triggering async data ingestion on a Java 21 Virtual Thread...");
            
            // EDGE CASE FIX 4 (The 100% Fix): True fire-and-forget Virtual Thread.
            // This will NOT block the Spring Boot startup sequence.
            Thread.startVirtualThread(this::performRobustIngestion);
            
        } else {
            log.info("[AI-INGEST] Ingestion lock found. Another instance is already syncing vectors. Skipping.");
        }
    }

    private void performRobustIngestion() {
        long startTime = System.currentTimeMillis();
        try {
            // =========================================================================
            // EDGE CASE FIX 1: THE "GHOST VECTOR" CLEANUP
            // Fetch INACTIVE records and explicitly tell Redis to delete them
            // =========================================================================
            log.info("[AI-INGEST] Step 1: Cleaning up Ghost Vectors (Deactivated records)...");
            List<String> vectorsToDelete = new ArrayList<>();

            questionRepository.findByIsActive("N").forEach(q -> vectorsToDelete.add("PROCEDURAL_" + q.getQuestionId()));
            
            faqRepository.findAll().stream()
                    .filter(f -> "N".equals(f.getIsActive()))
                    .forEach(f -> vectorsToDelete.add("FAQ_" + f.getFaqId()));
                    
            knowledgeBaseRepository.findByIsActive("N").forEach(kb -> {
                // Safely delete up to 20 potential chunks for deactivated KB articles
                for(int i = 0; i < 20; i++) {
                    vectorsToDelete.add("CONCEPTUAL_" + kb.getDocId() + "_chunk_" + i);
                }
            });

            if (!vectorsToDelete.isEmpty()) {
                embeddingStore.removeAll(vectorsToDelete);
                log.info("[AI-INGEST] Purged {} inactive vectors from Redis.", vectorsToDelete.size());
            }

            // =========================================================================
            // ACTIVE DATA PREPARATION
            // =========================================================================
            log.info("[AI-INGEST] Step 2: Preparing Active Vectors...");
            List<TextSegment> allSegments = new ArrayList<>();
            List<String> allIds = new ArrayList<>();

            // 1. PROCEDURAL DATA 
            questionRepository.findByIsActive("Y").forEach(q -> {
                String content = "Module: " + (q.getScreenName() != null ? q.getScreenName() : "General") +
                        "\nQuestion: " + q.getQuestionText() + 
                        "\nAnswer: " + q.getAnswerContent() +
                        (q.getProTip() != null ? "\nPro Tip: " + q.getProTip() : "");

                Metadata metadata = new Metadata()
                        .put("permissionId", q.getPermissionId() != null ? String.valueOf(q.getPermissionId()) : "GLOBAL")
                        .put("actionLink", q.getActionLink() != null ? q.getActionLink() : "NONE")
                        .put("actionLabel", q.getActionLabel() != null ? q.getActionLabel() : "NONE")
                        .put("dataType", "PROCEDURAL");

                allIds.add("PROCEDURAL_" + q.getQuestionId());
                allSegments.add(TextSegment.from(content, metadata));
            });

            // 2. FAQ DATA 
            faqRepository.findAll().stream().filter(f -> "Y".equals(f.getIsActive())).forEach(faq -> {
                String content = "FAQ Question: " + faq.getQuestionText() + "\nAnswer: " + faq.getAnswerContent();
                Metadata metadata = new Metadata()
                        .put("permissionId", "GLOBAL")
                        .put("actionLink", "NONE")
                        .put("actionLabel", "NONE")
                        .put("dataType", "FAQ");

                allIds.add("FAQ_" + faq.getFaqId());
                allSegments.add(TextSegment.from(content, metadata));
            });

            // 3. CONCEPTUAL DATA (Knowledge Base)
            knowledgeBaseRepository.findByIsActive("Y").forEach(kb -> {
                String content = "Topic: " + kb.getTopic() + "\nInformation: " + kb.getContentParagraph();
                Metadata metadata = new Metadata()
                        .put("permissionId", kb.getPermissionId() != null ? String.valueOf(kb.getPermissionId()) : "GLOBAL")
                        .put("actionLink", "NONE")
                        .put("actionLabel", "NONE")
                        .put("dataType", "CONCEPTUAL");

                // EDGE CASE FIX 3: Reduced chunk limit to 1500 chars to respect the mxbai 512-token context limit!
                List<TextSegment> kbChunks = DocumentSplitters.recursive(1500, 150).split(Document.from(content, metadata));
                
                for (int i = 0; i < kbChunks.size(); i++) {
                    allIds.add("CONCEPTUAL_" + kb.getDocId() + "_chunk_" + i);
                    allSegments.add(kbChunks.get(i));
                }
            });

            // =========================================================================
            // BATCH EMBEDDING & BATCH REDIS INGESTION
            // =========================================================================
            if (allSegments.isEmpty()) {
                log.warn("[AI-INGEST] No active documents found in Oracle DB to ingest!");
                return;
            }

            int totalSegments = allSegments.size();
            int successfulBatches = 0;
            
            log.info("[AI-INGEST] Processing {} total segments in batches of {}...", totalSegments, BATCH_SIZE);

            for (int i = 0; i < totalSegments; i += BATCH_SIZE) {
                // Safe sublist logic (e.g. if size is 52, loop 1 is 0-50, loop 2 is 50-52)
                int end = Math.min(totalSegments, i + BATCH_SIZE);
                List<TextSegment> batchSegments = allSegments.subList(i, end);
                List<String> batchIds = allIds.subList(i, end);

                try {
                    List<Embedding> batchEmbeddings = embeddingModel.embedAll(batchSegments).content();
                    embeddingStore.addAll(batchIds, batchEmbeddings, batchSegments);
                    successfulBatches++;
                } catch (Exception e) {
                    log.error("[AI-INGEST] Failed to process batch {}-{}.", i, end - 1, e);
                }
            }

            log.info("[AI-INGEST] COMPLETE. {}/{} batches stored successfully in {} seconds.", successfulBatches, (int) Math.ceil((double) totalSegments / BATCH_SIZE), (System.currentTimeMillis() - startTime) / 1000);

        } catch (Exception e) {
            log.error("[AI-INGEST] FATAL ERROR during background ingestion.", e);
        } finally {
            // Always release the lock so it can run again on the next server restart
            redisTemplate.delete(INGESTION_LOCK_KEY);
            log.info("[AI-INGEST] Ingestion lock released.");
        }
    }
}



package com.fincore.analyticsservice.model;

import jakarta.persistence.*;
import lombok.Getter;
import lombok.Setter;

import java.util.List;

@Entity
@Table(name = "DR_REPORT_VIEW")
@Getter
@Setter
public class DrReportView {
    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    // =========================================================
    // FIX: This is the missing link that caused the crash.
    // It maps to the DR_REPORT table via REPORT_ID foreign key.
    // =========================================================
    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "REPORT_ID", nullable = false)
    private DrReport report;

    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "DATASOURCE_ID", nullable = false)
    private DrDatasource datasource;

    @Column(name = "VIEW_CODE", unique = true, nullable = false)
    private String viewCode;

    // Updated to match our DB alter script for integer Role IDs
    @Column(name = "REQUIRED_ROLE_IDS")
    private String requiredRoleIds;

    @Column(name = "IS_ACTIVE")
    private boolean active;

    @OneToMany(mappedBy = "reportView", fetch = FetchType.LAZY)
    @OrderBy("drillLevel ASC")
    private List<DrViewDimension> dimensions;

    @OneToMany(mappedBy = "reportView", fetch = FetchType.LAZY)
    private List<DrViewMetric> metrics;
}

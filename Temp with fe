package com.fincore.NotificationService.service;

import io.fabric8.kubernetes.client.KubernetesClient;
import io.fabric8.kubernetes.client.KubernetesClientBuilder;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;

@Service
@Slf4j
public class KubernetesAdminService {

    // Fabric8 automatically detects if it is running inside a Kubernetes cluster
    // and uses the ServiceAccount token mounted inside the pod.
    private final KubernetesClient client = new KubernetesClientBuilder().build();

    /**
     * Fetch logs for a deployment (e.g., "kafka-connect" or "kafka")
     */
    public String getDeploymentLogs(String namespace, String deploymentName, int tailLines) {
        try {
            return client.apps().deployments()
                    .inNamespace(namespace)
                    .withName(deploymentName)
                    .getLog(true) // true = pretty/colored
                    .substring(0, Math.min(10000, 10000)); // Protect memory, limit to last 10k chars roughly or use tailing logic
        } catch (Exception e) {
            log.error("Failed to fetch logs for {}", deploymentName, e);
            return "Error fetching logs: " + e.getMessage() + "\n(Did you configure Kubernetes RBAC ServiceAccount permissions for this pod?)";
        }
    }

    /**
     * Restart a pod/deployment (Equivalent to kubectl rollout restart)
     */
    public void restartDeployment(String namespace, String deploymentName) {
        try {
            client.apps().deployments()
                    .inNamespace(namespace)
                    .withName(deploymentName)
                    .rolling().restart();
            log.info("Restarted deployment: {}", deploymentName);
        } catch (Exception e) {
            log.error("Failed to restart deployment", e);
            throw new RuntimeException("Could not restart " + deploymentName);
        }
    }
}


# Use the official Ollama base image
FROM ollama/ollama:latest

# 1. Copy your pre-downloaded models directly into the image layer
COPY ./models /root/.ollama/models

# 2. Copy BOTH of your custom Modelfiles from the contextfiles directory
COPY ./contextfiles/Modelfile /tmp/Modelfile
COPY ./contextfiles/Modelfile-mxbai /tmp/Modelfile-mxbai

# THIS IS THE CRITICAL LINE YOU MISSED! (Fixes the Windows hidden characters)
RUN sed -i 's/\r$//' /tmp/Modelfile && sed -i 's/\r$//' /tmp/Modelfile-mxbai

# 3. Start the daemon briefly, compile BOTH custom models, then kill it
RUN nohup bash -c "ollama serve &" && \
    sleep 5 && \
    ollama create llama-fincore -f /tmp/Modelfile && \
    ollama create mxbai-embed-large -f /tmp/Modelfile-mxbai && \
    pkill ollama

# Expose the standard port
EXPOSE 11434

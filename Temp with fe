package com.fincore.gateway.Service;

import com.fasterxml.jackson.core.JsonProcessingException;
import com.fasterxml.jackson.core.type.TypeReference;
import com.fasterxml.jackson.databind.ObjectMapper;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.data.redis.core.ReactiveStringRedisTemplate;
import org.springframework.http.HttpStatus;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.stereotype.Service;
import org.springframework.web.server.ResponseStatusException;
import reactor.core.publisher.Mono;
import reactor.util.function.Tuple2;
import reactor.util.function.Tuples;

import java.time.Duration;
import java.util.ArrayList;
import java.util.List;
import java.util.Map;

/**
 * ============================================================================
 * OTP LIFECYCLE & REDIS STATE ENGINE PLAN
 * ============================================================================
 * OTP Validity               : 5 min
 * Max Wrong Attempts         : 5
 * Resend Cooldown            : 30 sec
 * Max Resend Count           : 5
 * Lock Type                  : OTP Session Lock (NOT AD/LDAP Account Lock)
 * OTP Regeneration           : New OTP every resend
 * Previous OTP Valid         : No (Overwritten in Redis)
 * Rate Limit Scope           : IP Address (To prevent SMS Toll Fraud)
 *
 * REDIS KEYS PER TRANSACTION (txId):
 * 1. OTP_TX:{txId}       -> { "userId": "...", "otpHash": "..." } (TTL: 5m)
 * 2. OTP_FAILURES:{txId} -> Integer count (TTL: 5m)
 * 3. OTP_RESENDS:{txId}  -> Integer count (TTL: 5m)
 * 4. OTP_COOLDOWN:{txId} -> "locked" (TTL: 30s)
 * 5. RATE_LIMIT:OTP_REQ:IP:{ip} -> Integer count (TTL: 1h)
 * ============================================================================
 */
@Slf4j
@Service
@RequiredArgsConstructor
public class OtpSessionService {

    private final ReactiveStringRedisTemplate redis;
    private final PasswordEncoder passwordEncoder; 
    private final ObjectMapper mapper;

    private static final Duration OTP_VALIDITY = Duration.ofMinutes(5);
    private static final Duration COOLDOWN = Duration.ofSeconds(30);
    private static final int MAX_RESENDS = 5;
    private static final int MAX_FAILURES = 5;
    private static final int MAX_HOURLY_IP_REQUESTS = 50;

    /**
     * Rate limits OTP requests by IP to prevent API abuse and SMS Toll Fraud.
     */
    public Mono<Void> checkIpRateLimit(String clientIp) {
        String key = "RATE_LIMIT:OTP_REQ:IP:" + clientIp;
        return redis.opsForValue().increment(key)
                .flatMap(count -> {
                    if (count == 1) {
                        return redis.expire(key, Duration.ofHours(1)).then();
                    } else if (count > MAX_HOURLY_IP_REQUESTS) {
                        log.warn("SECURITY ALERT: IP {} exceeded hourly OTP limit.", clientIp);
                        return Mono.error(new ResponseStatusException(HttpStatus.TOO_MANY_REQUESTS, "Rate limit exceeded. Try again later."));
                    }
                    return Mono.empty();
                });
    }

    /**
     * Initializes or Updates the OTP state in Redis atomically.
     */
    public Mono<Void> saveOtpState(String txId, String userId, String plainOtp, boolean isResend) {
        String hash = passwordEncoder.encode(plainOtp);
        
        try {
            String payload = mapper.writeValueAsString(Map.of("userId", userId, "otpHash", hash));
            List<Mono<?>> operations = new ArrayList<>();
            
            // 1. Core Transaction (Overwrites old OTP if resend)
            operations.add(redis.opsForValue().set("OTP_TX:" + txId, payload, OTP_VALIDITY));
            // 2. Always reset failures on a fresh OTP dispatch
            operations.add(redis.opsForValue().set("OTP_FAILURES:" + txId, "0", OTP_VALIDITY));
            
            if (!isResend) {
                // First generation: Initialize resend counter
                operations.add(redis.opsForValue().set("OTP_RESENDS:" + txId, "0", OTP_VALIDITY));
            } else {
                // Resend: Extend the TTL of the resend counter so it survives the 5 min window refresh
                operations.add(redis.expire("OTP_RESENDS:" + txId, OTP_VALIDITY));
            }

            return Mono.when(operations)
                    .doOnSuccess(v -> log.info("Saved OTP State txId={} for user={} isResend={}", txId, userId, isResend));
                    
        } catch (JsonProcessingException e) {
            return Mono.error(new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, "Failed to process internal OTP payload"));
        }
    }

    /**
     * Safely executes an OTP Resend, enforcing cooldowns and max limits.
     * Returns Tuple of (NewPlainOtp, UserId).
     */
    public Mono<Tuple2<String, String>> processResend(String txId, String newPlainOtp) {
        String cooldownKey = "OTP_COOLDOWN:" + txId;
        String resendKey = "OTP_RESENDS:" + txId;

        // 1. Atomic Cooldown Lock (SETNX)
        return redis.opsForValue().setIfAbsent(cooldownKey, "locked", COOLDOWN)
                .flatMap(acquired -> {
                    if (!Boolean.TRUE.equals(acquired)) {
                        return Mono.error(new ResponseStatusException(HttpStatus.TOO_MANY_REQUESTS, "Please wait 30 seconds before requesting another OTP."));
                    }

                    // 2. Atomic Increment Resends
                    return redis.opsForValue().increment(resendKey)
                            .flatMap(resendCount -> {
                                if (resendCount > MAX_RESENDS) {
                                    return Mono.error(new ResponseStatusException(HttpStatus.TOO_MANY_REQUESTS, "Maximum OTP resend limit exceeded."));
                                }

                                // 3. Fetch userId, update TX, and return Tuple
                                return getUserIdFromTx(txId)
                                        .switchIfEmpty(Mono.error(new ResponseStatusException(HttpStatus.UNAUTHORIZED, "Transaction expired.")))
                                        .flatMap(userId -> saveOtpState(txId, userId, newPlainOtp, true)
                                                .thenReturn(Tuples.of(newPlainOtp, userId)));
                            });
                });
    }

    /**
     * Verifies the OTP using constant-time cryptographic matching (BCrypt).
     */
    public Mono<String> verifyOtp(String txId, String inputOtp) {
        String txKey = "OTP_TX:" + txId;
        String failKey = "OTP_FAILURES:" + txId;

        return redis.opsForValue().get(txKey)
                .switchIfEmpty(Mono.error(new ResponseStatusException(HttpStatus.UNAUTHORIZED, "OTP Session Expired or Invalid Transaction.")))
                .flatMap(payload -> {
                    try {
                        Map<String, String> data = mapper.readValue(payload, new TypeReference<>() {});
                        String userId = data.get("userId");
                        String storedHash = data.get("otpHash");

                        if (passwordEncoder.matches(inputOtp, storedHash)) {
                            // SUCCESS: Terminate transaction to prevent replay attacks
                            return redis.delete(txKey).thenReturn(userId);
                        } else {
                            // FAILURE: Atomic increment
                            return redis.opsForValue().increment(failKey)
                                    .flatMap(failCount -> {
                                        if (failCount >= MAX_FAILURES) {
                                            // Enforce Session Lockout (Do NOT lock AD account)
                                            return redis.delete(txKey)
                                                    .then(Mono.error(new ResponseStatusException(HttpStatus.UNAUTHORIZED, "Maximum wrong attempts exceeded. Session locked.")));
                                        }
                                        return Mono.error(new ResponseStatusException(HttpStatus.BAD_REQUEST, "Invalid OTP. Attempts remaining: " + (MAX_FAILURES - failCount)));
                                    });
                        }
                    } catch (JsonProcessingException e) {
                        return Mono.error(new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, "Redis payload corruption"));
                    }
                });
    }

    private Mono<String> getUserIdFromTx(String txId) {
        return redis.opsForValue().get("OTP_TX:" + txId)
                .flatMap(payload -> {
                    try {
                        Map<String, String> map = mapper.readValue(payload, new TypeReference<>() {});
                        return Mono.just(map.get("userId"));
                    } catch (JsonProcessingException e) { 
                        return Mono.error(new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, "Redis payload corruption"));
                    }
                });
    }
}



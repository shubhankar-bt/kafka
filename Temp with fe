package com.fincore.commonutilities.util;

import org.springframework.stereotype.Component;

import javax.crypto.Cipher;
import javax.crypto.KeyGenerator;
import javax.crypto.SecretKey;
import javax.crypto.spec.GCMParameterSpec;
import javax.crypto.spec.SecretKeySpec;
import java.nio.charset.StandardCharsets;
import java.security.NoSuchAlgorithmException;
import java.security.SecureRandom;
import java.util.Base64;

/**
 * Standard utility for AES-256-GCM Payload Encryption.
 * Shared across all Fincore microservices.
 */
@Component
public class AesEncryptionUtil {

    private static final String ALGORITHM = "AES/GCM/NoPadding";
    private static final int TAG_LENGTH_BIT = 128; // 16 bytes authentication tag
    private static final int KEY_SIZE = 256;

    /**
     * Generates a cryptographically secure 256-bit AES Key.
     * To be called by the Login/Auth Service upon successful authentication.
     */
    public String generateBase64SessionKey() {
        try {
            KeyGenerator keyGen = KeyGenerator.getInstance("AES");
            SecureRandom secureRandom = new SecureRandom();
            keyGen.init(KEY_SIZE, secureRandom);
            SecretKey secretKey = keyGen.generateKey();
            return Base64.getEncoder().encodeToString(secretKey.getEncoded());
        } catch (NoSuchAlgorithmException e) {
            throw new RuntimeException("AES Algorithm not found", e);
        }
    }

    /**
     * Decrypts an AES-256-GCM encrypted payload.
     * Expects frontend to send format: "Base64(IV):Base64(Ciphertext)"
     */
    public String decrypt(String encryptedPayload, String base64SecretKey) {
        try {
            // 1. Split the IV and the Ciphertext
            String[] parts = encryptedPayload.split(":");
            if (parts.length != 2) {
                throw new IllegalArgumentException("Invalid encrypted payload format. Expected IV:Ciphertext");
            }

            byte[] iv = Base64.getDecoder().decode(parts[0]);
            byte[] cipherText = Base64.getDecoder().decode(parts[1]);
            byte[] decodedKey = Base64.getDecoder().decode(base64SecretKey);

            // 2. Rebuild the Key and GCM Spec
            SecretKey secretKey = new SecretKeySpec(decodedKey, 0, decodedKey.length, "AES");
            GCMParameterSpec gcmParameterSpec = new GCMParameterSpec(TAG_LENGTH_BIT, iv);

            // 3. Decrypt
            Cipher cipher = Cipher.getInstance(ALGORITHM);
            cipher.init(Cipher.DECRYPT_MODE, secretKey, gcmParameterSpec);

            byte[] decryptedText = cipher.doFinal(cipherText);
            
            // 4. Return pure JSON string
            return new String(decryptedText, StandardCharsets.UTF_8);

        } catch (Exception e) {
            throw new SecurityException("Failed to decrypt payload. Data may be tampered or key is invalid.", e);
        }
    }
}



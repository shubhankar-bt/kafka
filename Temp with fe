Frontend Implementation: The Clean Refresh Request
An enterprise best practice is that an endpoint designed to rotate a session via an HttpOnly cookie should never receive the Access Token.
You must isolate the refresh request so it does not inherit the expired ⁠Authorization⁠ header from your global Axios configuration.
Update your Axios Interceptor / Refresh Logic:



// DO NOT use your main 'apiClient' for the refresh call. 
// Create a dedicated, clean Axios instance for auth operations.
const authClient = axios.create({
    baseURL: 'http://your-gateway-url/api',
    withCredentials: true // Crucial: This ensures the Refresh Cookie is sent
});

// Inside your main interceptor catch block:
try {
    // We use the clean client. It sends the cookie, but NO Authorization header.
    const refreshResponse = await authClient.post('/auth/refresh-token', {});

    const newAccessToken = refreshResponse.data.data.accessToken;
    localStorage.setItem('accessToken', newAccessToken);

    // Update your main client with the new token
    apiClient.defaults.headers.common['Authorization'] = `Bearer ${newAccessToken}`;
    originalRequest.headers['Authorization'] = `Bearer ${newAccessToken}`;

    // ... process queue and retry original request
} catch (refreshError) {
    // NOW if this fails, it's a true refresh token expiration
    localStorage.removeItem('accessToken');
    window.location.href = '/    // 1. Fix the constants to match your actual controller paths
    private static final Set<String> WHITELIST = Set.of(
            "/api/auth/check-user",
            "/api/auth/login",
            "/api/auth/logout",
            "/api/auth/refresh-token", // Explicitly whitelist the refresh endpoint
            "/actuator/info",
            "/actuator/health",
            "/api/auth/update-password"
    );

    // 2. Fix the pathMatchers in the SecurityWebFilterChain
    @Bean
    public SecurityWebFilterChain securityWebFilterChain(ServerHttpSecurity http) {
        log.info("Loading SecurityWebFilterChain");
        return http.csrf(ServerHttpSecurity.CsrfSpec::disable)
                .authorizeExchange(exchanges -> exchanges
                        // ADD THE /api PREFIX HERE
                        .pathMatchers("/api/auth/**", "/actuator/**").permitAll() 
                        .anyExchange().authenticated() 
                )
                .oauth2ResourceServer(oauth2 -> oauth2.jwt(Customizer.withDefaults()))
                .addFilterBefore(redisValidationFilter(), SecurityWebFiltersOrder.AUTHORIZATION).build();
    }

    // 3. Fix the helper method
    private boolean isWhitelisted(String path) {
        return WHITELIST.contains(path) ||
               path.startsWith("/api/auth/") || // ADD THE /api PREFIX HERE
               path.startsWith("/actuator/");
    }
















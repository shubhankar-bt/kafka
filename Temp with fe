package com.fincore.NotificationService.controller;

import com.fincore.NotificationService.service.KafkaConnectAdminService;
import com.fincore.NotificationService.service.KubernetesAdminService;
import lombok.RequiredArgsConstructor;
import org.apache.kafka.clients.admin.AdminClient;
import org.apache.kafka.clients.admin.DescribeClusterResult;
import org.springframework.http.ResponseEntity;
import org.springframework.kafka.core.KafkaAdmin;
import org.springframework.web.bind.annotation.*;

import java.util.Map;
import java.util.concurrent.ExecutionException;
import java.util.concurrent.TimeUnit;

@RestController
@RequestMapping("/api/admin")
@RequiredArgsConstructor
public class AdminDashboardController {

    private final KafkaConnectAdminService connectService;
    private final KubernetesAdminService k8sService;
    private final KafkaAdmin kafkaAdmin; // Provided by Spring Kafka

    // --- KAFKA CONNECT MANAGEMENT ---

    @GetMapping("/connectors/{name}/status")
    public ResponseEntity<Object> getConnectorStatus(@PathVariable String name) {
        return ResponseEntity.ok(connectService.getConnectorStatus(name));
    }

    @PostMapping("/connectors/{name}")
    public ResponseEntity<Object> deployConnector(@PathVariable String name, @RequestBody Map<String, Object> config) {
        // You would pass the "config" block of your JSON here from the frontend
        return ResponseEntity.ok(connectService.deployConnector(name, config));
    }

    @PostMapping("/connectors/{name}/restart")
    public ResponseEntity<String> restartConnector(@PathVariable String name) {
        connectService.restartConnector(name);
        return ResponseEntity.ok("Restart command issued successfully");
    }

    // --- KAFKA CLUSTER STATUS ---

    @GetMapping("/kafka/status")
    public ResponseEntity<Object> getKafkaClusterStatus() {
        try (AdminClient adminClient = AdminClient.create(kafkaAdmin.getConfigurationProperties())) {
            DescribeClusterResult cluster = adminClient.describeCluster();
            String clusterId = cluster.clusterId().get(3, TimeUnit.SECONDS);
            int nodeCount = cluster.nodes().get(3, TimeUnit.SECONDS).size();
            
            return ResponseEntity.ok(Map.of(
                    "status", "HEALTHY",
                    "clusterId", clusterId,
                    "brokerCount", nodeCount
            ));
        } catch (Exception e) {
            return ResponseEntity.ok(Map.of("status", "DOWN", "error", e.getMessage()));
        }
    }

    // --- KUBERNETES LOGS & POD MANAGEMENT ---
    // Note: Pass your actual namespace here (e.g., "default", "kafka-ns")

    @GetMapping("/logs/{app}")
    public ResponseEntity<String> getAppLogs(@PathVariable String app, @RequestParam(defaultValue = "default") String namespace) {
        // app could be "kafka" or "connect" (based on your Tanzu deployment names)
        return ResponseEntity.ok(k8sService.getDeploymentLogs(namespace, app, 100));
    }

    @PostMapping("/restart-app/{app}")
    public ResponseEntity<String> restartApp(@PathVariable String app, @RequestParam(defaultValue = "default") String namespace) {
        k8sService.restartDeployment(namespace, app);
        return ResponseEntity.ok(app + " is restarting...");
    }
}


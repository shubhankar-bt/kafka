package com.fincore.commonutilities.security;

import com.fasterxml.jackson.core.JsonProcessingException;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fincore.commonutilities.annotation.EncryptedResponse;
import com.fincore.commonutilities.jwt.JwtUtil;
import com.fincore.commonutilities.util.AesEncryptionUtil;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.core.MethodParameter;
import org.springframework.core.io.Resource;
import org.springframework.data.redis.core.StringRedisTemplate;
import org.springframework.http.HttpHeaders;
import org.springframework.http.MediaType;
import org.springframework.http.ProblemDetail;
import org.springframework.http.converter.HttpMessageConverter;
import org.springframework.http.converter.StringHttpMessageConverter;
import org.springframework.http.server.ServerHttpRequest;
import org.springframework.http.server.ServerHttpResponse;
import org.springframework.http.server.ServletServerHttpRequest;
import org.springframework.security.access.AccessDeniedException;
import org.springframework.web.bind.annotation.ControllerAdvice;
import org.springframework.web.servlet.mvc.method.annotation.ResponseBodyAdvice;

import java.security.GeneralSecurityException;
import java.util.Map;

/**
 * Global Interceptor that encrypts outgoing responses for methods 
 * annotated with @EncryptedResponse.
 */
@Slf4j
@ControllerAdvice
@RequiredArgsConstructor
public class EncryptResponseBodyAdvice implements ResponseBodyAdvice<Object> {

    private final AesEncryptionUtil aesEncryptionUtil;
    private final StringRedisTemplate redisTemplate;
    private final JwtUtil jwtUtil;
    private final ObjectMapper objectMapper;

    private static final String REDIS_AES_KEY_PREFIX = "AES_KEY:";

    @Override
    public boolean supports(MethodParameter returnType, Class<? extends HttpMessageConverter<?>> converterType) {
        return returnType.hasMethodAnnotation(EncryptedResponse.class) || 
               returnType.getDeclaringClass().isAnnotationPresent(EncryptedResponse.class);
    }

    @Override
    public Object beforeBodyWrite(Object body, MethodParameter returnType, MediaType selectedContentType,
                                  Class<? extends HttpMessageConverter<?>> selectedConverterType,
                                  ServerHttpRequest request, ServerHttpResponse response) {

        // EDGE CASE 1: Skip Nulls, File Downloads, and Spring Standard Error Responses
        if (body == null || body instanceof Resource || body instanceof byte[] || body instanceof ProblemDetail) {
            return body;
        }

        // EDGE CASE 2: Custom Error Wrappers (Don't encrypt 400/500 API responses)
        if (body.getClass().getSimpleName().toLowerCase().contains("error")) {
            return body;
        }

        try {
            // 1. Serialize payload to JSON (handle raw Strings cleanly)
            var plainTextPayload = body instanceof String ? (String) body : objectMapper.writeValueAsString(body);

            // 2. Validate Token & Extract User
            var servletRequest = ((ServletServerHttpRequest) request).getServletRequest();
            var token = servletRequest.getHeader(HttpHeaders.AUTHORIZATION);
            if (token == null || !token.toLowerCase().startsWith("bearer ")) {
                throw new AccessDeniedException("No valid Auth token found for encrypted response.");
            }
            
            var userId = jwtUtil.getUserIdFromToken(token.substring(7));

            // 3. Fetch AES Session Key
            var base64AesKey = redisTemplate.opsForValue().get(REDIS_AES_KEY_PREFIX + userId);
            
            // EDGE CASE 3: The Data Leak Trap. NEVER return plaintext if marked for encryption.
            if (base64AesKey == null) {
                log.error("Encryption failed: AES Key missing for user {}", userId);
                throw new IllegalStateException("Encryption Session expired. Cannot securely transmit data.");
            }

            // 4. Perform AES-256-GCM Encryption
            var encryptedString = aesEncryptionUtil.encrypt(plainTextPayload, base64AesKey);

            // 5. Add Header so Frontend knows to decrypt
            response.getHeaders().add("X-Encrypted-Response", "true");

            // 6. Wrap in JSON Map structure
            var wrappedResponse = Map.of("encryptedPayload", encryptedString);

            // EDGE CASE 4: The StringHttpMessageConverter Trap
            // If the controller returns a String, Spring will crash trying to map a Map.
            // We must manually serialize our wrapper map back into a String.
            if (selectedConverterType.equals(StringHttpMessageConverter.class)) {
                return objectMapper.writeValueAsString(wrappedResponse);
            }

            return wrappedResponse;

        } catch (GeneralSecurityException e) {
            log.error("Cryptographic failure during response encryption: {}", e.getMessage());
            // Hard fail - Do not leak plaintext
            throw new SecurityException("Failed to secure sensitive response.", e);
        } catch (JsonProcessingException e) {
            log.error("JSON serialization failure during response encryption: {}", e.getMessage());
            throw new IllegalStateException("Failed to serialize response payload.", e);
        }
    }
}



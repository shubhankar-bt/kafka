        String userId = jwtUtil.getUserIdFromToken(token);
        log.info("Received request to fetch my requests for user : {}", userId);
        return userRequestService.getMyRequests(params, userId);
    }

    @PostMapping("/cancel-request")
    public ResponseEntity cancelRequest(@RequestHeader("Authorization") String token, @RequestBody Map<String, Object> request) {
        log.info("Received request to cancel request with request id : {}", request.get("requestId"));
        return userRequestService.cancelRequest(request, jwtUtil.getUserIdFromToken(token));
    }

    @GetMapping("/validate/userid")
    public ResponseEntity validateUserId(@RequestParam("userId") String userId){
        log.info("Received request to validate user Id : {}", userId);
        return userRequestService.validateUserId(userId);
    }

     */
    public SseEmitter handleChatRequest(String userId, String roleId, HelpRequestDTO request) {
        SseEmitter emitter = new SseEmitter(180000L);
        String userMessage = request.getUserMessage().trim();

        // 1. Double Security Check (Never trust the client payload)
        boolean isEligible = preferenceService.isUserEligibleForAi(roleId);
        boolean useAiEngine = isEligible && request.isAiMode();

        log.info("[CHAT-ROUTER] User: {} | Role: {} | AI-Eligible: {} | UI-Toggle: {} | Routed To: {}", 
                userId, roleId, isEligible, request.isAiMode(), useAiEngine ? "LLM_RAG" : "GUIDED_MENU");

        try {
            if (useAiEngine) {
                return executeAiStreamingEngine(userId, roleId, userMessage, request.getCurrentScreen(), emitter);
            } else {
                return executeGuidedMenuFallback(userId, roleId, userMessage, emitter);
            }
        } catch (Exception e) {
            log.error("Routing failure", e);
            emitter.completeWithError(e);
            return emitter;
        }
    }

    /**
     * ENGINE 1: ZERO-LLM GUIDED MENU (Phase 1 Default)
     * Response Time: < 20ms
     */
    private SseEmitter executeGuidedMenuFallback(String userId, String roleId, String userMessage, SseEmitter emitter) throws Exception {
        
        List<Long> allowedPermIds = permissionService.getAllAllowedPermissionIdsForRole(roleId)
                .stream().map(Long::valueOf).toList();

        if ("/action faq".equalsIgnoreCase(userMessage)) {
            List<String> faqQuestions = faqRepository.findTop10ByIsActiveOrderByViewCountDesc("Y")
                    .stream().map(HelpFaqEntity::getQuestionText).toList();
            emitSuggestionAndClose(emitter, "Here are a few frequently asked questions:", faqQuestions);
            
            // Log analytics for zero-llm hit
            analyticsService.logChatInteraction(userId, "GUIDED_MENU", "FAQ Request", "SUGGESTION", 100);
            return emitter;
        }

        if (userMessage.startsWith("/action module")) {
            String requestedScreen = userMessage.replace("/action module", "").trim();
            List<String> moduleQuestions = questionRepository.findAllowedQuestions(requestedScreen, "Y", allowedPermIds)
                    .stream().map(HelpQuestionEntity::getQuestionText).toList();

            if (moduleQuestions.isEmpty()) {
                emitTextAndClose(emitter, "No specific guides available for " + requestedScreen + " with your current permissions.");
            } else {
                emitSuggestionAndClose(emitter, "Here are a few common questions for the " + requestedScreen + " screen:", moduleQuestions);
            }
            
            analyticsService.logChatInteraction(userId, "GUIDED_MENU", "Module Help: " + requestedScreen, "SUGGESTION", 100);
            return emitter;
        }

        // SECURITY CATCH-ALL: If user manually types a question while in fallback mode
        emitTextAndClose(emitter, "Finny AI is currently in Beta. Please use the quick action buttons to navigate the help menus.");
        analyticsService.logChatInteraction(userId, "GUIDED_MENU", userMessage, "REJECTED_FREE_TEXT", 0);
        return emitter;
    }


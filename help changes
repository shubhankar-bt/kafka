    public ApiResponse<HelpPreferenceDTO> getPreferences(
            @RequestHeader("X-User-Id") String userId, 
            @RequestHeader("X-Role-Id") String roleId) {
            
        return ApiResponse.success(preferenceService.getUserPreferences(userId, roleId));
    }

    /**
     * Called by UI when Admin flips the toggle.
     */
    @PostMapping("/preferences")
    public ApiResponse<HelpPreferenceDTO> updatePreferences(
            @RequestHeader("X-User-Id") String userId, 
            @RequestHeader("X-Role-Id") String roleId,
            @RequestParam boolean aiMode) {
            
        return ApiResponse.success(preferenceService.saveUserPreference(userId, roleId, aiMode));
    }

    /**
     * Stream endpoint updated to pass the full DTO.
     */
    @PostMapping("/chat/stream")
    public SseEmitter streamChat(
            @RequestHeader("X-User-Id") String userId,
            @RequestHeader("X-Role-Id") String roleId,
            @RequestBody @Valid HelpRequestDTO request) {
            
        return chatAgent.handleChatRequest(userId, roleId, request);
    }

package com.fincore.helpservice.service;

import com.fincore.helpservice.dto.HelpPreferenceDTO;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.data.redis.core.StringRedisTemplate;
import org.springframework.stereotype.Service;

import java.time.Duration;
import java.util.Arrays;
import java.util.List;

@Service
@RequiredArgsConstructor
@Slf4j
public class HelpPreferenceService {

    private final StringRedisTemplate redisTemplate;

    @Value("${fincore.help-service.ai-enabled-roles}")
    private String aiEnabledRoles;

    private static final String PREF_KEY_PREFIX = "fincore:help:prefs:";

    public boolean isUserEligibleForAi(String roleId) {
        if (roleId == null) return false;
        List<String> allowedRoles = Arrays.asList(aiEnabledRoles.split(","));
        return allowedRoles.contains(roleId);
    }

    public HelpPreferenceDTO getUserPreferences(String userId, String roleId) {
        boolean isEligible = isUserEligibleForAi(roleId);
        
        // If they aren't eligible, short-circuit and return false immediately
        if (!isEligible) {
            return new HelpPreferenceDTO(false, false);
        }

        // Fetch from Redis. Default to TRUE for Admins if not set yet.
        String redisKey = PREF_KEY_PREFIX + userId;
        String savedPref = redisTemplate.opsForValue().get(redisKey);
        
        boolean aiMode = (savedPref == null) ? true : Boolean.parseBoolean(savedPref);
        
        return new HelpPreferenceDTO(aiMode, true);
    }

    public HelpPreferenceDTO saveUserPreference(String userId, String roleId, boolean aiMode) {
        boolean isEligible = isUserEligibleForAi(roleId);
        
        // Defense in Depth: Do not save true if user is not authorized
        if (!isEligible) {
            log.warn("[SECURITY] Unauthorized user {} attempted to enable AI Mode.", userId);
            return new HelpPreferenceDTO(false, false);
        }

        String redisKey = PREF_KEY_PREFIX + userId;
        // Save to Redis with a 30-day TTL
        redisTemplate.opsForValue().set(redisKey, String.valueOf(aiMode), Duration.ofDays(30));
        
        log.info("[PREFERENCE] User {} updated AI Mode to: {}", userId, aiMode);
        return new HelpPreferenceDTO(aiMode, true);
    }
}






















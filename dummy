-- Index to speed up the main WHERE clause filtering
CREATE INDEX idx_process_run_etl_status 
ON fincore.process_run(etl_date, status, process_id);

-- Index to speed up the JOIN and the SORTING (ORDER BY pr.run_id DESC, pr.start_time DESC)
CREATE INDEX idx_process_run_sorting 
ON fincore.process_run(process_run_id, run_id, start_time);

-- Index to drastically speed up the stage JOIN
CREATE INDEX idx_prs_run_id 
ON fincore.process_run_stage(process_run_id, start_time);

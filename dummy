    public ProcessRun getDagRunInstance(String dagRunId, Integer processId) {
        if (dagRunId == null) {
            throw new AirflowIntegrationException("Invalid Dag Run ID " + dagRunId, HttpStatus.NOT_FOUND);
        }
        log.info("Trying to fetch Process Run with Dag Run ID - {} and Process Id - {}", dagRunId, processId);
        ProcessRun processRun = getProcessRunByAirfowRunId(dagRunId);

        if (processRun == null) {
            throw new AirflowIntegrationException("Dag Run Id is not found " + dagRunId, HttpStatus.NOT_FOUND);
        }

        if (!processRun.getProcessId().equals(processId)) {
            throw new AirflowIntegrationException("Dag Run Id is not associated with any process " + dagRunId, HttpStatus.NOT_FOUND);
        }
        return processRun;
    }

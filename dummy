    @Override
    public SseEmitter getProcessDataSSE() {
        SseEmitter emitter = new SseEmitter(Long.MAX_VALUE);
        processStatusEmitters.add(emitter);

        emitter.onCompletion(() -> processStatusEmitters.remove(emitter));
        emitter.onTimeout(() -> {
            processStatusEmitters.remove(emitter);
            emitter.complete();
        });
        emitter.onError(e -> {
            processStatusEmitters.remove(emitter);
            emitter.completeWithError(e);
        });

        // Send initial connection acknowledgement
        CompletableFuture.runAsync(() -> {
            try {
                emitter.send(SseEmitter.event()
                        .name("connected")
                        .data("Connection established"));
            } catch (IOException | IllegalStateException ex) {
                log.warn("Failed to send initial SSE event: {}", ex.getMessage());
                processStatusEmitters.remove(emitter);
                emitter.complete();
            }
        });

        return emitter;
    }

    @Transactional
    public void updateControllFilemaster(String fileName, Integer value, String etl_date) {
        try {
            SimpleDateFormat sdf = new SimpleDateFormat("dd-MM-yy");
            java.util.Date etlDate = sdf.parse(etl_date);
            int updatedRows = controlFileMasterRepository.updateDataLakeCount(fileName, value, etlDate);
            if (updatedRows > 0) {
                ControlFileMaster fileMaster = controlFileMasterRepository.findByFileNameAndEtlDate(fileName, etlDate);
                if (fileMaster != null) {
                    if (fileMaster.getDataLakeCount() != null &&
                            fileMaster.getHdfsRowCount() != null &&
                            fileMaster.getDataLakeCount().equals(fileMaster.getHdfsRowCount())) {
                        fileMaster.setDatalakeStatus("YES");
                    } else {
                        fileMaster.setDatalakeStatus("NO");
                    }
                }
            }
        } catch (ParseException e) {
            log.error("Error in Parsing the payload");
        }
    }


import io.lettuce.core.dynamic.annotation.Param;
import jakarta.validation.constraints.NotNull;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Modifying;
import org.springframework.data.jpa.repository.Query;

import java.time.LocalDate;
import java.util.List;
import java.util.Optional;

public interface ProcessRunRepository extends JpaRepository<ProcessRun, Long> {
    Optional<ProcessRun> findProcessRunByProcessIdAndRunIdAndEtlDate(long l, int i, LocalDate today);

    @Query(value = "   SELECT MAX(run_id)\n" +
            "               FROM process_run\n" +
            "               WHERE process_id = :processId\n" +
            "                 AND etl_date   = :etlDate", nativeQuery = true)
    Integer getRunId(@Param("processId") Integer processId, @Param("etlDate") LocalDate etlDate);

    ProcessRun findProcessRunByAirflowRunId(String airflowRunId);

    // CHANGED: Implemented Dual-Column logic for the summary CLOB
    @Query(value = """ 
                        SELECT
                            prs.process_run_stage_id AS id,
                            pr.process_run_id,
                            pr.process_id,
                            pr.run_id                AS run_id,
                            pr.remarks               AS process_remarks,
                            pr.execution_remarks     AS process_execution_remarks,
                            pr.status                AS process_status,
                            pm.process_name          AS process_type,
                            prs.stage_id,
                            pr.start_time            AS process_start_time,
                            pr.end_time              AS process_end_time,
                            prs.status               stage_status,
                            prs.remarks              AS stage_remarks,
                            pr.triggered_by,
                            pr.etl_date,
                            CASE WHEN DBMS_LOB.GETLENGTH(prs.summary) <= 4000 THEN DBMS_LOB.SUBSTR(prs.summary, 4000, 1) ELSE NULL END AS summary_short,
                            CASE WHEN DBMS_LOB.GETLENGTH(prs.summary) > 4000 THEN prs.summary ELSE NULL END AS summary_clob,
                            prs.start_time           AS stage_start_time,
                            prs.end_time             AS stage_end_time,
                            prs.source               AS stage_source,
                            pr.airflow_run_id,
                            pm.process_dag_id        AS dag_id,
                            psm.title                AS stage_title,
                            psm.icon                 AS stage_icon
                        FROM
                                 process_run_stage prs
                            JOIN process_run          pr ON pr.process_run_id = prs.process_run_id
                            JOIN process_master       pm ON pm.process_id = pr.process_id
                            LEFT JOIN process_stage_master psm ON psm.stage_id = prs.stage_id
                        WHERE
                            pr.etl_date = :etlDate 
                              AND (:processId IS NULL OR pr.process_id = :processId)   
                              AND   pr.status not in (:excludedStatusesList)
                        ORDER BY  pr.run_id DESC,pr.start_time DESC, prs.start_time ASC
            """, nativeQuery = true)
    List<ProcessRunInfoProj> getProcessInfo(@Param("etlDate") LocalDate etlDate, @Param("processId") Integer processId, @Param("excludedStatusesList") List<Integer> excludedStatusesList);

    ProcessRun getProcessRunByProcessRunId(@NotNull(message = "Process Run Id is Mandatory") Long processRunId);

    @Modifying
    @Query(value = "update process_run set status =:status where process_id=:processId and process_run_id != :processRunId", nativeQuery = true)
    Integer changeProcessState(@Param("processId") Integer processId, @Param("processRunId") Long processRunId, @Param("status") Integer status);

    @Query(value = """
                    select PROCESS_RUN_ID,
                    PROCESS_ID,
                    ETL_DATE,
                    RUN_ID,
                    STATUS,
                    START_TIME,
                    END_TIME,
                    TRIGGERED_BY,
                    AIRFLOW_RUN_ID,
                    REMARKS,
                    EXECUTION_REMARKS from process_run p where p.status=1 and p.etl_date=:etlDate
            """, nativeQuery = true)
    List<ProcessRun> getRunningProcessesForDate(@Param("etlDate") LocalDate etlDate);

    List<ProcessRun> findProcessRunsByStatusAndEtlDate(Integer waitingForApproval, LocalDate etlDate);
}


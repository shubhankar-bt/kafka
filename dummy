    private Map<String, Object> getProcessData(String etlDate, Integer processId) {

        // 1. Fetch dates ONCE to prevent redundant DB roundtrips
        List<FincoreDate> fincoreList = fincoreDateRepository.findAll();
        if (fincoreList.isEmpty()) {
            throw new ResourceNotFoundException("FinCore Date is Empty");
        }
        FincoreDate fincore = fincoreList.getFirst();

        LocalDate etlDateToUse;
        if (StringUtils.hasLength(etlDate)) {
            try {
                etlDateToUse = LocalDate.parse(etlDate); // yyyy-MM-dd
            } catch (DateTimeParseException e) {
                throw new IllegalArgumentException("Invalid etlDate format. Expected yyyy-MM-dd");
            }
        } else {
            // Extracted directly from our single DB fetch
            etlDateToUse = fincore.getEtlDate().toLocalDate();
        }

        Map<String, Object> wrapper = new LinkedHashMap<>();
        Map<String, Object> fincoreJson = new LinkedHashMap<>();
        fincoreJson.put("usersDate", formatDate(fincore.getUsersDate()));
        fincoreJson.put("etlDate", formatDate(fincore.getEtlDate()));
        wrapper.put("fincoreDate", fincoreJson);

        log.info("Process Id Received :{}", processId);

        List<Integer> excludedStatusesList = List.of(Constants.ARCHIVED);

        List<ProcessRunInfoProj> groupedList = processRunRepository.getProcessInfo(etlDateToUse, processId, excludedStatusesList);
        if (groupedList == null || groupedList.isEmpty()) {
            wrapper.put("initialData", Collections.emptyList());
            return wrapper;
        }

        // 2. Pre-allocate map capacity to avoid expensive resizing thresholds
        int initialCapacity = Math.max((int) (groupedList.size() / 0.75f) + 1, 16);
        Map<Long, ProcessRunInfo> map = new LinkedHashMap<>(initialCapacity);
        
        // 3. Replaced slow forEach lambda with a fast, allocation-free loop
        for (ProcessRunInfoProj row : groupedList) {
            ProcessRunInfo process = map.computeIfAbsent(row.getProcessRunId(), id -> {
                ProcessRunInfo p = new ProcessRunInfo();
                p.setProcessRunId(id);
                p.setProcessId(row.getProcessId());
                p.setRunId(row.getRunId());
                p.setProcessType(row.getProcessType());
                p.setProcessStartTime(row.getProcessStartTime());
                p.setProcessEndTime(row.getProcessEndTime());
                p.setTriggeredBy(row.getTriggeredBy());
                p.setEtlDate(row.getEtlDate());
                p.setStatus(row.getProcessStatus());
                p.setExecutionRemarks(row.getProcessExecutionRemarks());
                p.setAirflowRunId(row.getAirflowRunId());
                p.setDagId(row.getDagId());
                p.setStages(new ArrayList<>());
                return p;
            });
            
            ProcessRunStageInfo stage = new ProcessRunStageInfo();
            stage.setStageId(row.getStageId());
            stage.setStageStatus(row.getStageStatus());
            stage.setStageRemarks(row.getStageRemarks());
            stage.setSummary(clobToString(row.getSummary()));
            stage.setStageTitle(row.getStageTitle());
            stage.setStageIcon(row.getStageIcon());
            stage.setStartTime(row.getStageStartTime());
            stage.setEndTime(row.getStageEndTime());
            stage.setStageSource(row.getStageSource());
            
            process.getStages().add(stage);
        }

        wrapper.put("initialData", List.copyOf(map.values()));
        return wrapper;
    }

    /**
     * Converts Oracle CLOB objects to a normal Java String.
     * FIX: Fixed critical memory/cursor leak using try-with-resources.
     * PERF: Utilized JVM optimized Reader.transferTo for extreme speed improvements.
     */
    private String clobToString(Object clobObj) {
        if (clobObj == null) {
            return null;
        }
        
        try {
            if (clobObj instanceof java.sql.Clob clob) {
                // try-with-resources automatically closes the reader, fixing Oracle DB cursor leaks
                try (Reader reader = clob.getCharacterStream();
                     StringWriter writer = new StringWriter()) {
                    
                    // Native IO optimization, bypasses Java heap buffering
                    reader.transferTo(writer); 
                    return writer.toString();
                }
            }
            return clobObj.toString();
        } catch (SQLException | IOException e) {
            log.error("Unable to process the Payload", e);
            return null;
        }
    }

    private Long toMills(Object time) {
        if (time == null) return 0L;
        if (time instanceof java.sql.Timestamp ts) return ts.getTime();
        if (time instanceof java.sql.Date d) return d.getTime();
        if (time instanceof Number n) return n.longValue();
        return 0L;
    }

    private String formatDate(Object date) {
        if (date == null) return null;
        if (date instanceof java.sql.Timestamp ts) return ts.toLocalDateTime().toLocalDate().toString();
        if (date instanceof java.sql.Date d) return d.toLocalDate().toString();
        return String.valueOf(date);
    }

    public void sendProcessStatusUpdates() {
        log.info("Sending Process Update");
        CompletableFuture.runAsync(() -> {
            Iterator<SseEmitter> emitters = processStatusEmitters.iterator();
            
            // Only generate data once per broadcast to save DB hits
            Map<String, Object> data = null;
            if(emitters.hasNext()){
                data = getProcessData(null, null);
            }
            
            while (emitters.hasNext()) {
                SseEmitter emitter = emitters.next();
                try {
                    emitter.send(SseEmitter.event().data(data));
                } catch (IOException e) {
                    log.warn("Client Disconnected, removing SSE emitter");
                    emitter.complete();
                    emitters.remove();
                }
            }
        });
    }

